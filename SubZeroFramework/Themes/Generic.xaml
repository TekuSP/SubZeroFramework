<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:icons="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:not_win="http://uno.ui/not_win"
    xmlns:win="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    mc:Ignorable="not_win">

    <Style TargetType="controls:NavigationMaterialViewItemPresenter">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:NavigationMaterialViewItemPresenter">
                    <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Grid
                            x:Name="CompactIcon"
                            not_win:Margin="-2,0,0,0"
                            win:Margin="1.5,0,0,0"
                            Visibility="Collapsed">
                            <icons:MaterialIcon
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Foreground="{TemplateBinding Foreground}"
                                IconSize="{TemplateBinding IconSize}"
                                Kind="{TemplateBinding Kind}" />
                        </Grid>
                        <StackPanel
                            x:Name="ExpandedContent"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            not_win:Margin="-6,0,0,0"
                            win:Margin="-2.5,0,0,0"
                            Orientation="Horizontal"
                            Spacing="{TemplateBinding Spacing}">
                            <icons:MaterialIcon
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Foreground="{TemplateBinding Foreground}"
                                IconSize="{TemplateBinding IconSize}"
                                Kind="{TemplateBinding Kind}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{TemplateBinding FontFamily}"
                                FontSize="{TemplateBinding FontSize}"
                                FontWeight="{TemplateBinding FontWeight}"
                                Foreground="{TemplateBinding Foreground}"
                                Text="{TemplateBinding Text}" />
                        </StackPanel>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="LayoutStates">
                                <VisualState x:Name="Expanded" />
                                <VisualState x:Name="Compact">
                                    <VisualState.StateTriggers>
                                        <StateTrigger IsActive="{Binding IsCompact, RelativeSource={RelativeSource TemplatedParent}}" />
                                    </VisualState.StateTriggers>
                                    <VisualState.Setters>
                                        <Setter Target="CompactIcon.Visibility" Value="Visible" />
                                        <Setter Target="ExpandedContent.Visibility" Value="Collapsed" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:ElevatedCard">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Elevation" Value="30" />
        <Setter Property="Padding" Value="5" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:ElevatedCard">
                    <!--  We split the shadow layer from the content layer to avoid clipping issues  -->
                    <Grid Margin="{TemplateBinding Margin}" Padding="{TemplateBinding Padding}">
                        <!--  Shadow Layer (behind content)  -->
                        <Border
                            x:Name="ShadowBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <Border.Shadow>
                                <ThemeShadow />
                            </Border.Shadow>
                        </Border>
                        <!--  Content Layer (receives no shadow from itself)  -->
                        <Border Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                ContentTransitions="{TemplateBinding ContentTransitions}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
