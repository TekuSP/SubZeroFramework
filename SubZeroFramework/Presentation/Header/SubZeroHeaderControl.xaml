<UserControl
    x:Class="SubZeroFramework.Presentation.Header.SubZeroHeaderControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SubZeroFramework.Presentation.Header"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid
        Height="130"
        Margin="5,5,5,10"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Top">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid
            x:Name="brandGrid"
            Grid.Column="0"
            Margin="5"
            Background="{StaticResource BrandBackgroundBrush}"
            CornerRadius="8">
            <Image
                Margin="5"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Source="ms-appx:///Assets/Svg/main_logo.png"
                Stretch="UniformToFill" />
        </Grid>

        <Border
            Grid.Column="0"
            Margin="5"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="{ThemeResource OverlayCornerRadius}"
            Loaded="{x:Bind BrandShadow_Loaded}"
            Translation="0,0,30">
            <Border.Shadow>
                <ThemeShadow x:Name="brandShadow" />
            </Border.Shadow>
        </Border>

        <Grid
            x:Name="cardGrid"
            Grid.Column="1"
            Margin="5"
            Background="{StaticResource CardBackgroundBrush}"
            CornerRadius="8">
            <StackPanel Margin="10,3">
                <TextBlock
                    Foreground="White"
                    Style="{ThemeResource SubtitleTextBlockStyle}"
                    Text="System Information" />
            </StackPanel>
        </Grid>

        <Border
            Grid.Column="1"
            Margin="5"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="{ThemeResource OverlayCornerRadius}"
            Loaded="{x:Bind CardShadow_Loaded}"
            Translation="0,0,30 ">
            <Border.Shadow>
                <ThemeShadow x:Name="cardShadow" />
            </Border.Shadow>
        </Border>
    </Grid>
</UserControl>
