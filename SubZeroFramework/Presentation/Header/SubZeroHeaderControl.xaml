<UserControl
    x:Class="SubZeroFramework.Presentation.Header.SubZeroHeaderControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SubZeroFramework.Presentation.Header"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uno="using:Material.Icons.UNO"
    d:DesignHeight="300"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <Grid
        MinHeight="130"
        MaxHeight="180"
        Margin="5,5,5,10"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Top">
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Height="130">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <controls:ElevatedCard Grid.Column="0" Background="{StaticResource BrandBackgroundBrush}">
                <Grid Margin="10">
                    <Image
                        MaxWidth="500"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Source="ms-appx:///Assets/Svg/main_logo.png"
                        Stretch="UniformToFill" />
                </Grid>
            </controls:ElevatedCard>

            <controls:ElevatedCard Grid.Column="1" Background="{StaticResource CardBackgroundBrush}">
                <StackPanel>
                    <TextBlock
                        Foreground="White"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Text="System Information" />
                    <uno:MaterialIconText
                        Margin="0,5,0,0"
                        Kind="{x:Bind ViewModel.ProductIcon, Mode=OneWay}"
                        Text="{x:Bind ViewModel.ProductName, Mode=OneWay}" />
                    <uno:MaterialIconText Kind="Chip" Text="{x:Bind ViewModel.CPUName, Mode=OneWay}" />
                    <uno:MaterialIconText Kind="Memory" Text="{x:Bind ViewModel.RAMAmount, Mode=OneWay}" />
                    <uno:MaterialIconText Kind="Connection" Text="{x:Bind ViewModel.ECDriver, Mode=OneWay}" />
                </StackPanel>
            </controls:ElevatedCard>
        </Grid>
        <Grid
            Grid.Row="1"
            MinHeight="0"
            MaxHeight="50">
            <InfoBar
                Title="{x:Bind ViewModel.ErrorTitle, Mode=OneWay}"
                Margin="4,0"
                IsClosable="{x:Bind ViewModel.IsErrorClosable, Mode=OneWay}"
                IsOpen="{x:Bind ViewModel.IsInError, Mode=OneWay}"
                Message="{x:Bind ViewModel.ErrorReason, Mode=OneWay}"
                Severity="{x:Bind ViewModel.ErrorSeverity, Mode=OneWay}" />
        </Grid>
    </Grid>

</UserControl>
