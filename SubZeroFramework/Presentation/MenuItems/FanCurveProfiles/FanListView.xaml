<UserControl
    x:Class="SubZeroFramework.Presentation.MenuItems.FanCurveProfiles.FanListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fanModels="using:SubZeroFramework.Controls.Fans.Models"
    xmlns:fans="using:SubZeroFramework.Controls.Fans"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <controls:ElevatedCard
        Background="{StaticResource CardBackgroundBrush}"
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch">
        <Grid Padding="14" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="4,2,4,0">
                <TextBlock
                    FontSize="17"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Fans" />
                <TextBlock
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="by location" />
            </Grid>
            <ListView
                Grid.Row="1"
                Padding="0"
                ItemsSource="{x:Bind ViewModel.Fans, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedFan, Mode=TwoWay}"
                SelectionMode="Single">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,0,0,8" />
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <!--  A linked partner is controlled by its leader: disable the row so it can't be selected/edited.  -->
                        <Setter Property="IsEnabled" Value="{Binding IsRowSelectable}" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="fanModels:FanCardModel">
                        <Border
                            Padding="12"
                            Background="{x:Bind RowBackgroundBrush, Mode=OneWay}"
                            BorderBrush="{x:Bind RowBorderBrush, Mode=OneWay}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Opacity="{x:Bind RowOpacity, Mode=OneWay}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid
                                    Width="46"
                                    Height="46"
                                    VerticalAlignment="Center">
                                    <controls:BandRingGaugeView Fan="{x:Bind}" RingThickness="5" />
                                    <material:MaterialIcon
                                        Width="16"
                                        Height="16"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Foreground="{x:Bind SpeedBandBrush, Mode=OneWay}"
                                        Kind="Fan" />
                                </Grid>
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="7">
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind LocationDisplay, Mode=OneWay}" />
                                        <TextBlock
                                            VerticalAlignment="Bottom"
                                            FontSize="11"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{x:Bind SlotLabel, Mode=OneWay}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind RowSpeedDisplay, Mode=OneWay}" />
                                        <TextBlock
                                            VerticalAlignment="Bottom"
                                            FontSize="11"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{x:Bind RowSubLine, Mode=OneWay}" />
                                    </StackPanel>
                                    <Border
                                        Padding="9,1"
                                        HorizontalAlignment="Left"
                                        BorderBrush="{StaticResource TextSecondaryBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Visibility="{x:Bind ModePillVisibility, Mode=OneWay}">
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{x:Bind TargetMode, Mode=OneWay}" />
                                    </Border>
                                    <!--  Linked partner: controlled by its leader; unlink (via the leader's "Applies to") to control it.  -->
                                    <Grid
                                        ColumnSpacing="5"
                                        Visibility="{x:Bind LinkedNoteVisibility, Mode=OneWay}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <material:MaterialIcon
                                            Grid.Column="0"
                                            Width="12"
                                            Height="12"
                                            VerticalAlignment="Top"
                                            Margin="0,2,0,0"
                                            Foreground="{StaticResource BrandPrimaryBrush}"
                                            Kind="LinkVariant" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="11"
                                            Foreground="{StaticResource BrandPrimaryBrush}"
                                            Text="{x:Bind LinkedNoteText, Mode=OneWay}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="2"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Spacing="6">
                                    <fans:FanStatusChipView HorizontalAlignment="Right" Fan="{x:Bind}" />
                                    <Border
                                        Padding="8,2"
                                        HorizontalAlignment="Right"
                                        Background="{StaticResource BrandPrimaryBrush}"
                                        CornerRadius="8"
                                        Visibility="{x:Bind ChangesPendingVisibility, Mode=OneWay}">
                                        <StackPanel
                                            Orientation="Horizontal"
                                            Spacing="5"
                                            VerticalAlignment="Center">
                                            <material:MaterialIcon
                                                Width="11"
                                                Height="11"
                                                VerticalAlignment="Center"
                                                Foreground="White"
                                                Kind="CircleEditOutline" />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="White"
                                                Text="Changes pending" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
            <Border
                Grid.Row="2"
                Padding="2,13,2,2"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,1,0,0">
                <StackPanel Spacing="10">
                    <!--  Status line (staged or clean) — always present  -->
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="7" Visibility="{x:Bind ViewModel.StagedFooterVisibility, Mode=OneWay}">
                        <material:MaterialIcon Width="14" Height="14" VerticalAlignment="Center" Foreground="{StaticResource BrandPrimaryBrush}" Kind="CircleEditOutline" />
                        <TextBlock FontSize="12" Foreground="{StaticResource BrandPrimaryBrush}" Text="{x:Bind ViewModel.StagedSummaryText, Mode=OneWay}" />
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal" Spacing="7" Visibility="{x:Bind ViewModel.CleanFooterVisibility, Mode=OneWay}">
                        <controls:StatusBadgeView
                            Diameter="18"
                            Fill="{StaticResource StatusSuccessBrush}"
                            Glyph="Check"
                            GlyphForeground="#FF14241F"
                            GlyphSize="12" />
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Text="All fans up to date" />
                    </StackPanel>
                    <!--  Commit actions: always visible, enabled per staging state  -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{x:Bind ViewModel.RevertToAppliedCommand, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <material:MaterialIcon Width="14" Height="14" VerticalAlignment="Center" Kind="UndoVariant" />
                                <TextBlock Text="Revert all" />
                            </StackPanel>
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="#FFC42B1C" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FFD33A2B" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FF9E2115" />
                                <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#FF2A2D2D" />
                                <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                                <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#59FFFFFF" />
                            </Button.Resources>
                        </Button>
                        <Button Command="{x:Bind ViewModel.ApplyCustomCurveCommand, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <material:MaterialIcon Width="14" Height="14" VerticalAlignment="Center" Kind="Check" />
                                <TextBlock Text="Apply all" />
                            </StackPanel>
                            <Button.Resources>
                                <SolidColorBrush x:Key="ButtonBackground" Color="#FF0078D7" />
                                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#FF1184E0" />
                                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#FF006CC1" />
                                <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#FF2A2D2D" />
                                <SolidColorBrush x:Key="ButtonForeground" Color="White" />
                                <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                                <SolidColorBrush x:Key="ButtonForegroundDisabled" Color="#59FFFFFF" />
                            </Button.Resources>
                        </Button>
                        <Button Command="{x:Bind ViewModel.TestOnFanCommand, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <material:MaterialIcon Width="14" Height="14" VerticalAlignment="Center" Kind="Play" />
                                <TextBlock Text="Preview all" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </controls:ElevatedCard>
</UserControl>
