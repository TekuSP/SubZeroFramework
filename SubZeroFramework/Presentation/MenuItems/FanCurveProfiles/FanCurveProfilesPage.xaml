<Page
    x:Class="SubZeroFramework.Presentation.MenuItems.FanCurveProfiles.FanCurveProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cardModels="using:SubZeroFramework.Controls.FanCurveProfiles.Models"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fanControls="using:SubZeroFramework.Controls.Fans"
    xmlns:fanModels="using:SubZeroFramework.Controls.Fans.Models"
    xmlns:local="using:SubZeroFramework.Presentation.MenuItems.FanCurveProfiles"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:uen="using:Uno.Extensions.Navigation.UI"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid x:Name="PageRoot" utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20" Spacing="20">

                <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Fan Curve Profiles" />

                <muxc:InfoBar
                    IsClosable="True"
                    IsOpen="{x:Bind ViewModel.IsStatusVisible, Mode=TwoWay}"
                    Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    Severity="{x:Bind ViewModel.StatusSeverity, Mode=OneWay}" />

                <!--  Fan tiles  -->
                <GridView
                    IsItemClickEnabled="False"
                    ItemsSource="{x:Bind ViewModel.Fans, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedFan, Mode=TwoWay}"
                    SelectionMode="Single">
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="0,0,16,16" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="fanModels:FanCardModel">
                            <fanControls:FanCardView IsHitTestVisible="False" ViewModel="{x:Bind Mode=OneWay}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <!--  Editor card  -->
                <controls:ElevatedCard
                    HorizontalContentAlignment="Stretch"
                    Background="{StaticResource CardBackgroundBrush}"
                    Visibility="{x:Bind ViewModel.EditorVisibility, Mode=OneWay}">
                    <StackPanel Padding="20" Spacing="16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock
                                FontSize="20"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{x:Bind ViewModel.SelectedFanHeading, Mode=OneWay}" />
                            <Border
                                Padding="8,2"
                                VerticalAlignment="Center"
                                Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource TextSecondaryBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                                <TextBlock
                                    FontSize="12"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="{x:Bind ViewModel.SelectedFanModeDisplay, Mode=OneWay}" />
                            </Border>
                        </StackPanel>

                        <!--  Mode selector  -->
                        <ItemsControl>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <controls:AutoWrapPanel
                                        HorizontalSpacing="12"
                                        ItemWidth="150"
                                        VerticalSpacing="12" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <Button
                                Padding="12,14"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="{x:Bind ViewModel.AutoTileBackground, Mode=OneWay}"
                                BorderBrush="{StaticResource TextSecondaryBrush}"
                                BorderThickness="1"
                                Command="{x:Bind ViewModel.SetAutoCommand, Mode=OneWay}"
                                CornerRadius="8">
                                <StackPanel HorizontalAlignment="Center" Spacing="6">
                                    <material:MaterialIcon
                                        Width="32"
                                        Height="32"
                                        HorizontalAlignment="Center"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Kind="AutoFix" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="Auto" />
                                </StackPanel>
                                <Button.Resources>
                                    <ResourceDictionary>
                                        <StaticResource x:Key="ButtonPointerOverBackgroundThemeBrush" ResourceKey="BrandSecondaryBrush" />
                                        <StaticResource x:Key="ButtonPressedBackgroundThemeBrush" ResourceKey="BrandPrimaryBrush" />
                                        <StaticResource x:Key="ButtonDisabledBackgroundThemeBrush" ResourceKey="BrandDisabledBrush" />
                                    </ResourceDictionary>
                                </Button.Resources>
                            </Button>
                            <Button
                                Padding="12,14"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="{x:Bind ViewModel.ManualTileBackground, Mode=OneWay}"
                                BorderBrush="{StaticResource TextSecondaryBrush}"
                                BorderThickness="1"
                                Command="{x:Bind ViewModel.SetManualCommand, Mode=OneWay}"
                                CornerRadius="8">
                                <StackPanel HorizontalAlignment="Center" Spacing="6">
                                    <material:MaterialIcon
                                        Width="32"
                                        Height="32"
                                        HorizontalAlignment="Center"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Kind="Tune" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="Manual" />
                                </StackPanel>
                                <Button.Resources>
                                    <ResourceDictionary>
                                        <StaticResource x:Key="ButtonPointerOverBackgroundThemeBrush" ResourceKey="BrandSecondaryBrush" />
                                        <StaticResource x:Key="ButtonPressedBackgroundThemeBrush" ResourceKey="BrandPrimaryBrush" />
                                        <StaticResource x:Key="ButtonDisabledBackgroundThemeBrush" ResourceKey="BrandDisabledBrush" />
                                    </ResourceDictionary>
                                </Button.Resources>
                            </Button>
                            <Button
                                Padding="12,14"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="{x:Bind ViewModel.CustomTileBackground, Mode=OneWay}"
                                BorderBrush="{StaticResource TextPrimaryBrush}"
                                BorderThickness="1"
                                Command="{x:Bind ViewModel.EnterCustomEditorCommand, Mode=OneWay}"
                                CornerRadius="8">
                                <StackPanel HorizontalAlignment="Center" Spacing="6">
                                    <material:MaterialIcon
                                        Width="32"
                                        Height="32"
                                        HorizontalAlignment="Center"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Kind="ChartBellCurve" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="Custom curve" />
                                </StackPanel>
                                <Button.Resources>
                                    <ResourceDictionary>
                                        <StaticResource x:Key="ButtonPointerOverBackgroundThemeBrush" ResourceKey="BrandSecondaryBrush" />
                                        <StaticResource x:Key="ButtonPressedBackgroundThemeBrush" ResourceKey="BrandPrimaryBrush" />
                                        <StaticResource x:Key="ButtonDisabledBackgroundThemeBrush" ResourceKey="BrandDisabledBrush" />
                                    </ResourceDictionary>
                                </Button.Resources>
                            </Button>
                            <Button
                                Padding="12,14"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="{x:Bind ViewModel.MaxTileBackground, Mode=OneWay}"
                                BorderBrush="{StaticResource TextSecondaryBrush}"
                                BorderThickness="1"
                                Command="{x:Bind ViewModel.SetMaxCommand, Mode=OneWay}"
                                CornerRadius="8">
                                <StackPanel HorizontalAlignment="Center" Spacing="6">
                                    <material:MaterialIcon
                                        Width="32"
                                        Height="32"
                                        HorizontalAlignment="Center"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Kind="Speedometer" />
                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="Max" />
                                </StackPanel>
                                <Button.Resources>
                                    <ResourceDictionary>
                                        <StaticResource x:Key="ButtonPointerOverBackgroundThemeBrush" ResourceKey="BrandSecondaryBrush" />
                                        <StaticResource x:Key="ButtonPressedBackgroundThemeBrush" ResourceKey="BrandPrimaryBrush" />
                                        <StaticResource x:Key="ButtonDisabledBackgroundThemeBrush" ResourceKey="BrandDisabledBrush" />
                                    </ResourceDictionary>
                                </Button.Resources>
                            </Button>
                        </ItemsControl>

                        <!--  Auto body  -->
                        <muxc:InfoBar
                            Title="Auto mode active"
                            IsClosable="False"
                            IsOpen="True"
                            Message="The embedded controller is driving this fan based on its built-in policy. No user override is active."
                            Severity="Informational"
                            Visibility="{x:Bind ViewModel.IsAutoBodyVisible, Mode=OneWay}" />

                        <!--  Manual body  -->
                        <StackPanel Spacing="12" Visibility="{x:Bind ViewModel.IsManualBodyVisible, Mode=OneWay}">
                            <TextBlock
                                FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Set a fixed duty cycle. Changes apply automatically after a short pause; use Apply to send immediately." />
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Slider
                                    Grid.Column="0"
                                    Maximum="100"
                                    Minimum="0"
                                    StepFrequency="1"
                                    TickFrequency="10"
                                    Value="{x:Bind ViewModel.ManualDutyPercent, Mode=TwoWay}" />
                                <muxc:NumberBox
                                    Grid.Column="1"
                                    Width="100"
                                    Maximum="100"
                                    Minimum="0"
                                    SmallChange="1"
                                    SpinButtonPlacementMode="Inline"
                                    Value="{x:Bind ViewModel.ManualDutyPercent, Mode=TwoWay}" />
                                <Button
                                    Grid.Column="2"
                                    Command="{x:Bind ViewModel.ApplyManualDutyCommand, Mode=OneWay}"
                                    Content="Apply" />
                            </Grid>
                        </StackPanel>

                        <!--  Max body  -->
                        <muxc:InfoBar
                            Title="Max mode active"
                            IsClosable="False"
                            IsOpen="True"
                            Message="This fan is forced to 100% duty. Expect significantly increased acoustics. Click Auto to release."
                            Severity="Warning"
                            Visibility="{x:Bind ViewModel.IsMaxBodyVisible, Mode=OneWay}" />

                        <!--  Custom body  -->
                        <StackPanel Spacing="14" Visibility="{x:Bind ViewModel.IsCustomBodyVisible, Mode=OneWay}">
                            <muxc:InfoBar
                                Title="Custom curve editor"
                                IsClosable="False"
                                IsOpen="True"
                                Message="Define a temperature/duty curve and pick driving sensors. Applied curves are persisted by the service and restored automatically on the next service start."
                                Severity="Informational" />

                            <Border
                                Padding="12"
                                Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource TextSecondaryBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                                <StackPanel Spacing="6">
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="Left-click empty area to add a point, drag a point to move it, right-click a point to remove it." />
                                    <lvc:CartesianChart
                                        x:Name="CurveChart"
                                        Height="260"
                                        Background="Transparent"
                                        PointerCaptureLost="CurveChart_PointerReleased"
                                        PointerMoved="CurveChart_PointerMoved"
                                        PointerPressed="CurveChart_PointerPressed"
                                        PointerReleased="CurveChart_PointerReleased"
                                        RightTapped="CurveChart_RightTapped"
                                        TooltipPosition="Top">
                                        <lvc:CartesianChart.Series>
                                            <lvc:SeriesCollection>
                                                <lvc:XamlLineSeries
                                                    Fill="{x:Null}"
                                                    GeometryFill="{x:Bind ViewModel.CurveGeometryFillPaint, Mode=OneWay}"
                                                    GeometrySize="12"
                                                    LineSmoothness="0.2"
                                                    Stroke="{x:Bind ViewModel.CurveStrokePaint, Mode=OneWay}"
                                                    Values="{x:Bind ViewModel.CurveSeriesPoints, Mode=OneWay}" />
                                            </lvc:SeriesCollection>
                                        </lvc:CartesianChart.Series>
                                        <lvc:CartesianChart.XAxes>
                                            <lvc:AxesCollection>
                                                <lvc:XamlAxis
                                                    Labeler="{x:Bind ViewModel.CurveTemperatureLabelFormatter, Mode=OneWay}"
                                                    LabelsPaint="{x:Bind ViewModel.CurveAxisLabelsPaint, Mode=OneWay}"
                                                    MaxLimit="135"
                                                    MinLimit="-5"
                                                    MinStep="10"
                                                    SeparatorsPaint="{x:Bind ViewModel.CurveAxisSeparatorsPaint, Mode=OneWay}"
                                                    ShowSeparatorLines="True"
                                                    TextSize="11" />
                                            </lvc:AxesCollection>
                                        </lvc:CartesianChart.XAxes>
                                        <lvc:CartesianChart.YAxes>
                                            <lvc:AxesCollection>
                                                <lvc:XamlAxis
                                                    Labeler="{x:Bind ViewModel.CurveDutyLabelFormatter, Mode=OneWay}"
                                                    LabelsPaint="{x:Bind ViewModel.CurveAxisLabelsPaint, Mode=OneWay}"
                                                    MaxLimit="108"
                                                    MinLimit="-4"
                                                    MinStep="20"
                                                    SeparatorsPaint="{x:Bind ViewModel.CurveAxisSeparatorsPaint, Mode=OneWay}"
                                                    ShowSeparatorLines="True"
                                                    TextSize="11" />
                                            </lvc:AxesCollection>
                                        </lvc:CartesianChart.YAxes>
                                    </lvc:CartesianChart>
                                </StackPanel>
                            </Border>

                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Driving temperature sensors" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.AvailableSensors, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <controls:AutoWrapPanel
                                            HorizontalSpacing="8"
                                            ItemWidth="180"
                                            VerticalSpacing="8" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="cardModels:SensorChipModel">
                                        <ToggleButton
                                            HorizontalAlignment="Stretch"
                                            Content="{x:Bind DisplayName, Mode=OneWay}"
                                            IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="Aggregation:" />
                                <ComboBox
                                    MinWidth="160"
                                    ItemsSource="{x:Bind ViewModel.AggregationModes, Mode=OneTime}"
                                    SelectedItem="{x:Bind ViewModel.SelectedAggregation, Mode=TwoWay}" />
                            </StackPanel>

                            <Border
                                Padding="12"
                                Background="{StaticResource CardBackgroundBrush}"
                                BorderBrush="{StaticResource TextSecondaryBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Visibility="{x:Bind ViewModel.SensorChartVisibility, Mode=OneWay}">
                                <StackPanel Spacing="6">
                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="Last 30 seconds of selected sensors" />
                                    <lvc:CartesianChart
                                        Height="200"
                                        Background="Transparent"
                                        LegendPosition="Bottom"
                                        Series="{x:Bind ViewModel.SensorChartSeries, Mode=OneWay}"
                                        TooltipPosition="Top">
                                        <lvc:CartesianChart.XAxes>
                                            <lvc:AxesCollection>
                                                <lvc:XamlDateTimeAxis
                                                    AnimationsSpeed="0"
                                                    CustomSeparators="{x:Bind ViewModel.SensorChartSeparators, Mode=OneWay}"
                                                    DateFormatter="{x:Bind ViewModel.SensorChartDateFormatter, Mode=OneWay}"
                                                    LabelsPaint="{x:Bind ViewModel.CurveAxisLabelsPaint, Mode=OneWay}"
                                                    MaxLimit="{x:Bind ViewModel.SensorChartMaxLimit, Mode=OneWay}"
                                                    MinLimit="{x:Bind ViewModel.SensorChartMinLimit, Mode=OneWay}"
                                                    SeparatorsPaint="{x:Bind ViewModel.CurveAxisSeparatorsPaint, Mode=OneWay}"
                                                    ShowSeparatorLines="True"
                                                    TextSize="11" />
                                            </lvc:AxesCollection>
                                        </lvc:CartesianChart.XAxes>
                                        <lvc:CartesianChart.YAxes>
                                            <lvc:AxesCollection>
                                                <lvc:XamlAxis
                                                    Labeler="{x:Bind ViewModel.SensorChartTemperatureFormatter, Mode=OneWay}"
                                                    LabelsPaint="{x:Bind ViewModel.CurveAxisLabelsPaint, Mode=OneWay}"
                                                    SeparatorsPaint="{x:Bind ViewModel.CurveAxisSeparatorsPaint, Mode=OneWay}"
                                                    ShowSeparatorLines="True"
                                                    TextSize="11" />
                                            </lvc:AxesCollection>
                                        </lvc:CartesianChart.YAxes>
                                    </lvc:CartesianChart>
                                </StackPanel>
                            </Border>

                            <StackPanel
                                HorizontalAlignment="Right"
                                Orientation="Horizontal"
                                Spacing="8">
                                <Button
                                    MinWidth="96"
                                    Background="#C42B1C"
                                    BorderBrush="#C42B1C"
                                    Command="{x:Bind ViewModel.CancelCustomEditorCommand, Mode=OneWay}"
                                    Content="Cancel"
                                    Foreground="White">
                                    <Button.Resources>
                                        <ResourceDictionary>
                                            <Setter x:Key="cancelPointerOver" Value="#c42b1c" />
                                            <Setter x:Key="pressedOver" Value="#440e09" />
                                            <StaticResource x:Key="ButtonPointerOverBackgroundThemeBrush" ResourceKey="cancelPointerOver" />
                                            <StaticResource x:Key="ButtonPressedBackgroundThemeBrush" ResourceKey="pressedOver" />
                                            <StaticResource x:Key="ButtonDisabledBackgroundThemeBrush" ResourceKey="BrandDisabledBrush" />
                                        </ResourceDictionary>
                                    </Button.Resources>
                                </Button>
                                <Button
                                    MinWidth="96"
                                    Background="{StaticResource BrandPrimaryBrush}"
                                    BorderBrush="{StaticResource BrandPrimaryBrush}"
                                    Command="{x:Bind ViewModel.ApplyCustomCurveCommand, Mode=OneWay}"
                                    Content="Apply"
                                    Foreground="White">
                                    <Button.Resources>
                                        <ResourceDictionary>
                                            <StaticResource x:Key="ButtonPointerOverBackgroundThemeBrush" ResourceKey="BrandSecondaryBrush" />
                                            <StaticResource x:Key="ButtonPressedBackgroundThemeBrush" ResourceKey="BrandPrimaryBrush" />
                                            <StaticResource x:Key="ButtonDisabledBackgroundThemeBrush" ResourceKey="BrandDisabledBrush" />
                                        </ResourceDictionary>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </controls:ElevatedCard>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

