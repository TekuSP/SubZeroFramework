<UserControl
    x:Class="SubZeroFramework.Presentation.MenuItems.FanCurveProfiles.Modes.FanModeGaugeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Shared mode gauge (Auto / Manual / Max): a single segmented current-speed ring + centre RPM/target
          text. One control so every mode body renders the gauge identically. (The target is conveyed by the
          "→ … target" text below the RPM; no inner ghost arc, which read as a confusing double ring.)  -->
    <Grid
        Width="184"
        Height="184"
        VerticalAlignment="Center">
        <!--  Bind the gauge straight through to the coordinator's SelectedFan (which always raises PropertyChanged)
              rather than the mode VM's RefreshVersion-projected SelectedFan, so the ring/RPM never go stale if the
              fan was selected before this body's mode VM attached.  -->
        <controls:BandRingGaugeView Fan="{x:Bind ViewModel.Page.SelectedFan, Mode=OneWay}" RingThickness="14" />
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="34"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="{x:Bind ViewModel.Page.SelectedFan.FanSpeedValueDisplay, Mode=OneWay}" />
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="12"
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="RPM now" />
            <TextBlock
                Margin="0,8,0,0"
                HorizontalAlignment="Center"
                FontSize="13"
                FontWeight="SemiBold"
                Foreground="{StaticResource BrandPrimaryBrush}"
                Text="{x:Bind ViewModel.ModeTargetText, Mode=OneWay}" />
        </StackPanel>
    </Grid>
</UserControl>
