<UserControl
    x:Class="SubZeroFramework.Presentation.MenuItems.FanCurveProfiles.Modes.FanCustomCurveView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SubZeroFramework.Presentation.MenuItems.FanCurveProfiles"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Custom curve body: reuses the full curve editor, bound to the shared coordinator.  -->
    <local:FanCurveEditorView ViewModel="{x:Bind ViewModel.Page, Mode=OneWay}" />
</UserControl>
