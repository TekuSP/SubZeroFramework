<UserControl
    x:Class="SubZeroFramework.Presentation.MenuItems.Modules.Layouts.ModulesFw16View"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:branding="using:SubZeroFramework.Controls.Branding"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.Modules.Models"
    xmlns:modules="using:SubZeroFramework.Controls.Modules"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="SlotCardTemplate" x:DataType="models:ModuleSlotCardModel">
            <modules:ModuleSlotCardView Model="{x:Bind}" Tapped="OnSlotCardTapped" />
        </DataTemplate>
        <DataTemplate x:Key="DeckCardTemplate" x:DataType="models:ModuleDeckCardModel">
            <modules:ModuleDeckCardView Model="{x:Bind}" Tapped="OnDeckCardTapped" />
        </DataTemplate>
    </UserControl.Resources>

    <!--  FW16 chassis map (mockup): expansion-bay banner over slots 1-3 | chassis art | slots 4-6, the selected
          expansion-module hero, then the composable input deck (webcam/fingerprint chips, module PNG tiles,
          touchpad row) and the selected input-deck hero.  -->
    <StackPanel Spacing="16">
        <!--  Star spacer columns keep the chassis map centered regardless of the region host's alignment.  -->
        <Grid ColumnSpacing="14" RowSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Column="1"
                Grid.ColumnSpan="3"
                Padding="16,10"
                HorizontalAlignment="Center"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{x:Bind ViewModel.Page.BayBorderBrush, Mode=OneWay}"
                BorderThickness="1.5"
                CornerRadius="11"
                Tapped="OnBayTapped"
                Visibility="{x:Bind ViewModel.Page.BayVisibility, Mode=OneWay}">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <branding:BrandLogoView
                        VerticalAlignment="Center"
                        FallbackGlyph="ExpansionCardVariant"
                        IconSize="28"
                        Vendor="{x:Bind ViewModel.Page.BayLogoVendor, Mode=OneWay}" />
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Expansion bay" />
                        <TextBlock
                            FontSize="12.5"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{x:Bind ViewModel.Page.BayName, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <ItemsControl
                Grid.Row="1"
                Grid.Column="1"
                VerticalAlignment="Center"
                ItemTemplate="{StaticResource SlotCardTemplate}"
                ItemsSource="{x:Bind ViewModel.Page.LeftSlotCards, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="12" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <Image
                Grid.Row="1"
                Grid.Column="2"
                Height="300"
                VerticalAlignment="Center"
                Source="ms-appx:///Assets/Png/framework-16-top.png"
                Stretch="Uniform" />

            <ItemsControl
                Grid.Row="1"
                Grid.Column="3"
                VerticalAlignment="Center"
                ItemTemplate="{StaticResource SlotCardTemplate}"
                ItemsSource="{x:Bind ViewModel.Page.RightSlotCards, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="12" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Grid>

        <!--  Cards the FFI detected over USB but could not pin to a slot unambiguously.  -->
        <StackPanel Spacing="8" Visibility="{x:Bind ViewModel.Page.DetachedVisibility, Mode=OneWay}">
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="12.5"
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="Detected cards · slot not resolved" />
            <ItemsControl HorizontalAlignment="Center" ItemsSource="{x:Bind ViewModel.Page.DetachedChips, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ModuleInternalChipModel">
                        <Border
                            Height="30"
                            Padding="12,0"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource SurfaceOutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="15">
                            <StackPanel
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="6">
                                <material:MaterialIcon
                                    Width="14"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource StatusInfoBrush}"
                                    Kind="{x:Bind IconKind, Mode=OneWay}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind Name, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Selected expansion module" />
        <modules:ModuleHeroView Source="{x:Bind ViewModel.Page.SelectedExpansionHero, Mode=OneWay}" />

        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Input deck &amp; internal modules" />

        <StackPanel HorizontalAlignment="Center" Spacing="12">
            <ItemsControl HorizontalAlignment="Center" ItemsSource="{x:Bind ViewModel.Page.InternalChips, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ModuleInternalChipModel">
                        <Border
                            Padding="14,10"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource SurfaceOutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="11">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <material:MaterialIcon
                                    Width="16"
                                    Height="16"
                                    HorizontalAlignment="Center"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Kind="{x:Bind IconKind, Mode=OneWay}" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="12.5"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind Name, Mode=OneWay}" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="11.5"
                                    Foreground="{x:Bind StateBrush, Mode=OneWay}"
                                    Text="{x:Bind StateDisplay, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  Both deck rows render through the SAME card template — presumed spacers are ordinary deck
                  cards, so every spacer tile is identical and selectable.  -->
            <ItemsControl HorizontalAlignment="Center" ItemTemplate="{StaticResource DeckCardTemplate}" ItemsSource="{x:Bind ViewModel.Page.DeckTopRowCards, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <ItemsControl
                HorizontalAlignment="Center"
                ItemTemplate="{StaticResource DeckCardTemplate}"
                ItemsSource="{x:Bind ViewModel.Page.TouchpadRowCards, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.Page.TouchpadRowVisibility, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>

        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Selected input-deck module" />
        <modules:ModuleHeroView Source="{x:Bind ViewModel.Page.SelectedDeckCard.Hero, Mode=OneWay}" />
    </StackPanel>
</UserControl>
