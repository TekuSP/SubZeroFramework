<Page
    x:Class="SubZeroFramework.Presentation.MenuItems.Modules.ModulesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="15,0,15,24" Spacing="12">
                <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Modules" />
                <TextBlock
                    FontSize="14"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="Physical module and port maps for this chassis. The interactive map and per-slot details will appear here."
                    TextWrapping="Wrap" />

                <controls:ElevatedCard
                    HorizontalContentAlignment="Stretch"
                    Background="{StaticResource CardBackgroundBrush}">
                    <StackPanel
                        Padding="22"
                        HorizontalAlignment="Center"
                        Spacing="12">
                        <material:MaterialIcon
                            Width="48"
                            Height="48"
                            HorizontalAlignment="Center"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Kind="ExpansionCardVariant" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Module map coming soon" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{x:Bind ViewModel.PlatformFamilyDisplay, Mode=OneWay}" />
                    </StackPanel>
                </controls:ElevatedCard>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
