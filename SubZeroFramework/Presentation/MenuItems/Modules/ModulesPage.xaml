<Page
    x:Class="SubZeroFramework.Presentation.MenuItems.Modules.ModulesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uen="using:Uno.Extensions.Navigation.UI"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="15,0,15,24" Spacing="12">
                <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Modules" />

                <!--  Per-platform layout bodies resolve into this sub-region (FW16 for now; FW12/13/13 Pro and
                      Desktop follow). Platforms without a map yet keep the placeholder card.  -->
                <ContentControl
                    x:Name="LayoutRegionHost"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Top"
                    uen:Region.Attached="True"
                    Visibility="{x:Bind ViewModel.LayoutVisibility, Mode=OneWay}" />

                <controls:ElevatedCard
                    HorizontalContentAlignment="Stretch"
                    Background="{StaticResource CardBackgroundBrush}"
                    Visibility="{x:Bind ViewModel.PlaceholderVisibility, Mode=OneWay}">
                    <StackPanel
                        Padding="22"
                        HorizontalAlignment="Center"
                        Spacing="12">
                        <material:MaterialIcon
                            Width="48"
                            Height="48"
                            HorizontalAlignment="Center"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Kind="ExpansionCardVariant" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Coming soon" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{x:Bind ViewModel.PlatformFamilyDisplay, Mode=OneWay}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="13"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{x:Bind ViewModel.InventorySummaryDisplay, Mode=OneWay}"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </controls:ElevatedCard>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
