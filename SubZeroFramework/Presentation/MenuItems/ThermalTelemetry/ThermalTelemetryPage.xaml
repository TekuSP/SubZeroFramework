<Page
    x:Class="SubZeroFramework.Presentation.MenuItems.ThermalTelemetry.ThermalTelemetryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:thermalControls="using:SubZeroFramework.Controls.Thermal"
    xmlns:thermalModels="using:SubZeroFramework.Controls.Thermal.Models"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="0,0,0,24" Spacing="18">

                <!--  Title + history window selector  -->
                <Grid Margin="15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock
                            FontSize="28"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Thermal telemetry" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="12">
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="History window" />
                        <!--  Segmented pill (ToggleButtons) so the active window floods brand blue (matches design).  -->
                        <Border
                            Padding="3"
                            VerticalAlignment="Center"
                            Background="{StaticResource CardSecondaryBackgroundBrush}"
                            CornerRadius="9">
                            <Border.Resources>
                                <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="#0078D7" />
                                <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#1184E0" />
                                <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="#006CC1" />
                                <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="#FFFFFA" />
                                <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="#FFFFFA" />
                                <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="#FFFFFA" />
                                <SolidColorBrush x:Key="ToggleButtonBackground" Color="Transparent" />
                                <SolidColorBrush x:Key="ToggleButtonBackgroundPointerOver" Color="#22FFFFFF" />
                                <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="#0078D7" />
                                <Thickness x:Key="ToggleButtonBorderThemeThickness">0</Thickness>
                            </Border.Resources>
                            <StackPanel Orientation="Horizontal" Spacing="3">
                                <ToggleButton
                                    Padding="14,6"
                                    Click="HistorySegment_Click"
                                    CornerRadius="6"
                                    IsChecked="{x:Bind ViewModel.IsHistoryWindow0Selected, Mode=OneWay}"
                                    Tag="0">
                                    <TextBlock Text="1 min" />
                                </ToggleButton>
                                <ToggleButton
                                    Padding="14,6"
                                    Click="HistorySegment_Click"
                                    CornerRadius="6"
                                    IsChecked="{x:Bind ViewModel.IsHistoryWindow1Selected, Mode=OneWay}"
                                    Tag="1">
                                    <TextBlock Text="5 min" />
                                </ToggleButton>
                                <ToggleButton
                                    Padding="14,6"
                                    Click="HistorySegment_Click"
                                    CornerRadius="6"
                                    IsChecked="{x:Bind ViewModel.IsHistoryWindow2Selected, Mode=OneWay}"
                                    Tag="2">
                                    <TextBlock Text="15 min" />
                                </ToggleButton>
                                <ToggleButton
                                    Padding="14,6"
                                    Click="HistorySegment_Click"
                                    CornerRadius="6"
                                    IsChecked="{x:Bind ViewModel.IsHistoryWindow3Selected, Mode=OneWay}"
                                    Tag="3">
                                    <TextBlock Text="1 hour" />
                                </ToggleButton>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!--  Device / telemetry meta tiles (darker inner cards, matching the Power telemetry stat tiles)  -->
                <StackPanel Margin="10,0">
                    <controls:ElevatedCard
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel Padding="18,14">
                            <Grid ColumnSpacing="12" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Padding="12"
                                    Background="{StaticResource CardSecondaryBackgroundBrush}"
                                    CornerRadius="10">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <material:MaterialIcon
                                                Width="14"
                                                Height="14"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Kind="Laptop" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="DEVICE" />
                                        </StackPanel>
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.DeviceModelDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="0"
                                    Grid.Column="1"
                                    Padding="12"
                                    Background="{StaticResource CardSecondaryBackgroundBrush}"
                                    CornerRadius="10">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <material:MaterialIcon
                                                Width="14"
                                                Height="14"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Kind="Chip" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="PLATFORM" />
                                        </StackPanel>
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.PlatformDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Padding="12"
                                    Background="{StaticResource CardSecondaryBackgroundBrush}"
                                    CornerRadius="10">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <material:MaterialIcon
                                                Width="14"
                                                Height="14"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Kind="Cog" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="DRIVER" />
                                        </StackPanel>
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.DriverDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="0"
                                    Grid.Column="3"
                                    Padding="12"
                                    Background="{StaticResource CardSecondaryBackgroundBrush}"
                                    CornerRadius="10">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <material:MaterialIcon
                                                Width="14"
                                                Height="14"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Kind="Memory" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="EC BUILD" />
                                        </StackPanel>
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.EcBuildInfoDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Padding="12"
                                    Background="{StaticResource CardSecondaryBackgroundBrush}"
                                    CornerRadius="10">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <material:MaterialIcon
                                                Width="14"
                                                Height="14"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Kind="ClockOutline" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="LAST SEEN" />
                                        </StackPanel>
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.TelemetryObservedDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Padding="12"
                                    Background="{StaticResource CardSecondaryBackgroundBrush}"
                                    CornerRadius="10">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <material:MaterialIcon
                                                Width="14"
                                                Height="14"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Kind="Pulse" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="SERVICE" />
                                        </StackPanel>
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="{x:Bind ViewModel.ServiceStateBrush, Mode=OneWay}"
                                            Text="{x:Bind ViewModel.ServiceStateDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Grid.ColumnSpan="2"
                                    Padding="12"
                                    Background="{StaticResource CardSecondaryBackgroundBrush}"
                                    CornerRadius="10">
                                    <StackPanel Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <material:MaterialIcon
                                                Width="14"
                                                Height="14"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Kind="AlertCircleOutline" />
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="LAST ERROR" />
                                        </StackPanel>
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.LastErrorDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </controls:ElevatedCard>
                </StackPanel>

                <!--  Sensors grid  -->
                <StackPanel Margin="10,0" Spacing="10">
                    <Grid Margin="5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            FontSize="22"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Sensors" />
                        <TextBlock
                            Grid.Column="1"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{x:Bind ViewModel.PlottedSummary, Mode=OneWay}" />
                        <HyperlinkButton
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Command="{x:Bind ViewModel.ToggleSelectAllCommand}"
                            Content="{x:Bind ViewModel.SelectAllLabel, Mode=OneWay}" />
                    </Grid>

                    <GridView
                        IsItemClickEnabled="False"
                        ItemsSource="{x:Bind ViewModel.Sensors, Mode=OneWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollMode="Disabled"
                        SelectionMode="None">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="0,0,12,12" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="thermalModels:ThermalSensorModel">
                                <thermalControls:ThermalSensorTileView Width="210" ViewModel="{x:Bind Mode=OneWay}" />
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>

                <!--  Temperature comparison chart  -->
                <StackPanel Margin="10,0">
                    <controls:ElevatedCard
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Temperature comparison" />

                            <ItemsControl
                                Grid.Row="1"
                                Margin="0,12,0,4"
                                ItemsSource="{x:Bind ViewModel.PlottedSensors, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="thermalModels:ThermalSensorModel">
                                        <StackPanel
                                            Margin="0,0,18,0"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="6">
                                            <Rectangle
                                                Width="14"
                                                Height="3"
                                                VerticalAlignment="Center"
                                                Fill="{x:Bind SeriesBrush, Mode=OneWay}"
                                                RadiusX="2"
                                                RadiusY="2" />
                                            <TextBlock
                                                FontSize="13"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="{x:Bind CardTitle, Mode=OneWay}" />
                                            <TextBlock
                                                FontSize="13"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind TemperatureValueWithUnit, Mode=OneWay}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border
                                Grid.Row="2"
                                Padding="10,6"
                                Background="#FF161F1F"
                                CornerRadius="14">
                                <lvc:CartesianChart
                                    Height="360"
                                    AutoUpdateEnabled="True"
                                    Background="Transparent"
                                    LegendPosition="Hidden"
                                    Series="{x:Bind ViewModel.ThermalHistorySeries, Mode=OneWay}"
                                    TooltipPosition="Top">
                                    <lvc:CartesianChart.XAxes>
                                        <lvc:AxesCollection>
                                            <lvc:XamlDateTimeAxis
                                                AnimationsSpeed="0"
                                                CustomSeparators="{x:Bind ViewModel.ThermalHistorySeparators, Mode=OneWay}"
                                                DateFormatter="{x:Bind ViewModel.ThermalHistoryDateFormatter, Mode=OneWay}"
                                                Interval="0:10:0"
                                                LabelsPaint="{lvc:SolidColorPaint Color={StaticResource ChartSubtleAxisLabelColor}}"
                                                MaxLimit="{x:Bind ViewModel.ThermalHistoryMaxLimit, Mode=OneWay}"
                                                MinLimit="{x:Bind ViewModel.ThermalHistoryMinLimit, Mode=OneWay}"
                                                ShowSeparatorLines="False"
                                                TextSize="12" />
                                        </lvc:AxesCollection>
                                    </lvc:CartesianChart.XAxes>
                                    <lvc:CartesianChart.YAxes>
                                        <lvc:AxesCollection>
                                            <lvc:XamlAxis
                                                Labeler="{x:Bind ViewModel.ThermalLabelFormatter, Mode=OneWay}"
                                                LabelsPaint="{lvc:SolidColorPaint Color={StaticResource ChartSubtleAxisLabelColor}}"
                                                MaxLimit="{x:Bind ViewModel.ThermalHistoryYAxisMaxLimit, Mode=OneWay}"
                                                MinLimit="{x:Bind ViewModel.ThermalHistoryYAxisMinLimit, Mode=OneWay}"
                                                SeparatorsPaint="{lvc:SolidColorPaint Color={StaticResource ChartSeparatorColor}}"
                                                ShowSeparatorLines="True"
                                                TextSize="12" />
                                        </lvc:AxesCollection>
                                    </lvc:CartesianChart.YAxes>
                                </lvc:CartesianChart>
                            </Border>
                        </Grid>
                    </controls:ElevatedCard>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
