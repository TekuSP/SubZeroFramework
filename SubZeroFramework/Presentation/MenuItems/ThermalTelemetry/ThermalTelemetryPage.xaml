<Page
    x:Class="SubZeroFramework.Presentation.MenuItems.ThermalTelemetry.ThermalTelemetryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SubZeroFramework.Presentation.MenuItems.ThermalTelemetry"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:thermalControls="using:SubZeroFramework.Controls.Thermal"
    xmlns:thermalModels="using:SubZeroFramework.Controls.Thermal.Models"
    xmlns:uen="using:Uno.Extensions.Navigation.UI"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="0,0,0,24" Spacing="18">
                <StackPanel Margin="15,0,15,0">
                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Thermal Telemetry" />
                    <TextBlock
                        Margin="0,6,0,0"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Compare sensor temperatures over time with stable current-value cards and selectable chart series." />
                </StackPanel>

                <StackPanel Margin="10,0">
                    <controls:ElevatedCard
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel Padding="14" Spacing="14">
                            <TextBlock
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="System Context" />
                            <Grid ColumnSpacing="12" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    Padding="12"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Device" />
                                        <TextBlock
                                            FontSize="18"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.DeviceModelDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Column="1"
                                    Padding="12"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Platform" />
                                        <TextBlock
                                            FontSize="18"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.PlatformDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Column="2"
                                    Padding="12"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Driver" />
                                        <TextBlock
                                            FontSize="18"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.DriverDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Column="3"
                                    Padding="12"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="EC Build" />
                                        <TextBlock
                                            FontSize="18"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.EcBuildInfoDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Column="4"
                                    Padding="12"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Telemetry Last Seen" />
                                        <TextBlock
                                            FontSize="18"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.TelemetryObservedDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="3*" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    Padding="12"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Service state" />
                                        <TextBlock
                                            FontSize="18"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.ServiceStateDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Column="1"
                                    Padding="12"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Last error" />
                                        <TextBlock
                                            FontSize="16"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.LastErrorDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </controls:ElevatedCard>
                </StackPanel>

                <StackPanel Margin="10,0">
                    <controls:ElevatedCard
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}">
                        <Grid Margin="14">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock
                                        FontSize="22"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="Temperature Comparison" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="Toggle sensors below to compare multiple series on one shared chart." />
                                </StackPanel>

                                <StackPanel Grid.Column="1" MinWidth="180">
                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="History window" />
                                    <ComboBox
                                        Margin="0,6,0,0"
                                        ItemsSource="{x:Bind ViewModel.HistoryWindowOptions, Mode=OneWay}"
                                        SelectedIndex="{x:Bind ViewModel.SelectedHistoryWindowIndex, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>

                            <GridView
                                Grid.Row="1"
                                Margin="-8,16,-8,10"
                                HorizontalAlignment="Stretch"
                                IsItemClickEnabled="False"
                                ItemsSource="{x:Bind ViewModel.Sensors, Mode=OneWay}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.HorizontalScrollMode="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollMode="Disabled"
                                SelectionMode="None">
                                <GridView.ItemContainerStyle>
                                    <Style TargetType="GridViewItem">
                                        <Setter Property="Margin" Value="8,0,8,12" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </GridView.ItemContainerStyle>
                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="thermalModels:ThermalSensorModel">
                                        <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}">
                                            <CheckBox.Content>
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind DisplayName, Mode=OneWay}" />
                                                    <TextBlock Foreground="{x:Bind TemperatureBrush, Mode=OneWay}" Text="{x:Bind TemperatureValueWithUnit, Mode=OneWay}" />
                                                    <TextBlock Foreground="{x:Bind StatusBrush, Mode=OneWay}" Text="{x:Bind StatusText, Mode=OneWay}" />
                                                </StackPanel>
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>

                            <Border
                                Grid.Row="2"
                                Padding="6"
                                Background="#221A1E32"
                                CornerRadius="18">
                                <Grid>
                                    <lvc:CartesianChart
                                        Height="360"
                                        AutoUpdateEnabled="True"
                                        Background="Transparent"
                                        LegendPosition="Top"
                                        Series="{x:Bind ViewModel.ThermalHistorySeries, Mode=OneWay}"
                                        TooltipPosition="Top">
                                        <lvc:CartesianChart.XAxes>
                                            <lvc:AxesCollection>
                                                <lvc:XamlDateTimeAxis
                                                    AnimationsSpeed="0"
                                                    CustomSeparators="{x:Bind ViewModel.ThermalHistorySeparators, Mode=OneWay}"
                                                    DateFormatter="{x:Bind ViewModel.ThermalHistoryDateFormatter, Mode=OneWay}"
                                                    Interval="0:10:0"
                                                    LabelsPaint="{lvc:SolidColorPaint Color='#FFD7D8FF'}"
                                                    MaxLimit="{x:Bind ViewModel.ThermalHistoryMaxLimit, Mode=OneWay}"
                                                    MinLimit="{x:Bind ViewModel.ThermalHistoryMinLimit, Mode=OneWay}"
                                                    SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                    ShowSeparatorLines="True"
                                                    TextSize="12" />
                                            </lvc:AxesCollection>
                                        </lvc:CartesianChart.XAxes>
                                        <lvc:CartesianChart.YAxes>
                                            <lvc:AxesCollection>
                                                <lvc:XamlAxis
                                                    Labeler="{x:Bind ViewModel.ThermalLabelFormatter, Mode=OneWay}"
                                                    LabelsPaint="{lvc:SolidColorPaint Color='#FFD7D8FF'}"
                                                    MaxLimit="100"
                                                    MinLimit="0"
                                                    SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                    ShowSeparatorLines="True"
                                                    TextSize="12" />
                                            </lvc:AxesCollection>
                                        </lvc:CartesianChart.YAxes>
                                    </lvc:CartesianChart>
                                </Grid>
                            </Border>
                        </Grid>
                    </controls:ElevatedCard>
                </StackPanel>

                <StackPanel>
                    <TextBlock
                        Margin="15,0"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Current Sensor State" />
                    <GridView
                        Margin="10,0"
                        IsItemClickEnabled="False"
                        ItemsSource="{x:Bind ViewModel.Sensors, Mode=OneWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollMode="Disabled"
                        SelectionMode="None">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="0,0,12,12" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="thermalModels:ThermalSensorModel">
                                <thermalControls:ThermalStateCardView ViewModel="{x:Bind Mode=OneWay}" />
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
