<UserControl
    x:Class="SubZeroFramework.Presentation.MenuItems.Settings.Sections.SettingsAboutSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.Settings.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  One About row: component name | version value + optional GitHub link.  -->
        <DataTemplate x:Key="AboutRowTemplate" x:DataType="models:AboutRowModel">
            <StackPanel>
                <Grid MinHeight="46" ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="13.5"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="{x:Bind Name}" />

                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontSize="13.5"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="{x:Bind Value, Mode=OneWay}" />

                    <HyperlinkButton
                        Grid.Column="2"
                        Padding="8,4"
                        VerticalAlignment="Center"
                        NavigateUri="{x:Bind LinkUri}"
                        Visibility="{x:Bind LinkVisibility}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <material:MaterialIcon
                                Width="14"
                                Height="14"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource StatusInfoBrush}"
                                Kind="Github" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12.5"
                                Foreground="{StaticResource StatusInfoBrush}"
                                Text="GitHub" />
                        </StackPanel>
                    </HyperlinkButton>
                </Grid>
                <Border Height="1" Background="{StaticResource SurfaceOutlineBrush}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            Padding="24,4,24,24"
            HorizontalAlignment="Stretch"
            Spacing="10">

            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="About SubZero" />
                <TextBlock
                    FontSize="13"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="Version information and project links." />
            </StackPanel>

            <ItemsControl
                MinWidth="560"
                ItemTemplate="{StaticResource AboutRowTemplate}"
                ItemsSource="{x:Bind ViewModel.Page.AboutRows, Mode=OneWay}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
