<UserControl
    x:Class="SubZeroFramework.Presentation.MenuItems.Settings.Sections.SettingsUnitsSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controlsSettings="using:SubZeroFramework.Controls.Settings"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.Settings.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="UnitRowTemplate" x:DataType="models:UnitPreferenceRowModel">
            <StackPanel>
                <controlsSettings:UnitSegmentPickerView Margin="0,7" Item="{x:Bind}" />
                <Border Height="1" Background="{StaticResource SurfaceOutlineBrush}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="980"
            Padding="24,4,24,24"
            HorizontalAlignment="Stretch"
            Spacing="10">

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Display units" />
                    <TextBlock
                        FontSize="13"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Powered by UnitsNet. Changes apply live across every page and are saved on this device." />
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Height="34"
                    Padding="14,0"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderBrush="{StaticResource SurfaceOutlineBrush}"
                    BorderThickness="1"
                    Command="{x:Bind ViewModel.Page.ResetUnitsCommand, Mode=OneWay}"
                    Content="Reset to defaults"
                    CornerRadius="17"
                    FontSize="12.5"
                    Foreground="{StaticResource TextSecondaryBrush}" />
            </Grid>

            <TextBlock
                FontSize="12.5"
                Foreground="{StaticResource StatusWarningBrush}"
                Text="{x:Bind ViewModel.Page.UnitsStatusMessage, Mode=OneWay}"
                TextWrapping="WrapWholeWords"
                Visibility="{x:Bind ViewModel.Page.UnitsStatusVisibility, Mode=OneWay}" />

            <ItemsControl ItemTemplate="{StaticResource UnitRowTemplate}" ItemsSource="{x:Bind ViewModel.Page.UnitRows, Mode=OneWay}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
