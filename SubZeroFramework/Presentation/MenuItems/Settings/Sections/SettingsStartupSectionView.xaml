<UserControl
    x:Class="SubZeroFramework.Presentation.MenuItems.Settings.Sections.SettingsStartupSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            Padding="24,4,24,24"
            HorizontalAlignment="Stretch"
            Spacing="10">

            <StackPanel Spacing="4">
                <TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Startup &amp; alerts" />
                <TextBlock
                    FontSize="13"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="How SubZero launches and when it notifies you." />
            </StackPanel>

            <TextBlock
                FontSize="12.5"
                Foreground="{StaticResource StatusWarningBrush}"
                Text="{x:Bind ViewModel.Page.StartupStatusMessage, Mode=OneWay}"
                TextWrapping="WrapWholeWords"
                Visibility="{x:Bind ViewModel.Page.StartupStatusVisibility, Mode=OneWay}" />

            <StackPanel>
                <controls:ToggleRowView
                    Title="Start with system boot"
                    Margin="0,7"
                    IconKind="RocketLaunchOutline"
                    IsOn="{x:Bind ViewModel.Page.StartWithSystemBoot, Mode=TwoWay}"
                    IsToggleEnabled="{x:Bind ViewModel.Page.StartWithSystemBootSupported, Mode=OneWay}"
                    Subtitle="Launch SubZero when you sign in" />
                <Border Height="1" Background="{StaticResource SurfaceOutlineBrush}" />

                <controls:ToggleRowView
                    Title="Autorun service"
                    Margin="0,7"
                    IconKind="WeatherNight"
                    IsOn="{x:Bind ViewModel.Page.AutorunIsOn, Mode=TwoWay}"
                    IsToggleEnabled="{x:Bind ViewModel.Page.CanToggleAutorun, Mode=OneWay}"
                    Subtitle="Keep the service running at startup" />
                <Border Height="1" Background="{StaticResource SurfaceOutlineBrush}" />

                <!--
                    Disabled for the MVP: toast delivery is unreliable (see ThermalAlertMonitor's remarks;
                    Linux direction is org.freedesktop.Notifications over D-Bus).
                -->
                <controls:ToggleRowView
                    Title="Thermal alerts"
                    Margin="0,7"
                    IconKind="BellOutline"
                    IsOn="{x:Bind ViewModel.Page.ThermalAlertsEnabled, Mode=TwoWay}"
                    IsToggleEnabled="False"
                    Opacity="0.5"
                    Subtitle="Coming soon" />
                <Border Height="1" Background="{StaticResource SurfaceOutlineBrush}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
