<Page
    x:Class="SubZeroFramework.Presentation.MenuItems.Settings.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.Settings.Models"
    xmlns:uen="using:Uno.Extensions.Navigation.UI"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.Resources>
        <!--  One sub-nav entry: accent bar | icon | title + subtitle. Clicking navigates the section sub-region.  -->
        <DataTemplate x:Key="SettingsSectionTemplate" x:DataType="models:SettingsSectionRailItemModel">
            <Button
                Margin="0,2"
                Padding="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="{x:Bind RailBackground, Mode=OneWay}"
                BorderThickness="0"
                Click="OnSectionItemClick"
                CornerRadius="8">
                <Grid Height="54" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Grid.Column="0"
                        Width="3"
                        Height="30"
                        VerticalAlignment="Center"
                        Background="{StaticResource BrandPrimaryBrush}"
                        CornerRadius="2"
                        Visibility="{x:Bind AccentBarVisibility, Mode=OneWay}" />
                    <material:MaterialIcon
                        Grid.Column="1"
                        Width="17"
                        Height="17"
                        Margin="9,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{x:Bind IconBrush, Mode=OneWay}"
                        Kind="{x:Bind IconKind}" />
                    <StackPanel
                        Grid.Column="2"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Spacing="1">
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{x:Bind TitleBrush, Mode=OneWay}"
                            Text="{x:Bind Title}" />
                        <TextBlock
                            FontSize="11.5"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{x:Bind Subtitle}" />
                    </StackPanel>
                </Grid>
            </Button>
        </DataTemplate>
    </Page.Resources>

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <Grid Padding="15,0,15,24" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                FontSize="28"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="Settings" />

            <!--
                Two-pane body: sub-nav card | section body sub-region resolved by navigation (Device-Caps pattern).
                The sub-nav card stretches to the window bottom with the service status pinned at its foot.
            -->
            <Grid Grid.Row="1" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12">
                    <Grid Padding="8" RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ItemsControl
                            VerticalAlignment="Top"
                            ItemTemplate="{StaticResource SettingsSectionTemplate}"
                            ItemsSource="{x:Bind ViewModel.Sections, Mode=OneWay}" />

                        <StackPanel Grid.Row="1" Spacing="8">
                            <Border Height="1" Background="{StaticResource SurfaceOutlineBrush}" />
                            <StackPanel
                                Margin="9,0,0,6"
                                Orientation="Horizontal"
                                Spacing="8">
                                <material:MaterialIcon
                                    Width="15"
                                    Height="15"
                                    VerticalAlignment="Center"
                                    Foreground="{x:Bind ViewModel.FooterBrush, Mode=OneWay}"
                                    Kind="{x:Bind ViewModel.FooterIconKind, Mode=OneWay}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12.5"
                                    FontWeight="SemiBold"
                                    Foreground="{x:Bind ViewModel.FooterBrush, Mode=OneWay}"
                                    Text="{x:Bind ViewModel.FooterText, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!--
                    No page-level ScrollViewer: section bodies manage their own scrolling so the sub-nav card
                    can stretch to the window bottom (full-height side-panel rule).
                -->
                <ContentControl
                    x:Name="SectionRegionHost"
                    Grid.Column="1"
                    HorizontalContentAlignment="Left"
                    VerticalContentAlignment="Stretch"
                    uen:Region.Attached="True" />
            </Grid>
        </Grid>
    </Grid>
</Page>
