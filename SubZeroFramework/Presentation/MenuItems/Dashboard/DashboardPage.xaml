<Page
    x:Class="SubZeroFramework.Presentation.MenuItems.Dashboard.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SubZeroFramework.Presentation.MenuItems.Dashboard"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uen="using:Uno.Extensions.Navigation.UI"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="0,0,0,24" Spacing="18">
                <StackPanel>
                    <TextBlock
                        Margin="15,0"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Active Cooling Section" />
                    <GridView
                        Margin="10,0"
                        AllowDrop="True"
                        CanDragItems="True"
                        CanReorderItems="True"
                        ItemsSource="{x:Bind ViewModel.VisibleFans, Mode=OneWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollMode="Disabled"
                        SelectionMode="None">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="local:FanCardModel">
                                <controls:ElevatedCard
                                    Width="300"
                                    Height="250"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    Background="{StaticResource CardBackgroundBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock
                                            Grid.Row="0"
                                            Margin="15,15,15,0"
                                            FontSize="20"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind Snapshot.DisplayName, Mode=OneWay}" />

                                        <Grid Grid.Row="1" Margin="-125,-5,0,0">
                                            <lvc:PieChart
                                                Background="Transparent"
                                                CornerRadius="0"
                                                InitialRotation="-225"
                                                LegendPosition="Hidden"
                                                MaxAngle="200"
                                                MaxValue="8000"
                                                MinValue="0"
                                                TooltipPosition="Hidden">
                                                <lvc:PieChart.Series>
                                                    <lvc:SeriesCollection>
                                                        <lvc:XamlPieSeries
                                                            CornerRadius="0"
                                                            DataLabelsPaint="{lvc:SolidColorPaint Color='#00000000'}"
                                                            Fill="{lvc:SolidColorPaint Color='#FFD7D8FF'}"
                                                            MaxRadialColumnWidth="15"
                                                            Values="{x:Bind FanSpeedGaugeValues, Mode=OneWay}" />
                                                        <lvc:XamlPieSeries
                                                            DataLabelsPaint="{lvc:SolidColorPaint Color='#00000000'}"
                                                            Fill="{lvc:SolidColorPaint Color='#FF5D5E73'}"
                                                            MaxRadialColumnWidth="15"
                                                            Values="{x:Bind FanSpeedRemainingGaugeValues, Mode=OneWay}" />
                                                    </lvc:SeriesCollection>
                                                </lvc:PieChart.Series>
                                            </lvc:PieChart>
                                        </Grid>

                                        <StackPanel
                                            Grid.Row="1"
                                            Margin="-55,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="36"
                                                FontWeight="Bold"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind Snapshot.SpeedRpm, Mode=OneWay}" />
                                            <TextBlock
                                                Margin="4,0,0,6"
                                                VerticalAlignment="Bottom"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="RPM" />
                                        </StackPanel>

                                        <StackPanel
                                            Grid.Row="0"
                                            Margin="0,15,15,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Top">
                                            <StackPanel
                                                HorizontalAlignment="Right"
                                                Orientation="Horizontal"
                                                Spacing="6">
                                                <material:MaterialIcon
                                                    Width="14"
                                                    Height="14"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Kind="Target" />
                                                <TextBlock
                                                    FontSize="14"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="{x:Bind TargetModeDisplay, Mode=OneWay}" />
                                            </StackPanel>
                                            <StackPanel
                                                Margin="0,2,0,0"
                                                HorizontalAlignment="Center"
                                                Orientation="Horizontal"
                                                Spacing="6">
                                                <material:MaterialIcon
                                                    Width="14"
                                                    Height="14"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Kind="Thermometer" />
                                                <TextBlock
                                                    FontSize="14"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="{x:Bind DrivingTemperatureDisplay, Mode=OneWay}" />
                                            </StackPanel>
                                        </StackPanel>

                                        <lvc:CartesianChart
                                            Grid.Row="1"
                                            Grid.RowSpan="2"
                                            Width="210"
                                            Height="90"
                                            Margin="0,0,-20,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            AutoUpdateEnabled="True"
                                            Background="Transparent"
                                            TooltipPosition="Hidden">
                                            <lvc:CartesianChart.Series>
                                                <lvc:SeriesCollection>
                                                    <lvc:XamlLineSeries
                                                        Fill="{x:Null}"
                                                        GeometryFill="{x:Null}"
                                                        GeometryStroke="{x:Null}"
                                                        Stroke="{lvc:SolidColorPaint Color='#FFD7D8FF',
                                                                                     StrokeWidth='2'}"
                                                        Values="{x:Bind FanSpeedHistory, Mode=OneWay}" />
                                                </lvc:SeriesCollection>
                                            </lvc:CartesianChart.Series>
                                            <lvc:CartesianChart.XAxes>
                                                <lvc:AxesCollection>
                                                    <lvc:XamlDateTimeAxis
                                                        AnimationsSpeed="0"
                                                        CustomSeparators="{x:Bind Separators, Mode=OneWay}"
                                                        DateFormatter="{x:Bind LabelsFormatter}"
                                                        Interval="0:0:1"
                                                        LabelsPaint="{lvc:SolidColorPaint Color='D85D5E73'}"
                                                        SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                        TextSize="8" />
                                                </lvc:AxesCollection>
                                            </lvc:CartesianChart.XAxes>
                                            <lvc:CartesianChart.YAxes>
                                                <lvc:AxesCollection>
                                                    <lvc:XamlAxis
                                                        Padding="{lvc:Padding Value='0,0'}"
                                                        LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                                        MaxLimit="8000"
                                                        MinLimit="0"
                                                        SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                        ShowSeparatorLines="True"
                                                        TextSize="8" />
                                                </lvc:AxesCollection>
                                            </lvc:CartesianChart.YAxes>
                                        </lvc:CartesianChart>

                                        <Grid
                                            Grid.Row="2"
                                            Height="50"
                                            Margin="0,0,0,5">
                                            <StackPanel
                                                Margin="15,0,0,10"
                                                VerticalAlignment="Bottom"
                                                Orientation="Horizontal"
                                                Spacing="6">
                                                <material:MaterialIcon
                                                    Width="14"
                                                    Height="14"
                                                    Foreground="{x:Bind StatusBrush, Mode=OneWay}"
                                                    Kind="Circle" />
                                                <TextBlock
                                                    FontSize="14"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="{x:Bind StatusText, Mode=OneWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </controls:ElevatedCard>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>

                <StackPanel>
                    <TextBlock
                        Margin="15,0"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Thermal Snapshot Section" />
                    <GridView
                        Margin="10,0"
                        ItemsSource="{x:Bind ViewModel.VisibleThermalSensors, Mode=OneWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollMode="Disabled"
                        SelectionMode="None">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="local:ThermalSensorModel">
                                <controls:ElevatedCard
                                    Width="300"
                                    Height="250"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    Background="{StaticResource CardBackgroundBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock
                                            Grid.Row="0"
                                            Margin="15,15,15,0"
                                            FontSize="20"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind DisplayName, Mode=OneWay}" />

                                        <Grid Grid.Row="1" Margin="-100,0,0,0">
                                            <lvc:PieChart
                                                AnimationsSpeed="0"
                                                Background="Transparent"
                                                CornerRadius="0"
                                                InitialRotation="-225"
                                                LegendPosition="Hidden"
                                                MaxAngle="200"
                                                MaxValue="100"
                                                MinValue="0"
                                                TooltipPosition="Hidden">
                                                <lvc:PieChart.Series>
                                                    <lvc:SeriesCollection>
                                                        <lvc:XamlPieSeries
                                                            AnimationsSpeed="0"
                                                            DataLabelsPaint="{lvc:SolidColorPaint Color='#00000000'}"
                                                            Fill="{lvc:SolidColorPaint Color='#FFD7D8FF'}"
                                                            MaxRadialColumnWidth="15"
                                                            Values="{x:Bind CoolGaugeValues, Mode=OneWay}" />
                                                        <lvc:XamlPieSeries
                                                            AnimationsSpeed="0"
                                                            DataLabelsPaint="{lvc:SolidColorPaint Color='#00000000'}"
                                                            Fill="{lvc:SolidColorPaint Color='#FF8AB7E8'}"
                                                            MaxRadialColumnWidth="15"
                                                            Values="{x:Bind NormalGaugeValues, Mode=OneWay}" />
                                                        <lvc:XamlPieSeries
                                                            AnimationsSpeed="0"
                                                            DataLabelsPaint="{lvc:SolidColorPaint Color='#00000000'}"
                                                            Fill="{lvc:SolidColorPaint Color='#FFC5994E'}"
                                                            MaxRadialColumnWidth="15"
                                                            Values="{x:Bind WarmGaugeValues, Mode=OneWay}" />
                                                        <lvc:XamlPieSeries
                                                            AnimationsSpeed="0"
                                                            DataLabelsPaint="{lvc:SolidColorPaint Color='#00000000'}"
                                                            Fill="{lvc:SolidColorPaint Color='#FF8A5C5B'}"
                                                            MaxRadialColumnWidth="15"
                                                            Values="{x:Bind HotGaugeValues, Mode=OneWay}" />
                                                        <lvc:XamlPieSeries
                                                            AnimationsSpeed="0"
                                                            DataLabelsPaint="{lvc:SolidColorPaint Color='#00000000'}"
                                                            Fill="{lvc:SolidColorPaint Color='#FF5D5E73'}"
                                                            MaxRadialColumnWidth="15"
                                                            Values="{x:Bind RemainingGaugeValues, Mode=OneWay}" />
                                                    </lvc:SeriesCollection>
                                                </lvc:PieChart.Series>
                                            </lvc:PieChart>
                                        </Grid>

                                        <StackPanel
                                            Grid.Row="1"
                                            Margin="-75,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal">
                                            <TextBlock
                                                FontSize="36"
                                                FontWeight="Bold"
                                                Foreground="{x:Bind TemperatureBrush, Mode=OneWay}"
                                                Text="{x:Bind TemperatureValueDisplay, Mode=OneWay}" />
                                            <TextBlock
                                                Margin="4,0,0,6"
                                                VerticalAlignment="Bottom"
                                                Foreground="{x:Bind TemperatureBrush, Mode=OneWay}"
                                                Text="°C" />
                                        </StackPanel>

                                        <lvc:CartesianChart
                                            Grid.Row="1"
                                            Grid.RowSpan="2"
                                            Width="210"
                                            Height="90"
                                            Margin="0,0,-20,0"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            AutoUpdateEnabled="True"
                                            Background="Transparent"
                                            TooltipPosition="Hidden">
                                            <lvc:CartesianChart.Series>
                                                <lvc:SeriesCollection>
                                                    <lvc:XamlLineSeries
                                                        AnimationsSpeed="0"
                                                        Fill="{x:Null}"
                                                        GeometryFill="{x:Null}"
                                                        GeometryStroke="{x:Null}"
                                                        Stroke="{lvc:SolidColorPaint Color='#FF8AB7E8',
                                                                                     StrokeWidth='2'}"
                                                        Values="{x:Bind TemperatureHistory, Mode=OneWay}" />
                                                </lvc:SeriesCollection>
                                            </lvc:CartesianChart.Series>
                                            <lvc:CartesianChart.XAxes>
                                                <lvc:AxesCollection>
                                                    <lvc:XamlDateTimeAxis
                                                        AnimationsSpeed="0"
                                                        CustomSeparators="{x:Bind Separators, Mode=OneWay}"
                                                        DateFormatter="{x:Bind LabelsFormatter}"
                                                        Interval="0:5:0"
                                                        LabelsPaint="{lvc:SolidColorPaint Color='#D85D5E73'}"
                                                        SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                        ShowSeparatorLines="True"
                                                        TextSize="8" />
                                                </lvc:AxesCollection>
                                            </lvc:CartesianChart.XAxes>
                                            <lvc:CartesianChart.YAxes>
                                                <lvc:AxesCollection>
                                                    <lvc:XamlAxis
                                                        Padding="{lvc:Padding Value='0,0'}"
                                                        LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                                        MaxLimit="100"
                                                        MinLimit="0"
                                                        SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                        ShowSeparatorLines="True"
                                                        TextSize="8" />
                                                </lvc:AxesCollection>
                                            </lvc:CartesianChart.YAxes>
                                        </lvc:CartesianChart>

                                        <Grid
                                            Grid.Row="2"
                                            Height="50"
                                            Margin="0,0,0,5">
                                            <StackPanel
                                                Margin="15,0,0,10"
                                                VerticalAlignment="Bottom"
                                                Orientation="Horizontal"
                                                Spacing="6">
                                                <material:MaterialIcon
                                                    Width="14"
                                                    Height="14"
                                                    Foreground="{x:Bind StatusBrush, Mode=OneWay}"
                                                    Kind="Circle" />
                                                <TextBlock
                                                    FontSize="14"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="{x:Bind StatusText, Mode=OneWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </controls:ElevatedCard>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>

                <StackPanel>
                    <TextBlock
                        Margin="15,0"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Thermal History Section" />
                    <controls:ElevatedCard
                        Margin="5,0"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}">
                        <Grid Margin="15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="One Hour Thermal History" />

                            <GridView
                                Grid.Row="1"
                                Margin="-8,16,-8,10"
                                HorizontalAlignment="Stretch"
                                IsItemClickEnabled="False"
                                ItemsSource="{x:Bind ViewModel.VisibleThermalSensors, Mode=OneWay}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.HorizontalScrollMode="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollMode="Disabled"
                                SelectionMode="None">
                                <GridView.ItemContainerStyle>
                                    <Style TargetType="GridViewItem">
                                        <Setter Property="Margin" Value="8,0,8,12" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </GridView.ItemContainerStyle>
                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="local:ThermalSensorModel">
                                        <CheckBox Foreground="{StaticResource TextPrimaryBrush}" IsChecked="{x:Bind IsSelected, Mode=TwoWay}">
                                            <CheckBox.Content>
                                                <TextBlock Text="{x:Bind SelectionDisplay, Mode=OneWay}" />
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>

                            <Border
                                Grid.Row="2"
                                Padding="6"
                                Background="#221A1E32"
                                CornerRadius="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <lvc:CartesianChart
                                        x:Name="ThermalHistoryChart"
                                        Height="324"
                                        AutoUpdateEnabled="True"
                                        Background="Transparent"
                                        LegendPosition="Hidden"
                                        TooltipPosition="Top">
                                        <lvc:CartesianChart.XAxes>
                                            <lvc:AxesCollection>
                                                <lvc:XamlDateTimeAxis
                                                    AnimationsSpeed="0"
                                                    CustomSeparators="{x:Bind ThermalHistorySeparators, Mode=OneWay}"
                                                    DateFormatter="{x:Bind ThermalHistoryDateFormatter, Mode=OneWay}"
                                                    Interval="0:10:0"
                                                    LabelsPaint="{lvc:SolidColorPaint Color='#FFD7D8FF'}"
                                                    MaxLimit="{x:Bind ThermalHistoryMaxLimit, Mode=OneWay}"
                                                    MinLimit="{x:Bind ThermalHistoryMinLimit, Mode=OneWay}"
                                                    SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                    ShowSeparatorLines="True"
                                                    TextSize="12" />
                                            </lvc:AxesCollection>
                                        </lvc:CartesianChart.XAxes>
                                        <lvc:CartesianChart.YAxes>
                                            <lvc:AxesCollection>
                                                <lvc:XamlAxis
                                                    Labeler="{x:Bind ThermalLabelFormatter}"
                                                    LabelsPaint="{lvc:SolidColorPaint Color='#FFD7D8FF'}"
                                                    MaxLimit="100"
                                                    MinLimit="0"
                                                    SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                    TextSize="12" />
                                            </lvc:AxesCollection>
                                        </lvc:CartesianChart.YAxes>
                                    </lvc:CartesianChart>
                                </Grid>
                            </Border>
                        </Grid>
                    </controls:ElevatedCard>
                </StackPanel>

                <StackPanel>
                    <TextBlock
                        Margin="15,0"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Power &amp; Battery" />
                    <ItemsRepeater
                        Margin="10,0"
                        VerticalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.Batteries, Mode=OneWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollMode="Disabled">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="local:PowerCardModel">
                                <Border VerticalAlignment="Stretch">
                                    <controls:ElevatedCard
                                        MinHeight="360"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch"
                                        Background="{StaticResource CardBackgroundBrush}">
                                        <Grid
                                            Margin="14"
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>

                                            <TextBlock
                                                FontSize="30"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind BatteryTitle, Mode=OneWay}" />

                                            <StackPanel
                                                Grid.Row="1"
                                                Margin="0,12,0,0"
                                                Spacing="8">
                                                <ProgressBar
                                                    Height="10"
                                                    Foreground="{x:Bind StateBrush, Mode=OneWay}"
                                                    Maximum="100"
                                                    Value="{x:Bind ChargePercentValue, Mode=OneWay}" />
                                                <TextBlock Foreground="{x:Bind StateBrush, Mode=OneWay}" Text="{x:Bind ChargeAndStateDisplay, Mode=OneWay}" />
                                            </StackPanel>

                                            <Grid
                                                Grid.Row="2"
                                                Margin="0,12,0,0"
                                                ColumnSpacing="8"
                                                RowSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="*" />
                                                </Grid.RowDefinitions>

                                                <Border
                                                    Grid.Column="0"
                                                    Padding="10"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Battery State" />
                                                        <TextBlock
                                                            FontSize="26"
                                                            Foreground="{x:Bind StateBrush, Mode=OneWay}"
                                                            Text="{x:Bind StateDisplay, Mode=OneWay}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border
                                                    Grid.Column="1"
                                                    Padding="10"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Power State" />
                                                        <TextBlock
                                                            FontSize="26"
                                                            Foreground="{x:Bind PowerBrush, Mode=OneWay}"
                                                            Text="{x:Bind PowerDisplay, Mode=OneWay}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border
                                                    Grid.Column="2"
                                                    Padding="10"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="{x:Bind RateKind, Mode=OneWay}" />
                                                        <TextBlock
                                                            FontSize="26"
                                                            Foreground="{StaticResource StatusWarningBrush}"
                                                            Text="{x:Bind RateDisplay, Mode=OneWay}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border
                                                    Grid.Column="3"
                                                    Padding="10"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Battery Voltage (V)" />
                                                        <TextBlock
                                                            FontSize="26"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            Text="{x:Bind VoltageDisplay, Mode=OneWay}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border
                                                    Grid.Column="4"
                                                    Padding="10"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Battery Cycles" />
                                                        <TextBlock
                                                            FontSize="26"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            Text="{x:Bind CyclesDisplay, Mode=OneWay}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border
                                                    Grid.Row="1"
                                                    Grid.Column="0"
                                                    Padding="10"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Nominal Voltage (V)" />
                                                        <TextBlock
                                                            FontSize="26"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            Text="{x:Bind DesignVoltage, Mode=OneWay}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Padding="10"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Battery Design Capacity (Ah)" />
                                                        <TextBlock
                                                            FontSize="26"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            Text="{x:Bind DesignCapacityAmepereHours, Mode=OneWay}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border
                                                    Grid.Row="1"
                                                    Grid.Column="2"
                                                    Padding="10"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Battery Remaining Capacity (Ah)" />
                                                        <TextBlock
                                                            FontSize="26"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            Text="{x:Bind RemainingCapacityAmpereHours, Mode=OneWay}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border
                                                    Grid.Row="1"
                                                    Grid.Column="3"
                                                    Padding="10"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Battery Last Full Charge (Ah)" />
                                                        <TextBlock
                                                            FontSize="26"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            Text="{x:Bind LastFullChargeCapacityAmpereHours, Mode=OneWay}" />
                                                    </StackPanel>
                                                </Border>

                                                <Border
                                                    Grid.Row="1"
                                                    Grid.Column="4"
                                                    Padding="10"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="10">
                                                    <StackPanel>
                                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Battery Health" />
                                                        <TextBlock
                                                            FontSize="26"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            Text="{x:Bind BatteryLife, Mode=OneWay}" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>

                                            <Grid
                                                Grid.Row="3"
                                                Margin="0,12,0,0"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch"
                                                ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <Border
                                                    Grid.Column="0"
                                                    Padding="8"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="12">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock
                                                            Margin="0,0,0,4"
                                                            Foreground="{StaticResource TextSecondaryBrush}"
                                                            Text="Charge (%)" />
                                                        <lvc:CartesianChart
                                                            Grid.Row="1"
                                                            Height="160"
                                                            AutoUpdateEnabled="True"
                                                            Background="Transparent"
                                                            LegendPosition="Hidden"
                                                            TooltipPosition="Top">
                                                            <lvc:CartesianChart.Series>
                                                                <lvc:SeriesCollection>
                                                                    <lvc:XamlLineSeries
                                                                        AnimationsSpeed="0"
                                                                        Fill="{x:Null}"
                                                                        GeometryFill="{x:Null}"
                                                                        GeometryStroke="{x:Null}"
                                                                        Stroke="{lvc:SolidColorPaint Color='#FF8AB7E8',
                                                                                                     StrokeWidth='2'}"
                                                                        Values="{x:Bind ChargeHistory, Mode=OneWay}" />
                                                                </lvc:SeriesCollection>
                                                            </lvc:CartesianChart.Series>
                                                            <lvc:CartesianChart.XAxes>
                                                                <lvc:AxesCollection>
                                                                    <lvc:XamlDateTimeAxis
                                                                        AnimationsSpeed="0"
                                                                        CustomSeparators="{x:Bind ChargeSeparators, Mode=OneWay}"
                                                                        DateFormatter="{x:Bind LabelsFormatter}"
                                                                        Interval="0:10:0"
                                                                        LabelsPaint="{lvc:SolidColorPaint Color='#FFD7D8FF'}"
                                                                        MaxLimit="{x:Bind ChargeMax, Mode=OneWay}"
                                                                        MinLimit="{x:Bind ChargeMin, Mode=OneWay}"
                                                                        SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                                        ShowSeparatorLines="True"
                                                                        TextSize="12" />
                                                                </lvc:AxesCollection>
                                                            </lvc:CartesianChart.XAxes>
                                                            <lvc:CartesianChart.YAxes>
                                                                <lvc:AxesCollection>
                                                                    <lvc:XamlAxis
                                                                        AnimationsSpeed="0"
                                                                        LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                                                        MaxLimit="100"
                                                                        MinLimit="0"
                                                                        SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                                        ShowSeparatorLines="True"
                                                                        TextSize="9" />
                                                                </lvc:AxesCollection>
                                                            </lvc:CartesianChart.YAxes>
                                                        </lvc:CartesianChart>
                                                    </Grid>
                                                </Border>

                                                <Border
                                                    Grid.Column="1"
                                                    Padding="8"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="12">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock
                                                            Margin="0,0,0,4"
                                                            Foreground="{StaticResource TextSecondaryBrush}"
                                                            Text="{x:Bind RateKind, Mode=OneWay}" />
                                                        <lvc:CartesianChart
                                                            Grid.Row="1"
                                                            Height="160"
                                                            AutoUpdateEnabled="True"
                                                            Background="Transparent"
                                                            LegendPosition="Hidden"
                                                            TooltipPosition="Top">
                                                            <lvc:CartesianChart.Series>
                                                                <lvc:SeriesCollection>
                                                                    <lvc:XamlLineSeries
                                                                        AnimationsSpeed="0"
                                                                        Fill="{x:Null}"
                                                                        GeometryFill="{x:Null}"
                                                                        GeometryStroke="{x:Null}"
                                                                        Stroke="{lvc:SolidColorPaint Color='#FFC5994E',
                                                                                                     StrokeWidth='2'}"
                                                                        Values="{x:Bind CurrentHistory, Mode=OneWay}" />
                                                                </lvc:SeriesCollection>
                                                            </lvc:CartesianChart.Series>
                                                            <lvc:CartesianChart.XAxes>
                                                                <lvc:AxesCollection>
                                                                    <lvc:XamlDateTimeAxis
                                                                        AnimationsSpeed="0"
                                                                        CustomSeparators="{x:Bind CurrentSeparators, Mode=OneWay}"
                                                                        DateFormatter="{x:Bind LabelsFormatter}"
                                                                        Interval="0:10:0"
                                                                        LabelsPaint="{lvc:SolidColorPaint Color='#FFD7D8FF'}"
                                                                        MaxLimit="{x:Bind CurrentMax, Mode=OneWay}"
                                                                        MinLimit="{x:Bind CurrentMin, Mode=OneWay}"
                                                                        SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                                        ShowSeparatorLines="True"
                                                                        TextSize="12" />
                                                                </lvc:AxesCollection>
                                                            </lvc:CartesianChart.XAxes>
                                                            <lvc:CartesianChart.YAxes>
                                                                <lvc:AxesCollection>
                                                                    <lvc:XamlAxis
                                                                        AnimationsSpeed="0"
                                                                        LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                                                        SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                                        ShowSeparatorLines="True"
                                                                        TextSize="9" />
                                                                </lvc:AxesCollection>
                                                            </lvc:CartesianChart.YAxes>
                                                        </lvc:CartesianChart>
                                                    </Grid>
                                                </Border>

                                                <Border
                                                    Grid.Column="2"
                                                    Padding="8"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="12">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock
                                                            Margin="0,0,0,4"
                                                            Foreground="{StaticResource TextSecondaryBrush}"
                                                            Text="Battery Voltage (V)" />
                                                        <lvc:CartesianChart
                                                            Grid.Row="1"
                                                            Height="160"
                                                            AutoUpdateEnabled="True"
                                                            Background="Transparent"
                                                            LegendPosition="Hidden"
                                                            TooltipPosition="Top">
                                                            <lvc:CartesianChart.Series>
                                                                <lvc:SeriesCollection>
                                                                    <lvc:XamlLineSeries
                                                                        AnimationsSpeed="0"
                                                                        Fill="{x:Null}"
                                                                        GeometryFill="{x:Null}"
                                                                        GeometryStroke="{x:Null}"
                                                                        Stroke="{lvc:SolidColorPaint Color='#FFD7D8FF',
                                                                                                     StrokeWidth='2'}"
                                                                        Values="{x:Bind VoltageHistory, Mode=OneWay}" />
                                                                </lvc:SeriesCollection>
                                                            </lvc:CartesianChart.Series>
                                                            <lvc:CartesianChart.XAxes>
                                                                <lvc:AxesCollection>
                                                                    <lvc:XamlDateTimeAxis
                                                                        AnimationsSpeed="0"
                                                                        CustomSeparators="{x:Bind VoltageSeparators, Mode=OneWay}"
                                                                        DateFormatter="{x:Bind LabelsFormatter}"
                                                                        Interval="0:10:0"
                                                                        LabelsPaint="{lvc:SolidColorPaint Color='#FFD7D8FF'}"
                                                                        MaxLimit="{x:Bind VoltageMax, Mode=OneWay}"
                                                                        MinLimit="{x:Bind VoltageMin, Mode=OneWay}"
                                                                        SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                                        ShowSeparatorLines="True"
                                                                        TextSize="12" />
                                                                </lvc:AxesCollection>
                                                            </lvc:CartesianChart.XAxes>
                                                            <lvc:CartesianChart.YAxes>
                                                                <lvc:AxesCollection>
                                                                    <lvc:XamlAxis
                                                                        AnimationsSpeed="0"
                                                                        LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                                                        MaxLimit="18"
                                                                        MinLimit="10"
                                                                        SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                                        ShowSeparatorLines="True"
                                                                        TextSize="9" />
                                                                </lvc:AxesCollection>
                                                            </lvc:CartesianChart.YAxes>
                                                        </lvc:CartesianChart>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </controls:ElevatedCard>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
