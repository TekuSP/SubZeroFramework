<Page
    x:Class="SubZeroFramework.Presentation.MenuItems.Dashboard.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dashboardControls="using:SubZeroFramework.Controls.Dashboard"
    xmlns:dashboardModels="using:SubZeroFramework.Controls.Dashboard.Models"
    xmlns:deviceCapControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:powerControls="using:SubZeroFramework.Controls.Power"
    xmlns:thermalModels="using:SubZeroFramework.Controls.Thermal.Models"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.Resources>
        <!--  Preset card wrapped in a Button; Tag carries the model for the Click handler.  -->
        <DataTemplate x:Key="CoolingPresetTemplate" x:DataType="dashboardModels:CoolingPresetCardModel">
            <Button
                Padding="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Background="Transparent"
                BorderThickness="0"
                Click="OnPresetClick"
                CornerRadius="12"
                Tag="{x:Bind}">
                <dashboardControls:CoolingPresetCardView Model="{x:Bind}" />
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="FanQuickControlTemplate" x:DataType="dashboardModels:FanQuickControlModel">
            <dashboardControls:FanQuickControlCardView Model="{x:Bind}" />
        </DataTemplate>

        <!--  One thermal snapshot row: name | severity-tinted bar | value.  -->
        <DataTemplate x:Key="ThermalBarRowTemplate" x:DataType="thermalModels:ThermalSensorModel">
            <Grid MinHeight="30" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="44" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{x:Bind DisplayName, Mode=OneWay}"
                    TextTrimming="CharacterEllipsis" />
                <ProgressBar
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Background="{StaticResource CardSecondaryBackgroundBrush}"
                    Foreground="{x:Bind TemperatureBrush, Mode=OneWay}"
                    Maximum="100"
                    Value="{x:Bind GaugeValue, Mode=OneWay}" />
                <TextBlock
                    Grid.Column="2"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{x:Bind TemperatureBrush, Mode=OneWay}"
                    Text="{x:Bind TemperatureValueDisplay, Mode=OneWay}" />
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="15,0,15,24" Spacing="16">

                <!--
                    Cooling profile presets: not supported yet — the whole section renders grayed and inert
                    (feature-flagged off in the model too, so nothing actuates or derives selection).
                -->
                <StackPanel
                    IsHitTestVisible="False"
                    Opacity="0.4"
                    Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon
                            Width="18"
                            Height="18"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource StatusInfoBrush}"
                            Kind="Tune" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Cooling profile" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12.5"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{x:Bind ViewModel.CoolingProfileSubtitle, Mode=OneWay}" />
                    </StackPanel>

                    <ItemsControl ItemTemplate="{StaticResource CoolingPresetTemplate}" ItemsSource="{x:Bind ViewModel.CoolingPresets, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <deviceCapControls:StatTilePanel MaxColumns="5" MinTileWidth="200" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>

                <!--  Fans (read-only live overview)  -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon
                            Width="18"
                            Height="18"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource StatusInfoBrush}"
                            Kind="Fan" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="20"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Fans" />
                    </StackPanel>
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="6">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12.5"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Average fan speed" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{x:Bind ViewModel.AverageFanSpeedDisplay, Mode=OneWay}" />
                    </StackPanel>
                </Grid>

                <ItemsControl ItemTemplate="{StaticResource FanQuickControlTemplate}" ItemsSource="{x:Bind ViewModel.QuickFans, Mode=OneWay}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <deviceCapControls:StatTilePanel
                                ColumnSpacing="12"
                                MaxColumns="4"
                                MinTileWidth="300"
                                RowSpacing="12" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!--  Thermal snapshot | Power  -->
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Padding="18,14"
                        VerticalAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource SurfaceOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <material:MaterialIcon
                                        Width="16"
                                        Height="16"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource StatusInfoBrush}"
                                        Kind="Thermometer" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="Thermal snapshot" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="6">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="12"
                                        Foreground="{StaticResource TextSecondaryBrush}"
                                        Text="driving temperature" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource StatusSuccessBrush}"
                                        Text="{x:Bind ViewModel.DrivingTemperatureDisplay, Mode=OneWay}" />
                                </StackPanel>
                            </Grid>

                            <ItemsControl
                                Grid.Row="1"
                                VerticalAlignment="Top"
                                ItemTemplate="{StaticResource ThermalBarRowTemplate}"
                                ItemsSource="{x:Bind ViewModel.ThermalSensors, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <deviceCapControls:StatTilePanel
                                            ColumnSpacing="24"
                                            MaxColumns="2"
                                            MinTileWidth="260"
                                            RowSpacing="4" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <!--
                        Power: stretches to match the thermal card so the two bottoms align; content centers
                        in the extra space. The ring gets full 120px so its centre text never clips.
                    -->
                    <Border
                        Grid.Column="1"
                        Padding="18,14"
                        VerticalAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource SurfaceOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <Grid RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <material:MaterialIcon
                                    Width="16"
                                    Height="16"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource StatusInfoBrush}"
                                    Kind="BatteryChargingHigh" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="Power" />
                            </StackPanel>

                            <Grid
                                Grid.Row="1"
                                VerticalAlignment="Center"
                                ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <powerControls:BatteryChargeRingView
                                    Width="160"
                                    Height="160"
                                    ChargeFraction="{x:Bind ViewModel.BatteryChargeFraction, Mode=OneWay}"
                                    ChargeText="{x:Bind ViewModel.BatteryChargeText, Mode=OneWay}"
                                    IsAnimating="{x:Bind ViewModel.IsBatteryCharging, Mode=OneWay}" />
                                <StackPanel
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                                    <StackPanel Orientation="Horizontal" Spacing="7">
                                        <Ellipse
                                            Width="8"
                                            Height="8"
                                            VerticalAlignment="Center"
                                            Fill="{StaticResource StatusSuccessBrush}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="13.5"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.ChargingStateText, Mode=OneWay}" />
                                    </StackPanel>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            FontSize="12.5"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="Adapter" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="12.5"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.AdapterWattsDisplay, Mode=OneWay}" />
                                    </Grid>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            FontSize="12.5"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="Full in" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="12.5"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ViewModel.FullInDisplay, Mode=OneWay}" />
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
