<Page
    x:Class="SubZeroFramework.Presentation.MenuItems.Dashboard.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fanControls="using:SubZeroFramework.Controls.Fans"
    xmlns:fanModels="using:SubZeroFramework.Controls.Fans.Models"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:powerControls="using:SubZeroFramework.Controls.Power"
    xmlns:powerModels="using:SubZeroFramework.Controls.Power.Models"
    xmlns:thermalControls="using:SubZeroFramework.Controls.Thermal"
    xmlns:thermalModels="using:SubZeroFramework.Controls.Thermal.Models"
    xmlns:uen="using:Uno.Extensions.Navigation.UI"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="0,0,0,24" Spacing="18">
                <StackPanel>
                    <TextBlock
                        Margin="15,0"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Active Cooling Section" />
                    <GridView
                        Margin="10,0"
                        AllowDrop="True"
                        CanDragItems="True"
                        CanReorderItems="True"
                        ItemsSource="{x:Bind ViewModel.VisibleFans, Mode=OneWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollMode="Disabled"
                        SelectionMode="None">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="fanModels:FanCardModel">
                                <fanControls:FanCardView ViewModel="{x:Bind Mode=OneWay}" />
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>

                <StackPanel>
                    <TextBlock
                        Margin="15,0"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Thermal Snapshot Section" />
                    <GridView
                        Margin="10,0"
                        ItemsSource="{x:Bind ViewModel.VisibleThermalSensors, Mode=OneWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollMode="Disabled"
                        SelectionMode="None">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="thermalModels:ThermalSensorModel">
                                <thermalControls:ThermalSnapshotCardView ViewModel="{x:Bind Mode=OneWay}" />
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>

                <StackPanel>
                    <TextBlock
                        Margin="15,0"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Thermal History Section" />
                    <controls:ElevatedCard
                        Margin="5,0"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}">
                        <Grid Margin="15">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                FontSize="22"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="One Hour Thermal History" />

                            <GridView
                                Grid.Row="1"
                                Margin="-8,16,-8,10"
                                HorizontalAlignment="Stretch"
                                IsItemClickEnabled="False"
                                ItemsSource="{x:Bind ViewModel.VisibleThermalSensors, Mode=OneWay}"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ScrollViewer.HorizontalScrollMode="Disabled"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                ScrollViewer.VerticalScrollMode="Disabled"
                                SelectionMode="None">
                                <GridView.ItemContainerStyle>
                                    <Style TargetType="GridViewItem">
                                        <Setter Property="Margin" Value="8,0,8,12" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    </Style>
                                </GridView.ItemContainerStyle>
                                <GridView.ItemTemplate>
                                    <DataTemplate x:DataType="thermalModels:ThermalSensorModel">
                                        <CheckBox Foreground="{StaticResource TextPrimaryBrush}" IsChecked="{x:Bind IsSelected, Mode=TwoWay}">
                                            <CheckBox.Content>
                                                <TextBlock Text="{x:Bind SelectionDisplay, Mode=OneWay}" />
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </DataTemplate>
                                </GridView.ItemTemplate>
                            </GridView>

                            <Border
                                Grid.Row="2"
                                Padding="6"
                                Background="#221A1E32"
                                CornerRadius="18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <lvc:CartesianChart
                                        Height="324"
                                        AutoUpdateEnabled="True"
                                        Background="Transparent"
                                        LegendPosition="Hidden"
                                        Series="{x:Bind ViewModel.ThermalHistorySeries, Mode=OneWay}"
                                        TooltipPosition="Top">
                                        <lvc:CartesianChart.XAxes>
                                            <lvc:AxesCollection>
                                                <lvc:XamlDateTimeAxis
                                                    AnimationsSpeed="0"
                                                    CustomSeparators="{x:Bind ViewModel.ThermalHistorySeparators, Mode=OneWay}"
                                                    DateFormatter="{x:Bind ViewModel.ThermalHistoryDateFormatter, Mode=OneWay}"
                                                    Interval="0:10:0"
                                                    LabelsPaint="{lvc:SolidColorPaint Color='#FFD7D8FF'}"
                                                    MaxLimit="{x:Bind ViewModel.ThermalHistoryMaxLimit, Mode=OneWay}"
                                                    MinLimit="{x:Bind ViewModel.ThermalHistoryMinLimit, Mode=OneWay}"
                                                    SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                    ShowSeparatorLines="True"
                                                    TextSize="12" />
                                            </lvc:AxesCollection>
                                        </lvc:CartesianChart.XAxes>
                                        <lvc:CartesianChart.YAxes>
                                            <lvc:AxesCollection>
                                                <lvc:XamlAxis
                                                    Labeler="{x:Bind ViewModel.ThermalLabelFormatter, Mode=OneWay}"
                                                    LabelsPaint="{lvc:SolidColorPaint Color='#FFD7D8FF'}"
                                                    MaxLimit="100"
                                                    MinLimit="0"
                                                    SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                    TextSize="12" />
                                            </lvc:AxesCollection>
                                        </lvc:CartesianChart.YAxes>
                                    </lvc:CartesianChart>
                                </Grid>
                            </Border>
                        </Grid>
                    </controls:ElevatedCard>
                </StackPanel>

                <StackPanel>
                    <TextBlock
                        Margin="15,0"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Power &amp; Battery" />
                    <ItemsRepeater
                        Margin="10,0"
                        VerticalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.Batteries, Mode=OneWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollMode="Disabled">
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="powerModels:PowerCardModel">
                                <powerControls:PowerCardView ViewModel="{x:Bind Mode=OneWay}" />
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
