<Page
    x:Class="SubZeroFramework.Presentation.MenuItems.PowerTelemetry.PowerTelemetryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pt="using:SubZeroFramework.Presentation.MenuItems.PowerTelemetry"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer Padding="24">
            <StackPanel
                MaxWidth="920"
                HorizontalAlignment="Left"
                Spacing="6">
                <TextBlock
                    FontSize="22"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="USB-C Power Delivery" />
                <TextBlock
                    FontSize="13"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="Per-port negotiated power and roles reported by the embedded controller." />

                <TextBlock
                    Margin="0,16,0,0"
                    FontSize="13"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="No USB-C ports reported yet…"
                    Visibility="{x:Bind ViewModel.EmptyVisibility, Mode=OneWay}" />

                <ItemsControl
                    Margin="0,12,0,0"
                    ItemsSource="{x:Bind ViewModel.Ports, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.PortsVisibility, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="pt:PowerDeliveryPortViewModel">
                            <controls:ElevatedCard Margin="0,0,0,12" Background="{StaticResource CardBackgroundBrush}">
                                <Grid Padding="16" ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <material:MaterialIcon
                                        Grid.Column="0"
                                        Width="28"
                                        Height="28"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource BrandPrimaryBrush}"
                                        Kind="Usb" />

                                    <StackPanel
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock
                                                FontSize="16"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind Title}" />
                                            <Border
                                                Padding="7,1"
                                                VerticalAlignment="Center"
                                                Background="{StaticResource BrandPrimaryBrush}"
                                                CornerRadius="8"
                                                Visibility="{x:Bind ActiveBadgeVisibility, Mode=OneWay}">
                                                <TextBlock
                                                    FontSize="10"
                                                    Foreground="White"
                                                    Text="Charging" />
                                            </Border>
                                            <Border
                                                Padding="7,1"
                                                VerticalAlignment="Center"
                                                BorderBrush="{StaticResource TextSecondaryBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Visibility="{x:Bind EprBadgeVisibility, Mode=OneWay}">
                                                <TextBlock
                                                    FontSize="10"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="EPR" />
                                            </Border>
                                            <Border
                                                Padding="7,1"
                                                VerticalAlignment="Center"
                                                BorderBrush="{StaticResource TextSecondaryBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Visibility="{x:Bind VconnBadgeVisibility, Mode=OneWay}">
                                                <TextBlock
                                                    FontSize="10"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    Text="VCONN" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock
                                            FontSize="13"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{x:Bind DetailLine, Mode=OneWay}" />
                                    </StackPanel>

                                    <TextBlock
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="{x:Bind PowerText, Mode=OneWay}" />
                                </Grid>
                            </controls:ElevatedCard>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
