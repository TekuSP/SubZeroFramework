                                                    <TextBlock
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        Text="{x:Bind ProductCodeId, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                                        TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="2" Grid.Column="1" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Serial ID" />
