                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        Text="{x:Bind MonitorType, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                                        TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="1" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Manufacturer" />
                                                    <TextBlock
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        Text="{x:Bind DisplayManufacturer, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                                        TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="1" Grid.Column="1" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
