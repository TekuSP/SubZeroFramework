<Page
    x:Class="SubZeroFramework.Presentation.MenuItems.DeviceCapabilities.DeviceCapabilitiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SubZeroFramework.Presentation.MenuItems.DeviceCapabilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Models"
    xmlns:uen="using:Uno.Extensions.Navigation.UI"
    xmlns:uno="using:Material.Icons.UNO"
    xmlns:utu="using:Uno.Toolkit.UI"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="IsTextSelectionEnabled" Value="True" />
        </Style>

        <Style x:Key="CapabilityGridItemStyle" TargetType="GridViewItem">
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="CopyableValueTextBlockStyle" TargetType="TextBlock">
            <Setter Property="IsTextSelectionEnabled" Value="True" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>
    </Page.Resources>

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="0,0,0,24" Spacing="18">
                <StackPanel Margin="15,0,15,0">
                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Device Capabilities" />
                </StackPanel>

                <StackPanel Spacing="12">
                    <StackPanel Margin="10,0">
                        <controls:ElevatedCard
                            Margin="0"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{StaticResource CardBackgroundBrush}">
                            <StackPanel Padding="14">
                                <TextBlock
                                    FontSize="22" Margin="0,0,0,14"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="Onboard devices status" />

                                <StackPanel Spacing="8">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="Temperature Sensors" />
                                    <GridView
                                        IsItemClickEnabled="False"
                                        ItemContainerStyle="{StaticResource CapabilityGridItemStyle}"
                                        ItemsSource="{x:Bind ViewModel.TemperatureStatusItems, Mode=OneWay}"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        ScrollViewer.HorizontalScrollMode="Disabled"
                                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                        ScrollViewer.VerticalScrollMode="Disabled"
                                        SelectionMode="None">
                                        <GridView.ItemTemplate>
                                            <DataTemplate x:DataType="local:DeviceCapabilitiesRuntimeStatusItemModel">
                                                <Border
                                                    Width="220"
                                                    Padding="12"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="10">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock
                                                            FontSize="16"
                                                            FontWeight="SemiBold"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            Text="{x:Bind Name, Mode=OneWay}" />
                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Foreground="{x:Bind StatusForegroundBrush, Mode=OneWay}"
                                                            Text="{x:Bind Status, Mode=OneWay}"
                                                            TextWrapping="WrapWholeWords" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </GridView.ItemTemplate>
                                    </GridView>
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="Fans" />
                                    <GridView
                                        IsItemClickEnabled="False"
                                        ItemContainerStyle="{StaticResource CapabilityGridItemStyle}"
                                        ItemsSource="{x:Bind ViewModel.FanStatusItems, Mode=OneWay}"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        ScrollViewer.HorizontalScrollMode="Disabled"
                                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                        ScrollViewer.VerticalScrollMode="Disabled"
                                        SelectionMode="None">
                                        <GridView.ItemTemplate>
                                            <DataTemplate x:DataType="local:DeviceCapabilitiesRuntimeStatusItemModel">
                                                <Border
                                                    Width="220"
                                                    Padding="12"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="10">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock
                                                            FontSize="16"
                                                            FontWeight="SemiBold"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            Text="{x:Bind Name, Mode=OneWay}" />
                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Foreground="{x:Bind StatusForegroundBrush, Mode=OneWay}"
                                                            Text="{x:Bind Status, Mode=OneWay}"
                                                            TextWrapping="WrapWholeWords" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </GridView.ItemTemplate>
                                    </GridView>
                                </StackPanel>

                                <StackPanel Spacing="8">
                                    <TextBlock
                                        FontSize="18"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="Batteries" />
                                    <GridView
                                        IsItemClickEnabled="False"
                                        ItemContainerStyle="{StaticResource CapabilityGridItemStyle}"
                                        ItemsSource="{x:Bind ViewModel.BatteryStatusItems, Mode=OneWay}"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        ScrollViewer.HorizontalScrollMode="Disabled"
                                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                        ScrollViewer.VerticalScrollMode="Disabled"
                                        SelectionMode="None">
                                        <GridView.ItemTemplate>
                                            <DataTemplate x:DataType="local:DeviceCapabilitiesRuntimeStatusItemModel">
                                                <Border
                                                    Width="220"
                                                    Padding="12"
                                                    Background="#1AFFFFFF"
                                                    CornerRadius="10">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock
                                                            FontSize="16"
                                                            FontWeight="SemiBold"
                                                            Foreground="{StaticResource TextPrimaryBrush}"
                                                            Text="{x:Bind Name, Mode=OneWay}" />
                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Foreground="{x:Bind StatusForegroundBrush, Mode=OneWay}"
                                                            Text="{x:Bind Status, Mode=OneWay}"
                                                            TextWrapping="WrapWholeWords" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </GridView.ItemTemplate>
                                    </GridView>
                                </StackPanel>
                            </StackPanel>
                        </controls:ElevatedCard>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock
                        Margin="15,0"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="System Profile" />
                    <StackPanel Margin="10,0">
                        <controls:ElevatedCard
                            Margin="0"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{StaticResource CardBackgroundBrush}">
                            <StackPanel Padding="14" Spacing="14">
                                <TextBlock
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="Device Identity" />
                                <Grid ColumnSpacing="12" RowSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border
                                        Padding="12"
                                        Background="#1AFFFFFF"
                                        CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Operating system" />
                                            <TextBlock
                                                FontSize="26"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind ViewModel.SystemProfileOs, FallbackValue=Unknown, TargetNullValue=Unknown, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Grid.Column="1"
                                        Padding="12"
                                        Background="#1AFFFFFF"
                                        CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Vendor" />
                                            <TextBlock
                                                FontSize="26"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind ViewModel.SystemProfileVendor, FallbackValue=Unknown, TargetNullValue=Unknown, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Grid.Column="2"
                                        Padding="12"
                                        Background="#1AFFFFFF"
                                        CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Model" />
                                            <TextBlock
                                                FontSize="26"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind ViewModel.SystemProfileModel, FallbackValue=Unknown, TargetNullValue=Unknown, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Grid.Row="1"
                                        Padding="12"
                                        Background="#1AFFFFFF"
                                        CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="OS version" />
                                            <TextBlock
                                                FontSize="26"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind ViewModel.SystemProfileOsVersion, FallbackValue=Unknown, TargetNullValue=Unknown, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Grid.Row="1"
                                        Grid.Column="1"
                                        Padding="12"
                                        Background="#1AFFFFFF"
                                        CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Product / SKU" />
                                            <TextBlock
                                                FontSize="26"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind ViewModel.SystemProfileProductName, FallbackValue=Not separately reported, TargetNullValue=Not separately reported, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Grid.Row="1"
                                        Grid.Column="2"
                                        Padding="12"
                                        Background="#1AFFFFFF"
                                        CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="System revision" />
                                            <TextBlock
                                                FontSize="26"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind ViewModel.SystemProfileSystemVersion, FallbackValue=Unknown, TargetNullValue=Unknown, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Grid ColumnSpacing="12" RowSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border
                                        Padding="12"
                                        Background="#1AFFFFFF"
                                        CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="EC build" />
                                            <TextBlock
                                                FontSize="18"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind ViewModel.SystemProfileEcBuildInfo, FallbackValue=Unavailable, TargetNullValue=Unavailable, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Grid.Column="1"
                                        Padding="12"
                                        Background="#1AFFFFFF"
                                        CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="BIOS version" />
                                            <TextBlock
                                                FontSize="18"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind ViewModel.SystemProfileBiosVersion, FallbackValue=Unknown, TargetNullValue=Unknown, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>

                                    <Border
                                        Grid.Column="2"
                                        Padding="12"
                                        Background="#1AFFFFFF"
                                        CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="BIOS release date" />
                                            <TextBlock
                                                FontSize="18"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind ViewModel.SystemProfileBiosReleaseDate, FallbackValue=Unknown, TargetNullValue=Unknown, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </controls:ElevatedCard>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock
                        Margin="15,0"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="CPU" />
                    <StackPanel Margin="10,0" Spacing="12">
                        <controls:ElevatedCard
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{StaticResource CardBackgroundBrush}">
                            <StackPanel Padding="14" Spacing="14">
                                <TextBlock
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="Runtime Metrics" />
                                <Grid ColumnSpacing="12" RowSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Package count" />
                                            <TextBlock FontSize="26" Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind ViewModel.CpuCount, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Average clock" />
                                            <TextBlock FontSize="26" Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind ViewModel.AverageClockSpeed, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Average max clock" />
                                            <TextBlock FontSize="26" Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind ViewModel.AverageMaxClockSpeed, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </controls:ElevatedCard>

                        <controls:ElevatedCard
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{StaticResource CardBackgroundBrush}">
                            <StackPanel Padding="14" Spacing="10">
                                <TextBlock
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="Frequency History" />
                                <TextBlock
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="Average package frequency across recent hardware snapshots, shown over time."
                                    TextWrapping="WrapWholeWords" />
                                <lvc:CartesianChart
                                    Height="200"
                                    AutoUpdateEnabled="True"
                                    Background="Transparent"
                                    LegendPosition="Hidden"
                                    TooltipPosition="Hidden"
                                    ZoomMode="None">
                                    <lvc:CartesianChart.Series>
                                        <lvc:SeriesCollection>
                                            <lvc:XamlLineSeries
                                                AnimationsSpeed="0"
                                                Fill="{x:Null}"
                                                GeometryFill="{x:Null}"
                                                GeometryStroke="{x:Null}"
                                                Stroke="{lvc:SolidColorPaint Color='#FFD7D8FF', StrokeWidth='2'}"
                                                Values="{x:Bind ViewModel.CpuClockHistory, Mode=OneWay}" />
                                        </lvc:SeriesCollection>
                                    </lvc:CartesianChart.Series>
                                    <lvc:CartesianChart.XAxes>
                                        <lvc:AxesCollection>
                                            <lvc:XamlDateTimeAxis
                                                AnimationsSpeed="0"
                                                CustomSeparators="{x:Bind ViewModel.CpuClockHistorySeparators, Mode=OneWay}"
                                                DateFormatter="{x:Bind ViewModel.CpuClockLabelsFormatter}"
                                                Interval="0:10:0"
                                                LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                                MaxLimit="{x:Bind ViewModel.CpuClockHistoryMaxLimit, Mode=OneWay}"
                                                MinLimit="{x:Bind ViewModel.CpuClockHistoryMinLimit, Mode=OneWay}"
                                                SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                ShowSeparatorLines="True"
                                                TextSize="8" />
                                        </lvc:AxesCollection>
                                    </lvc:CartesianChart.XAxes>
                                    <lvc:CartesianChart.YAxes>
                                        <lvc:AxesCollection>
                                            <lvc:XamlAxis
                                                Padding="{lvc:Padding Value='0,0'}"
                                                LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                                SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                                ShowSeparatorLines="True"
                                                TextSize="8" />
                                        </lvc:AxesCollection>
                                    </lvc:CartesianChart.YAxes>
                                </lvc:CartesianChart>
                            </StackPanel>
                        </controls:ElevatedCard>
                    </StackPanel>

                    <TextBlock
                        Margin="15,0"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="CPU Packages" />
                    <GridView
                        Margin="10,0"
                        IsItemClickEnabled="False"
                        ItemContainerStyle="{StaticResource CapabilityGridItemStyle}"
                        ItemsSource="{x:Bind ViewModel.CpuPackageCards, Mode=OneWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollMode="Disabled"
                        SelectionMode="None">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="local:DeviceCapabilitiesCpuPackageCardModel">
                                <controls:ElevatedCard
                                    Width="460"
                                    HorizontalContentAlignment="Stretch"
                                    VerticalContentAlignment="Stretch"
                                    Background="{StaticResource CardBackgroundBrush}">
                                    <StackPanel Padding="14" Spacing="10">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock
                                                FontSize="18"
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind Title, Mode=OneWay}"
                                                TextWrapping="WrapWholeWords" />

                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Foreground="{StaticResource TextSecondaryBrush}"
                                                Text="{x:Bind PackageLabel, Mode=OneWay}" />
                                        </Grid>

                                        <Grid ColumnSpacing="8" RowSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <Border Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Manufacturer" />
                                                    <TextBlock
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        Text="{x:Bind ManufacturerDisplay, Mode=OneWay}"
                                                        TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Current clock" />
                                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind CurrentClockDisplay, Mode=OneWay}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="1" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Max clock" />
                                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind MaxClockDisplay, Mode=OneWay}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="1" Grid.Column="1" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Socket" />
                                                    <TextBlock
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        Text="{x:Bind SocketDisplay, Mode=OneWay}"
                                                        TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="2" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Physical cores" />
                                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind PhysicalCoreCountDisplay, Mode=OneWay}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="2" Grid.Column="1" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Logical processors" />
                                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind LogicalProcessorCountDisplay, Mode=OneWay}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="3" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="L1 cache" />
                                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind L1CacheDisplay, Mode=OneWay}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="3" Grid.Column="1" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="L2 cache" />
                                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind L2CacheDisplay, Mode=OneWay}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="4" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="L3 cache" />
                                                    <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind L3CacheDisplay, Mode=OneWay}" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Row="4" Grid.Column="1" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Virtualization" />
                                                    <TextBlock
                                                        Foreground="{StaticResource TextPrimaryBrush}"
                                                        Text="{x:Bind VirtualizationDisplay, Mode=OneWay}"
                                                        TextWrapping="WrapWholeWords" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </controls:ElevatedCard>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock
                        Margin="15,0"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Storage" />
                    <StackPanel Margin="10,0" Spacing="12">
                        <controls:ElevatedCard
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            Background="{StaticResource CardBackgroundBrush}">
                            <StackPanel Padding="14" Spacing="14">
                                <TextBlock
                                    FontSize="22"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="Drive Summary" />
                                <Grid ColumnSpacing="12" RowSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Drives" />
                                            <TextBlock
                                                Style="{StaticResource CopyableValueTextBlockStyle}"
                                                FontSize="26"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind ViewModel.StorageDriveCount, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Total capacity" />
                                            <TextBlock
                                                Style="{StaticResource CopyableValueTextBlockStyle}"
                                                FontSize="26"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind ViewModel.TotalStorageCapacity, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="1" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                        <StackPanel>
                                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Used" />
                                            <TextBlock
                                                Style="{StaticResource CopyableValueTextBlockStyle}"
                                                FontSize="26"
                                                Foreground="{StaticResource TextPrimaryBrush}"
                                                Text="{x:Bind ViewModel.TotalStorageUsedSpace, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>

