                                            <Border Grid.Column="1" Padding="10" Background="#1AFFFFFF" CornerRadius="10">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Monitor Type" />
