<Page
    x:Class="SubZeroFramework.Presentation.MenuItems.DeviceCapabilities.DeviceCapabilitiesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.DeviceCapabilities.Models"
    xmlns:uen="using:Uno.Extensions.Navigation.UI"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.Resources>
        <!--  One rail entry: accent bar | icon | name | count badge. Clicking navigates the category sub-region.  -->
        <DataTemplate x:Key="DeviceCapabilitiesCategoryTemplate" x:DataType="models:DeviceCapabilitiesCategoryRailItemModel">
            <Button
                Margin="0,2"
                Padding="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Stretch"
                Background="{x:Bind RailBackground, Mode=OneWay}"
                BorderThickness="0"
                Click="OnCategoryItemClick"
                CornerRadius="8">
                <Grid Height="40" ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border
                        Grid.Column="0"
                        Width="3"
                        Height="22"
                        VerticalAlignment="Center"
                        Background="{StaticResource BrandPrimaryBrush}"
                        CornerRadius="2"
                        Visibility="{x:Bind AccentBarVisibility, Mode=OneWay}" />
                    <material:MaterialIcon
                        Grid.Column="1"
                        Width="17"
                        Height="17"
                        Margin="9,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{x:Bind NameBrush, Mode=OneWay}"
                        Kind="{x:Bind IconKind}" />
                    <TextBlock
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{x:Bind NameBrush, Mode=OneWay}"
                        Text="{x:Bind Name}" />
                    <TextBlock
                        Grid.Column="3"
                        Margin="0,0,12,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="{x:Bind CountDisplay, Mode=OneWay}"
                        Visibility="{x:Bind CountVisibility, Mode=OneWay}" />
                </Grid>
            </Button>
        </DataTemplate>
    </Page.Resources>

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <Grid Padding="15,0,15,24" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                FontSize="28"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="Device capabilities" />

            <!--  Two-pane body: category rail | category body sub-region resolved by navigation (like the fan modes)  -->
            <Grid Grid.Row="1" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12">
                    <ItemsControl
                        Padding="8"
                        VerticalAlignment="Top"
                        ItemTemplate="{StaticResource DeviceCapabilitiesCategoryTemplate}"
                        ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}" />
                </Border>

                <!--
                    No page-level ScrollViewer: category bodies manage their own detail scrolling so their
                    picker panels can stretch to the window bottom like the rail (see full-height rule).
                -->
                <ContentControl
                    x:Name="CategoryRegionHost"
                    Grid.Column="1"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    uen:Region.Attached="True" />
            </Grid>
        </Grid>
    </Grid>
</Page>
