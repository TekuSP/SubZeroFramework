<UserControl
    x:Class="SubZeroFramework.Presentation.MenuItems.DeviceCapabilities.Categories.DeviceCapabilitiesNetworkAdapterDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="12">
        <TextBlock
            FontSize="20"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="{x:Bind ViewModel.Adapter.Title, Mode=OneWay}" />

        <deviceCapabilitiesControls:StatTilePanel>
            <deviceCapabilitiesControls:StatTileView
                IconKind="ExpansionCard"
                Label="Product"
                Value="{x:Bind ViewModel.Adapter.ProductDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Ethernet"
                Label="Connection"
                Value="{x:Bind ViewModel.Adapter.FriendlyTypeDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Speedometer"
                Label="Link speed"
                Value="{x:Bind ViewModel.Adapter.SpeedDisplay, Mode=OneWay}"
                ValueBrush="{x:Bind ViewModel.Adapter.SpeedBrush, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Barcode"
                Label="MAC address"
                Value="{x:Bind ViewModel.Adapter.MacAddressDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="IpNetwork"
                Label="IP addresses"
                Value="{x:Bind ViewModel.Adapter.IpAddressesDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="RouterNetwork"
                Label="Gateways"
                Value="{x:Bind ViewModel.Adapter.DefaultGatewaysDisplay, Mode=OneWay}" />
        </deviceCapabilitiesControls:StatTilePanel>
    </StackPanel>
</UserControl>
