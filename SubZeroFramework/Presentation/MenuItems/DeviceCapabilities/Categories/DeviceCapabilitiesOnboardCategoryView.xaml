<UserControl
    x:Class="SubZeroFramework.Presentation.MenuItems.DeviceCapabilities.Categories.DeviceCapabilitiesOnboardCategoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="0,0,12,0" VerticalScrollBarVisibility="Auto">
        <deviceCapabilitiesControls:OnboardStatusSectionView Margin="0,0,0,14" ViewModel="{x:Bind ViewModel.Section, Mode=OneWay}" />
    </ScrollViewer>
</UserControl>
