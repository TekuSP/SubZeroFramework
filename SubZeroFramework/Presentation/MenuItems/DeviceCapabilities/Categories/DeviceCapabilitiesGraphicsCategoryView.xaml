<UserControl
    x:Class="SubZeroFramework.Presentation.MenuItems.DeviceCapabilities.Categories.DeviceCapabilitiesGraphicsCategoryView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:branding="using:SubZeroFramework.Controls.Branding"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.DeviceCapabilities.Models"
    xmlns:uen="using:Uno.Extensions.Navigation.UI"
    mc:Ignorable="d">

    <Grid RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <deviceCapabilitiesControls:GraphicsSectionView ViewModel="{x:Bind ViewModel.Section, Mode=OneWay}" />

        <!--  Adapter picker | monitor picker | detail sub-regions resolved by data navigation (mockup: adapter
              detail stacked above the picked monitor's detail in one scrolling pane).  -->
        <Grid Grid.Row="1" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:InstancePickerView
                x:Name="Picker"
                Title="GRAPHICS ADAPTERS"
                EmptyText="None detected"
                ItemsSource="{x:Bind ViewModel.Page.GraphicsCardGroups, Mode=OneWay}"
                SelectionChanged="OnPickerSelectionChanged">
                <controls:InstancePickerView.ItemTemplate>
                            <DataTemplate x:DataType="models:DeviceCapabilitiesGraphicsCardGroupModel">
                                <Grid Margin="0,6" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <branding:BrandLogoView
                                        VerticalAlignment="Center"
                                        FallbackGlyph="ExpansionCard"
                                        IconSize="32"
                                        Vendor="{x:Bind DisplayName, Mode=OneWay}" />
                                    <StackPanel Grid.Column="1" Spacing="1">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind AdapterLabel, Mode=OneWay}" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{x:Bind DisplayName, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                </controls:InstancePickerView.ItemTemplate>
            </controls:InstancePickerView>

            <!--  ItemsSource is set from code-behind: the list is scoped to the picked adapter's monitors.  -->
            <controls:InstancePickerView
                x:Name="MonitorPicker"
                Grid.Column="1"
                Title="MONITORS"
                EmptyText="None detected"
                SelectionChanged="OnMonitorPickerSelectionChanged">
                <controls:InstancePickerView.ItemTemplate>
                            <DataTemplate x:DataType="models:DeviceCapabilitiesMonitorCardModel">
                                <Grid Margin="0,6" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <branding:BrandLogoView
                                        VerticalAlignment="Center"
                                        FallbackGlyph="Monitor"
                                        IconSize="32"
                                        Vendor="{x:Bind DisplayManufacturer, Mode=OneWay}" />
                                    <StackPanel Grid.Column="1" Spacing="1">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind DisplayName, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{x:Bind PickerSubtitle, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                </controls:InstancePickerView.ItemTemplate>
            </controls:InstancePickerView>

            <ScrollViewer
                Grid.Column="2"
                Padding="0,0,12,0"
                VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,0,14" Spacing="18">
                    <ContentControl
                        x:Name="DetailHost"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Top"
                        uen:Region.Attached="True" />
                    <ContentControl
                        x:Name="MonitorDetailHost"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Top"
                        uen:Region.Attached="True" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
