<UserControl
    x:Class="SubZeroFramework.Presentation.MenuItems.DeviceCapabilities.Categories.DeviceCapabilitiesGraphicsMonitorDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Monitor detail per the mockup: plain heading + stat tiles (Status green when active, Resolution carries the standard badge).  -->
    <StackPanel Spacing="12">
        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            IsTextSelectionEnabled="True"
            Text="{x:Bind ViewModel.Monitor.DisplayName, Mode=OneWay}" />

        <deviceCapabilitiesControls:StatTilePanel>
            <deviceCapabilitiesControls:StatTileView
                IconKind="CheckCircle"
                Label="Status"
                Value="{x:Bind ViewModel.Monitor.DisplayStatus, Mode=OneWay}"
                ValueBrush="{x:Bind ViewModel.Monitor.StatusBrush, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Monitor"
                Label="Monitor type"
                Value="{x:Bind ViewModel.Monitor.MonitorType, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Factory"
                Label="Manufacturer"
                Value="{x:Bind ViewModel.Monitor.DisplayManufacturer, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                Badge="{x:Bind ViewModel.Monitor.ResolutionBadge, Mode=OneWay}"
                IconKind="MonitorScreenshot"
                Label="Resolution"
                Value="{x:Bind ViewModel.Monitor.DisplayCurrentResolution, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="SineWave"
                Label="Refresh rate"
                Value="{x:Bind ViewModel.Monitor.DisplayCurrentRefreshRate, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="FormatSize"
                Label="Display density"
                Value="{x:Bind ViewModel.Monitor.DisplayLogicalDensity, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Tag"
                Label="Product code ID"
                Value="{x:Bind ViewModel.Monitor.ProductCodeId, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Pound"
                Label="Serial number"
                Value="{x:Bind ViewModel.Monitor.SerialNumberId, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="CalendarMonth"
                Label="Manufactured"
                Value="{x:Bind ViewModel.Monitor.ManufacturedDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="InformationOutline"
                Label="Description"
                Value="{x:Bind ViewModel.Monitor.Description, Mode=OneWay}" />
        </deviceCapabilitiesControls:StatTilePanel>
    </StackPanel>
</UserControl>
