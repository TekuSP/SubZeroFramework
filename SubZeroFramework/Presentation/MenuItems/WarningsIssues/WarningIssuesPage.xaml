<Page
    x:Class="SubZeroFramework.Presentation.MenuItems.WarningsIssues.WarningIssuesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="RecoveryActionButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </Page.Resources>

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <!--  Centered recovery hero: one layout, themed per state severity (recovery / limited /
                  read-only / all-clear), so every distinct warning and error message reuses it.  -->
            <StackPanel
                MaxWidth="760"
                Padding="24,48,24,32"
                HorizontalAlignment="Center"
                Spacing="0">

                <!--  Severity-tinted fan badge  -->
                <Grid
                    Width="92"
                    Height="92"
                    HorizontalAlignment="Center">
                    <Ellipse
                        Fill="{x:Bind ViewModel.HeroBadgeBackground, Mode=OneWay}"
                        Stroke="{x:Bind ViewModel.HeroBadgeBorderBrush, Mode=OneWay}"
                        StrokeThickness="1" />
                    <material:MaterialIcon
                        Width="38"
                        Height="38"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{x:Bind ViewModel.HeroAccentBrush, Mode=OneWay}"
                        Kind="Fan" />
                </Grid>

                <!--  Eyebrow: dot + letter-spaced mode label  -->
                <StackPanel
                    Margin="0,22,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="8">
                    <Ellipse
                        Width="7"
                        Height="7"
                        VerticalAlignment="Center"
                        Fill="{x:Bind ViewModel.HeroAccentBrush, Mode=OneWay}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        CharacterSpacing="200"
                        FontSize="12"
                        FontWeight="SemiBold"
                        Foreground="{x:Bind ViewModel.HeroAccentBrush, Mode=OneWay}"
                        Text="{x:Bind ViewModel.Eyebrow, Mode=OneWay}" />
                </StackPanel>

                <TextBlock
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    FontSize="32"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.StatusTitle, Mode=OneWay}"
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords" />

                <TextBlock
                    MaxWidth="540"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Center"
                    FontSize="14"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords" />

                <!--  Lifecycle actions: Install (primary) appears only when installable; Update only when
                      the packaged helper is newer than the registration.  -->
                <StackPanel
                    Margin="0,26,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="10">
                    <Button
                        Background="{StaticResource BrandPrimaryBrush}"
                        Command="{x:Bind ViewModel.InstallServiceCommand, Mode=OneWay}"
                        Style="{StaticResource RecoveryActionButtonStyle}"
                        Visibility="{x:Bind ViewModel.InstallButtonVisibility, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon
                                Width="15"
                                Height="15"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Kind="Download" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Install service" />
                        </StackPanel>
                    </Button>
                    <Button
                        Command="{x:Bind ViewModel.RestartServiceCommand, Mode=OneWay}"
                        Style="{StaticResource RecoveryActionButtonStyle}"
                        Visibility="{x:Bind ViewModel.RestartButtonVisibility, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon
                                Width="15"
                                Height="15"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Kind="Restart" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Restart service" />
                        </StackPanel>
                    </Button>
                    <Button
                        Command="{x:Bind ViewModel.UpdateServiceCommand, Mode=OneWay}"
                        Style="{StaticResource RecoveryActionButtonStyle}"
                        Visibility="{x:Bind ViewModel.UpdateButtonVisibility, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon
                                Width="15"
                                Height="15"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Kind="Update" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Update service" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!--  UAC / readiness hint  -->
                <StackPanel
                    MaxWidth="560"
                    Margin="0,14,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="7">
                    <material:MaterialIcon
                        Width="13"
                        Height="13"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Kind="ShieldCheckOutline" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="{x:Bind ViewModel.ActionHint, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                </StackPanel>

                <InfoBar
                    Title="{x:Bind ViewModel.LastActionTitle, Mode=OneWay}"
                    MaxWidth="620"
                    Margin="0,16,0,0"
                    IsClosable="True"
                    IsOpen="{x:Bind ViewModel.IsLastActionVisible, Mode=TwoWay}"
                    Message="{x:Bind ViewModel.LastActionMessage, Mode=OneWay}"
                    Severity="{x:Bind ViewModel.LastActionSeverity, Mode=OneWay}" />

                <!--  Paused capabilities | detected state  -->
                <StackPanel
                    Margin="0,26,0,0"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="14">
                    <Border
                        Width="270"
                        Padding="16,14"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource SurfaceOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <material:MaterialIcon
                                    Width="14"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Kind="PauseCircleOutline" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="{x:Bind ViewModel.PausedCardTitle, Mode=OneWay}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.DisabledControlOneVisibility, Mode=OneWay}">
                                <material:MaterialIcon
                                    Width="12"
                                    Height="12"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Kind="Minus" />
                                <TextBlock
                                    MaxWidth="215"
                                    VerticalAlignment="Center"
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.DisabledControlOne, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.DisabledControlTwoVisibility, Mode=OneWay}">
                                <material:MaterialIcon
                                    Width="12"
                                    Height="12"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Kind="Minus" />
                                <TextBlock
                                    MaxWidth="215"
                                    VerticalAlignment="Center"
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.DisabledControlTwo, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.DisabledControlThreeVisibility, Mode=OneWay}">
                                <material:MaterialIcon
                                    Width="12"
                                    Height="12"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Kind="Minus" />
                                <TextBlock
                                    MaxWidth="215"
                                    VerticalAlignment="Center"
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.DisabledControlThree, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8" Visibility="{x:Bind ViewModel.DisabledControlFourVisibility, Mode=OneWay}">
                                <material:MaterialIcon
                                    Width="12"
                                    Height="12"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Kind="Minus" />
                                <TextBlock
                                    MaxWidth="215"
                                    VerticalAlignment="Center"
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.DisabledControlFour, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border
                        Width="300"
                        Padding="16,14"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource SurfaceOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <material:MaterialIcon
                                    Width="14"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Kind="InformationOutline" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="Detected state" />
                            </StackPanel>

                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="Manager" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontSize="12.5"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.PlatformServiceManager, Mode=OneWay}" />
                            </Grid>
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="Registration" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontSize="12.5"
                                    FontWeight="SemiBold"
                                    Foreground="{x:Bind ViewModel.RegistrationBrush, Mode=OneWay}"
                                    Text="{x:Bind ViewModel.RegistrationDisplay, Mode=OneWay}" />
                            </Grid>
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="Service" />
                                <TextBlock
                                    Grid.Column="1"
                                    FontSize="12.5"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.ServiceIdentity, Mode=OneWay}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!--  Full explanation for the current state (every message variant keeps its detail text)  -->
                <TextBlock
                    MaxWidth="640"
                    Margin="0,22,0,0"
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Opacity="0.8"
                    Text="{x:Bind ViewModel.ExplanationBody, Mode=OneWay}"
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords" />

                <Button
                    Margin="0,18,0,0"
                    Padding="12,6"
                    HorizontalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{x:Bind ViewModel.RecheckCommand, Mode=OneWay}"
                    CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <material:MaterialIcon
                            Width="13"
                            Height="13"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Kind="Refresh" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12.5"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="Recheck now" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
