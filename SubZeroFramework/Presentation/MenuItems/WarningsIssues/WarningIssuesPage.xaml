<Page
    x:Class="SubZeroFramework.Presentation.MenuItems.WarningsIssues.WarningIssuesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SubZeroFramework.Presentation.MenuItems.WarningsIssues"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="WarningCardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <Style x:Key="WarningCardBodyStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style x:Key="WarningCardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>

        <Style x:Key="DisabledCardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryDisabledBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
            <Setter Property="TextDecorations" Value="Strikethrough" />
        </Style>

        <Style x:Key="WarningSmallLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="WarningActionButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <Grid utu:SafeArea.Insets="VisibleBounds">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="0,0,0,20">
                <StackPanel Margin="10,0,0,12">
                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Warnings and Issues" />
                </StackPanel>

                <controls:ElevatedCard
                    Margin="5,0,0,5"
                    Padding="0"
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="16">
                    <Grid MinHeight="252">
                        <Border
                            Background="{StaticResource StatusErrorBrush}"
                            CornerRadius="16"
                            Visibility="{x:Bind ViewModel.ErrorHeroVisibility, Mode=OneWay}" />
                        <Border
                            Background="{StaticResource StatusWarningBrush}"
                            CornerRadius="16"
                            Visibility="{x:Bind ViewModel.WarningHeroVisibility, Mode=OneWay}" />
                        <Border
                            Background="{StaticResource StatusSuccessBrush}"
                            CornerRadius="16"
                            Visibility="{x:Bind ViewModel.SuccessHeroVisibility, Mode=OneWay}" />
                        <Border
                            Background="{StaticResource BrandPrimaryBrush}"
                            CornerRadius="16"
                            Visibility="{x:Bind ViewModel.InformationalHeroVisibility, Mode=OneWay}" />

                        <Grid
                            Padding="22,20"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch"
                            ColumnSpacing="18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="146" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Grid
                                Width="128"
                                Height="128"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                                <Border
                                    Width="100"
                                    Height="100"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Background="#14000000"
                                    BorderBrush="{StaticResource BrandPrimaryBrush}"
                                    BorderThickness="5"
                                    CornerRadius="50">
                                    <TextBlock
                                        Margin="0,-6,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontFamily="{StaticResource MontserratFont}"
                                        FontSize="66"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource BrandPrimaryBrush}"
                                        Text="i" />
                                </Border>

                                <Border
                                    Width="56"
                                    Height="56"
                                    Margin="0,0,4,8"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Background="#16000000"
                                    BorderBrush="{StaticResource BrandPrimaryBrush}"
                                    BorderThickness="4"
                                    CornerRadius="28">
                                    <Grid>
                                        <material:MaterialIcon
                                            Width="30"
                                            Height="30"
                                            Margin="0,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Kind="Fan" />
                                        <Line
                                            HorizontalAlignment="Stretch"
                                            VerticalAlignment="Stretch"
                                            Stroke="{StaticResource BrandPrimaryBrush}"
                                            StrokeEndLineCap="Round"
                                            StrokeStartLineCap="Round"
                                            StrokeThickness="4"
                                            X1="43"
                                            X2="9"
                                            Y1="9"
                                            Y2="43" />
                                    </Grid>
                                </Border>
                            </Grid>

                            <StackPanel
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Spacing="8">
                                <TextBlock
                                    FontSize="40"
                                    FontWeight="Bold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.StatusTitle, Mode=OneWay}"
                                    TextAlignment="Left"
                                    TextWrapping="WrapWholeWords" />

                                <TextBlock
                                    FontSize="19"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                    TextAlignment="Left"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </controls:ElevatedCard>

                <Grid Margin="5,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <controls:ElevatedCard
                        Grid.Row="0"
                        Grid.Column="0"
                        MinHeight="200"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel Margin="15" Spacing="14">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <material:MaterialIcon
                                    Width="24"
                                    Height="24"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Kind="LanConnect" />
                                <TextBlock Style="{StaticResource WarningCardTitleStyle}" Text="Detected Service State" />
                            </StackPanel>

                            <TextBlock Style="{StaticResource WarningCardValueStyle}" Text="{x:Bind ViewModel.ServiceStateLineOne, Mode=OneWay}" />
                            <TextBlock Style="{StaticResource WarningCardValueStyle}" Text="{x:Bind ViewModel.ServiceStateLineTwo, Mode=OneWay}" />
                            <TextBlock Style="{StaticResource WarningCardValueStyle}" Text="{x:Bind ViewModel.ServiceStateLineThree, Mode=OneWay}" />
                        </StackPanel>
                    </controls:ElevatedCard>

                    <controls:ElevatedCard
                        Grid.Row="0"
                        Grid.Column="1"
                        MinHeight="200"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel Margin="15" Spacing="14">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <material:MaterialIcon
                                    Width="24"
                                    Height="24"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Kind="AlertCircleOutline" />
                                <TextBlock Style="{StaticResource WarningCardTitleStyle}" Text="Disabled Controls" />
                            </StackPanel>

                            <TextBlock Style="{StaticResource DisabledCardValueStyle}" Text="{x:Bind ViewModel.DisabledControlOne, Mode=OneWay}" />
                            <TextBlock Style="{StaticResource DisabledCardValueStyle}" Text="{x:Bind ViewModel.DisabledControlTwo, Mode=OneWay}" />
                            <TextBlock Style="{StaticResource DisabledCardValueStyle}" Text="{x:Bind ViewModel.DisabledControlThree, Mode=OneWay}" />
                            <TextBlock Style="{StaticResource DisabledCardValueStyle}" Text="{x:Bind ViewModel.DisabledControlFour, Mode=OneWay}" />
                        </StackPanel>
                    </controls:ElevatedCard>

                    <controls:ElevatedCard
                        Grid.Row="1"
                        Grid.Column="0"
                        MinHeight="200"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel Margin="15" Spacing="14">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <material:MaterialIcon
                                    Width="24"
                                    Height="24"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Kind="TextBoxOutline" />
                                <TextBlock Style="{StaticResource WarningCardTitleStyle}" Text="Explanation" />
                            </StackPanel>

                            <TextBlock Style="{StaticResource WarningCardBodyStyle}" Text="{x:Bind ViewModel.ExplanationBody, Mode=OneWay}" />
                        </StackPanel>
                    </controls:ElevatedCard>

                    <controls:ElevatedCard
                        Grid.Row="1"
                        Grid.Column="1"
                        MinHeight="200"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel Margin="15" Spacing="14">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <material:MaterialIcon
                                    Width="24"
                                    Height="24"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Kind="WrenchOutline" />
                                <TextBlock Style="{StaticResource WarningCardTitleStyle}" Text="Actions" />
                            </StackPanel>

                            <StackPanel Spacing="10">
                                <Button
                                    Command="{x:Bind ViewModel.RestartServiceCommand, Mode=OneWay}"
                                    Content="Restart service"
                                    IsEnabled="{x:Bind ViewModel.IsServiceControlSupported, Mode=OneWay}"
                                    Style="{StaticResource WarningActionButtonStyle}" />
                                <Button
                                    Command="{x:Bind ViewModel.InstallServiceCommand, Mode=OneWay}"
                                    Content="Install service"
                                    IsEnabled="{x:Bind ViewModel.CanInstallService, Mode=OneWay}"
                                    Style="{StaticResource WarningActionButtonStyle}" />
                                <Button
                                    Command="{x:Bind ViewModel.UpdateServiceCommand, Mode=OneWay}"
                                    Content="Update service"
                                    IsEnabled="{x:Bind ViewModel.CanUpdateService, Mode=OneWay}"
                                    Style="{StaticResource WarningActionButtonStyle}" />
                                <Button
                                    Command="{x:Bind ViewModel.UninstallServiceCommand, Mode=OneWay}"
                                    Content="Uninstall service"
                                    IsEnabled="{x:Bind ViewModel.IsServiceControlSupported, Mode=OneWay}"
                                    Style="{StaticResource WarningActionButtonStyle}" />
                            </StackPanel>

                            <TextBlock Style="{StaticResource WarningCardBodyStyle}" Text="{x:Bind ViewModel.ActionHint, Mode=OneWay}" />

                            <InfoBar
                                Title="{x:Bind ViewModel.LastActionTitle, Mode=OneWay}"
                                IsClosable="True"
                                IsOpen="{x:Bind ViewModel.IsLastActionVisible, Mode=TwoWay}"
                                Message="{x:Bind ViewModel.LastActionMessage, Mode=OneWay}"
                                Severity="{x:Bind ViewModel.LastActionSeverity, Mode=OneWay}" />
                        </StackPanel>
                    </controls:ElevatedCard>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
