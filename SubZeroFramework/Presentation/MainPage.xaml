<Page
    x:Class="SubZeroFramework.Presentation.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:header="using:SubZeroFramework.Presentation.Header"
    xmlns:len="using:SubZeroFramework.Extensions"
    xmlns:local="using:SubZeroFramework.Presentation"
    xmlns:uen="using:Uno.Extensions.Navigation.UI"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{StaticResource AppBackgroundBrush}"
    NavigationCacheMode="Required">
    <Page.Transitions>
        <TransitionCollection>
            <EntranceThemeTransition />
        </TransitionCollection>
    </Page.Transitions>
    <Grid uen:Region.Attached="True" utu:SafeArea.Insets="VisibleBounds">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid
            x:Name="TitleBarHost"
            Height="48"
            Background="{StaticResource SidebarBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="PaneToggleButtonColumn" Width="48" />
                <ColumnDefinition x:Name="DraggableAreaColumn" Width="*" />
            </Grid.ColumnDefinitions>
            <AppBarButton
                x:Name="PaneToggleButton"
                Grid.Column="0"
                Margin="5,0,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Click="PaneToggleButton_Click"
                Icon="GlobalNavigationButton" />
            <Grid Grid.Column="1" />
        </Grid>
        <NavigationView
            x:Name="MainNavigationView"
            Grid.Row="1"
            uen:Region.Attached="True"
            uen:Region.Navigator="ConfirmNav"
            Background="{StaticResource SidebarBackgroundBrush}"
            IsBackButtonVisible="Collapsed"
            IsBackEnabled="False"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            OpenPaneLength="250"
            PaneDisplayMode="LeftCompact"
            SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            SelectionChanged="{x:Bind MainNavigationView_SelectionChanged}">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    uen:Region.Name="Dashboard"
                    Content="Dashboard"
                    Icon="{len:FontIconStringExt Glyph={StaticResource DashboardMenuIcon}}"
                    IsEnabled="{x:Bind ViewModel.IsDashboardEnabled, Mode=OneWay}" />
                <NavigationViewItem
                    uen:Region.Name="ThermalTelemetry"
                    Content="Thermal Telemetry"
                    Icon="{len:FontIconStringExt Glyph={StaticResource ThermalTelemetryMenuIcon}}"
                    IsEnabled="{x:Bind ViewModel.IsThermalTelemetryEnabled, Mode=OneWay}" />
                <NavigationViewItem
                    uen:Region.Name="PowerTelemetry"
                    Content="Power Telemetry"
                    Icon="{len:FontIconStringExt Glyph={StaticResource PowerTelemetryMenuIcon}}"
                    IsEnabled="{x:Bind ViewModel.IsPowerTelemetryEnabled, Mode=OneWay}" />
                <controls:NavigationMaterialViewItem
                    uen:Region.Name="FanCurveProfiles"
                    IsEnabled="{x:Bind ViewModel.IsFanCurveProfilesEnabled, Mode=OneWay}"
                    MaterialIconKindName="{StaticResource FanCurveMenuIcon}"
                    Tag="FanCurveProfiles"
                    Text="Fan Curve Profiles" />
                <NavigationViewItem
                    uen:Region.Name="DeviceCapabilities"
                    Content="Device Capabilities"
                    Icon="{len:FontIconStringExt Glyph={StaticResource DeviceCapabilitiesMenuIcon}}"
                    IsEnabled="{x:Bind ViewModel.IsDeviceCapabilitiesEnabled, Mode=OneWay}" />
                <controls:NavigationMaterialViewItem
                    uen:Region.Name="Modules"
                    IsEnabled="{x:Bind ViewModel.IsModulesEnabled, Mode=OneWay}"
                    MaterialIconKindName="{StaticResource ModulesMenuIcon}"
                    Text="Modules" />
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem
                    uen:Region.Name="WarningIssues"
                    Content="Warnings and issues"
                    Icon="{len:FontIconStringExt Glyph={StaticResource WarningsMenuIcon}}"
                    IsEnabled="{x:Bind ViewModel.IsWarningIssuesEnabled, Mode=OneWay}"
                    Tag="WarningIssues" />
                <controls:NavigationMaterialViewItem
                    MaterialIconKindName="{StaticResource GithubMenuIcon}"
                    Tag="Github"
                    Text="Project Github" />
                <NavigationViewItem
                    uen:Region.Name="Settings"
                    Content="Settings"
                    Icon="{len:FontIconStringExt Glyph={StaticResource SettingsMenuIcon}}"
                    Tag="Settings" />
            </NavigationView.FooterMenuItems>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <header:SubZeroHeaderControl
                    Grid.Row="0"
                    SuppressErrorBar="{x:Bind ViewModel.IsWarningIssuesSelected, Mode=OneWay}"
                    SystemContainer="{x:Bind ViewModel.ServiceProvider, Mode=OneWay}" />
                <Grid
                    Grid.Row="1"
                    uen:Region.Attached="True"
                    uen:Region.Navigator="Visibility">
                    <Grid.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition />
                        </TransitionCollection>
                    </Grid.ChildrenTransitions>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Page>
