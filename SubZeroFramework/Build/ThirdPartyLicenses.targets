<Project>
  <!--
    Generates Assets/ThirdPartyLicenses/third-party-licenses.json for the Settings → Licenses page.

    Sources: the FULL RECURSIVE dependency closure — every package restore resolved for the app, Core,
    GrpcContracts, and Service projects (each project.assets.json lists dependencies of dependencies, all
    the way down), plus every centrally pinned NuGet package (Directory.Packages.props → @(PackageVersion))
    and the Uno.Sdk-injected implicit references of this project (@(PackageReference)). For each package
    the license is pulled from the installed package in the global packages folder: an embedded license
    file when the package ships one, otherwise a canonical SPDX template (Build/LicenseTexts) filled with
    the package's copyright/authors. Build-time and test-only packages are excluded below. The report
    lands in the intermediate directory and is linked into the output as
    Assets/ThirdPartyLicenses/third-party-licenses.json.
  -->

  <UsingTask TaskName="GenerateThirdPartyLicenseReport" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <Packages ParameterType="Microsoft.Build.Framework.ITaskItem[]" Required="true" />
      <StaticPackages ParameterType="Microsoft.Build.Framework.ITaskItem[]" />
      <AssetsFiles ParameterType="System.String" />
      <NuGetPackagesRoot ParameterType="System.String" Required="true" />
      <TemplateDirectory ParameterType="System.String" Required="true" />
      <ExcludedPackages ParameterType="System.String" />
      <OutputFile ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.Collections.Generic" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Linq" />
      <Using Namespace="System.Text" />
      <Using Namespace="System.Text.RegularExpressions" />
      <Using Namespace="System.Xml.Linq" />
      <Code Type="Fragment" Language="cs">
        <![CDATA[
        var excluded = new HashSet<string>(
            (ExcludedPackages ?? string.Empty).Split(new[] { ';' }, StringSplitOptions.RemoveEmptyEntries).Select(entry => entry.Trim()),
            StringComparer.OrdinalIgnoreCase);

        // Resolved packages from restore ("Id/Version" keys with type "package"). Each project.assets.json
        // lists the FULL transitive closure NuGet resolved for its project — dependencies of dependencies,
        // recursively — so this dictionary is both the version source for Uno.Sdk-injected implicit
        // references AND the recursive package set itself. First file wins on conflicts (the app's own
        // assets file is passed first, so the report matches what ships with the app).
        var resolvedVersions = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

        // dependency id -> the packages that declare it (from the "dependencies" blocks in the targets
        // section), so the report can say which parent imported each transitive library.
        var dependencyParents = new Dictionary<string, HashSet<string>>(StringComparer.OrdinalIgnoreCase);

        foreach (var assetsPath in (AssetsFiles ?? string.Empty).Split(new[] { ';' }, StringSplitOptions.RemoveEmptyEntries).Select(entry => entry.Trim()))
        {
            if (!File.Exists(assetsPath))
            {
                Log.LogMessage("License report: assets file not found: {0} (that project's transitive packages are covered only by central pins this build).", assetsPath);
                continue;
            }

            var assetsText = File.ReadAllText(assetsPath);

            foreach (Match match in Regex.Matches(
                assetsText,
                "\"([A-Za-z0-9_.\\-]+)/([0-9][^\"]*)\"\\s*:\\s*\\{[^{}]*?\"type\"\\s*:\\s*\"package\""))
            {
                if (!resolvedVersions.ContainsKey(match.Groups[1].Value))
                {
                    resolvedVersions[match.Groups[1].Value] = match.Groups[2].Value;
                }
            }

            // "dependencies" objects are flat (name -> version-range string), so [^{}]* captures them whole.
            foreach (Match match in Regex.Matches(
                assetsText,
                "\"([A-Za-z0-9_.\\-]+)/([0-9][^\"]*)\"\\s*:\\s*\\{[^{}]*?\"dependencies\"\\s*:\\s*\\{([^{}]*)\\}"))
            {
                var parent = match.Groups[1].Value;
                foreach (Match dependencyMatch in Regex.Matches(match.Groups[3].Value, "\"([A-Za-z0-9_.\\-]+)\"\\s*:"))
                {
                    var child = dependencyMatch.Groups[1].Value;
                    HashSet<string> parents;
                    if (!dependencyParents.TryGetValue(child, out parents))
                    {
                        parents = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
                        dependencyParents[child] = parents;
                    }

                    parents.Add(parent);
                }
            }
        }

        // Packages the solution references on purpose (central pins + this project's references): they get
        // no "imported by" attribution — only transitive packages do.
        var directPackages = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var item in Packages)
        {
            if (!string.IsNullOrEmpty(item.ItemSpec))
            {
                directPackages.Add(item.ItemSpec);
            }
        }

        // package id -> version; first occurrence wins (PackageVersion pins come first). The restore-resolved
        // version beats the pin when both exist so the report matches what actually ships.
        var packages = new SortedDictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        foreach (var item in Packages)
        {
            var id = item.ItemSpec;
            string resolved;
            var version = resolvedVersions.TryGetValue(id, out resolved) ? resolved : item.GetMetadata("Version");
            if (string.IsNullOrEmpty(id) || string.IsNullOrEmpty(version) || excluded.Contains(id) || packages.ContainsKey(id))
            {
                continue;
            }

            packages[id] = version;
        }

        // Every remaining restore-resolved package (the recursive closure) joins the report too, so
        // transitive dependencies get their licenses listed — not just the direct pins/references.
        foreach (var resolved in resolvedVersions)
        {
            if (!excluded.Contains(resolved.Key) && !packages.ContainsKey(resolved.Key))
            {
                packages[resolved.Key] = resolved.Value;
            }
        }

        var templates = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
        if (Directory.Exists(TemplateDirectory))
        {
            foreach (var templatePath in Directory.GetFiles(TemplateDirectory, "*.txt"))
            {
                templates[Path.GetFileNameWithoutExtension(templatePath)] = File.ReadAllText(templatePath);
            }
        }

        Func<string, string> jsonEscape = value =>
        {
            var builder = new StringBuilder(value.Length + 16);
            foreach (var ch in value)
            {
                switch (ch)
                {
                    case '\\': builder.Append("\\\\"); break;
                    case '"': builder.Append("\\\""); break;
                    case '\n': builder.Append("\\n"); break;
                    case '\r': builder.Append("\\r"); break;
                    case '\t': builder.Append("\\t"); break;
                    default:
                        if (ch < ' ') builder.AppendFormat("\\u{0:x4}", (int)ch);
                        else builder.Append(ch);
                        break;
                }
            }

            return builder.ToString();
        };

        var json = new StringBuilder();
        json.Append("[\n");
        var first = true;
        var written = 0;

        foreach (var package in packages)
        {
            var packageFolder = Path.Combine(NuGetPackagesRoot, package.Key.ToLowerInvariant(), package.Value);
            var nuspecPath = Path.Combine(packageFolder, package.Key.ToLowerInvariant() + ".nuspec");

            if (!Directory.Exists(packageFolder))
            {
                Log.LogMessage("License report: package folder not found for {0} {1}; skipping.", package.Key, package.Value);
                continue;
            }

            string licenseDisplay = "Unknown";
            string licenseText = null;
            string copyright = null;
            string authors = null;

            if (File.Exists(nuspecPath))
            {
                var metadata = XDocument.Load(nuspecPath).Root == null
                    ? null
                    : XDocument.Load(nuspecPath).Root.Elements().FirstOrDefault(element => element.Name.LocalName == "metadata");
                Func<string, string> metadataValue = name =>
                {
                    var element = metadata == null ? null : metadata.Elements().FirstOrDefault(child => child.Name.LocalName == name);
                    return element == null ? null : element.Value.Trim();
                };

                copyright = metadataValue("copyright");
                authors = metadataValue("authors");
                var licenseElement = metadata == null ? null : metadata.Elements().FirstOrDefault(element => element.Name.LocalName == "license");
                var licenseType = licenseElement == null ? null : (string)licenseElement.Attribute("type");
                var licenseValue = licenseElement == null ? null : licenseElement.Value.Trim();
                var licenseUrl = metadataValue("licenseUrl");

                if (licenseType == "expression" && !string.IsNullOrEmpty(licenseValue))
                {
                    licenseDisplay = licenseValue;
                }
                else if (licenseType == "file" && !string.IsNullOrEmpty(licenseValue))
                {
                    licenseDisplay = "License file";
                    var embeddedPath = Path.Combine(packageFolder, licenseValue.Replace('\\', Path.DirectorySeparatorChar).Replace('/', Path.DirectorySeparatorChar));
                    if (File.Exists(embeddedPath))
                    {
                        licenseText = File.ReadAllText(embeddedPath);
                    }
                }
                else if (!string.IsNullOrEmpty(licenseUrl))
                {
                    licenseDisplay = licenseUrl.IndexOf("/MIT", StringComparison.OrdinalIgnoreCase) >= 0 ? "MIT"
                        : licenseUrl.IndexOf("apache", StringComparison.OrdinalIgnoreCase) >= 0 ? "Apache-2.0"
                        : "See text";
                    licenseText = "License: " + licenseUrl;
                }
            }

            if (licenseText == null)
            {
                var licenseFile = Directory.GetFiles(packageFolder)
                    .FirstOrDefault(file =>
                        Path.GetFileNameWithoutExtension(file).Equals("LICENSE", StringComparison.OrdinalIgnoreCase)
                        || Path.GetFileNameWithoutExtension(file).Equals("LICENCE", StringComparison.OrdinalIgnoreCase));
                if (licenseFile != null)
                {
                    licenseText = File.ReadAllText(licenseFile);
                }
            }

            if (licenseText == null)
            {
                string template;
                if (templates.TryGetValue(licenseDisplay, out template))
                {
                    var copyrightLine = !string.IsNullOrEmpty(copyright)
                        ? copyright
                        : "Copyright (c) " + (string.IsNullOrEmpty(authors) ? package.Key : authors);
                    licenseText = template.Replace("{{copyright}}", copyrightLine);
                }
                else
                {
                    // No embedded text and no canonical template for the declared expression (or no
                    // declaration at all): never guess or hard-code a license on the package's behalf.
                    licenseText = "Unknown license terms";
                }
            }

            // Attribute transitive packages to the parents that imported them; parents that made the
            // report themselves are preferred so the line points at a row the user can find.
            var importedBy = string.Empty;
            HashSet<string> parentSet;
            if (!directPackages.Contains(package.Key) && dependencyParents.TryGetValue(package.Key, out parentSet))
            {
                var parents = parentSet.Where(parent => packages.ContainsKey(parent)).OrderBy(parent => parent, StringComparer.OrdinalIgnoreCase).ToList();
                if (parents.Count == 0)
                {
                    parents = parentSet.OrderBy(parent => parent, StringComparer.OrdinalIgnoreCase).ToList();
                }

                importedBy = string.Join(", ", parents.Take(3));
                if (parents.Count > 3)
                {
                    importedBy += " +" + (parents.Count - 3) + " more";
                }
            }

            if (!first)
            {
                json.Append(",\n");
            }

            first = false;
            written++;
            json.Append("  { \"packageId\": \"").Append(jsonEscape(package.Key))
                .Append("\", \"version\": \"").Append(jsonEscape(package.Value))
                .Append("\", \"license\": \"").Append(jsonEscape(licenseDisplay))
                .Append("\", \"importedBy\": \"").Append(jsonEscape(importedBy))
                .Append("\", \"text\": \"").Append(jsonEscape(licenseText.Replace("\r\n", "\n").Trim()))
                .Append("\" }");
        }

        // Non-NuGet components bundled inside a package (e.g. the native framework-system bits vendored in
        // FrameworkDotnet): their license texts live in Build/StaticLicenses and are appended verbatim.
        // An entry with no Version metadata reports the version of the FrameworkDotnet package it ships in.
        if (StaticPackages != null)
        {
            string bundledInVersion;
            packages.TryGetValue("FrameworkDotnet", out bundledInVersion);

            foreach (var item in StaticPackages)
            {
                var version = item.GetMetadata("Version");
                if (string.IsNullOrEmpty(version))
                {
                    version = string.IsNullOrEmpty(bundledInVersion) ? "bundled" : "bundled in FrameworkDotnet " + bundledInVersion;
                }

                var textFile = item.GetMetadata("TextFile");
                var text = File.Exists(textFile)
                    ? File.ReadAllText(textFile)
                    : "License text file missing: " + Path.GetFileName(textFile ?? string.Empty);

                if (!first)
                {
                    json.Append(",\n");
                }

                first = false;
                written++;
                json.Append("  { \"packageId\": \"").Append(jsonEscape(item.ItemSpec))
                    .Append("\", \"version\": \"").Append(jsonEscape(version))
                    .Append("\", \"license\": \"").Append(jsonEscape(item.GetMetadata("License")))
                    .Append("\", \"importedBy\": \"\"")
                    .Append(", \"text\": \"").Append(jsonEscape(text.Replace("\r\n", "\n").Trim()))
                    .Append("\" }");
            }
        }

        json.Append("\n]\n");
        Directory.CreateDirectory(Path.GetDirectoryName(OutputFile));
        File.WriteAllText(OutputFile, json.ToString());
        Log.LogMessage(Microsoft.Build.Framework.MessageImportance.Normal, "License report: wrote {0} packages to {1}", written, OutputFile);
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <Target Name="GenerateThirdPartyLicenseReport"
          BeforeTargets="AssignTargetPaths"
          Condition="'$(DesignTimeBuild)' != 'true'">
    <!-- Resolved at execution time: IntermediateOutputPath is defined by SDK targets imported after this file. -->
    <PropertyGroup>
      <!-- Path.Combine, NOT string concatenation: IntermediateOutputPath is usually relative ("obj/..."),
           but is ABSOLUTE when the build sets ArtifactsPath / BaseIntermediateOutputPath (e.g. building
           from WSL into a native Linux directory so Windows and Linux never share obj/). Concatenating an
           absolute path onto the project directory silently produced <projectdir>/tmp/.../obj/..., i.e. the
           report was written INSIDE the project cone, where the default Content glob picked it up again and
           the publish failed with NETSDK1152 (same relative path twice). Path.Combine returns the second
           argument unchanged when it is already absolute, and picks the right separator per platform. -->
      <ThirdPartyLicenseReportFile>$([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', '$(IntermediateOutputPath)', 'third-party-licenses.json'))</ThirdPartyLicenseReportFile>
      <!-- The app's own assets file FIRST (its resolved versions win), then the sibling projects that ship
           in the bundle, so their transitive dependency closures are licensed too. Missing files (e.g. the
           service before a solution restore) are skipped with a log message. -->
      <_LicenseAssetsFiles>$(ProjectAssetsFile);$(MSBuildProjectDirectory)\..\SubZeroFramework.Core\obj\project.assets.json;$(MSBuildProjectDirectory)\..\SubZeroFramework.GrpcContracts\obj\project.assets.json;$(MSBuildProjectDirectory)\..\SubZeroFramework.Service\obj\project.assets.json</_LicenseAssetsFiles>
    </PropertyGroup>

    <ItemGroup>
      <!-- Central pins first (whole-solution set), then this project's references (covers the Uno.Sdk
           implicit packages such as Uno.WinUI, Microsoft.WindowsAppSDK, and SkiaSharp.Views.WinUI, whose
           versions resolve from the assets file). -->
      <_LicensePackage Include="@(PackageVersion)" />
      <_LicensePackage Include="@(PackageReference)" />
      <_LicenseTemplateFile Include="$(MSBuildThisFileDirectory)LicenseTexts\*.txt" />

      <!-- Native components vendored inside the FrameworkDotnet package — not NuGet packages, so the
           extraction above cannot see them. Texts are kept verbatim in Build/StaticLicenses. -->
      <_StaticLicensePackage Include="framework-system-ffi-extensions">
        <License>MIT</License>
        <TextFile>$(MSBuildThisFileDirectory)StaticLicenses\framework-system-ffi-extensions.txt</TextFile>
      </_StaticLicensePackage>
      <_StaticLicensePackage Include="framework-system">
        <License>BSD-3-Clause</License>
        <TextFile>$(MSBuildThisFileDirectory)StaticLicenses\framework-system.txt</TextFile>
      </_StaticLicensePackage>
    </ItemGroup>

    <GenerateThirdPartyLicenseReport
        Packages="@(_LicensePackage)"
        StaticPackages="@(_StaticLicensePackage)"
        AssetsFiles="$(_LicenseAssetsFiles)"
        NuGetPackagesRoot="$(NuGetPackageRoot)"
        TemplateDirectory="$(MSBuildThisFileDirectory)LicenseTexts"
        ExcludedPackages="Grpc.Tools;Uno.Resizetizer;Microsoft.Windows.SDK.BuildTools;Microsoft.Windows.SDK.BuildTools.MSIX;Microsoft.Windows.SDK.BuildTools.WinApp;Uno.UI.DevServer;Uno.WinUI.DevServer;Uno.Settings.DevServer;Uno.Sdk.Extras;Uno.UI.HotDesign;Uno.UI.App.Mcp;Microsoft.CodeAnalysis.CSharp;NUnit;NUnit3TestAdapter;Microsoft.NET.Test.Sdk"
        OutputFile="$(ThirdPartyLicenseReportFile)" />

    <ItemGroup>
      <Content Include="$(ThirdPartyLicenseReportFile)"
               Link="Assets\ThirdPartyLicenses\third-party-licenses.json"
               CopyToOutputDirectory="PreserveNewest" />
    </ItemGroup>
  </Target>
</Project>
