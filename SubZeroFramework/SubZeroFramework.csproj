        <IconifyIcon Include="simple-icons:amd" Color="#ED1C24" />
        <IconifyIcon Include="simple-icons:nvidia" Color="#76B900" />
        <IconifyIcon Include="simple-icons:intel" Color="#0068B5" />
        <IconifyIcon Include="simple-icons:mediatek" Color="#EC9430" />
        <IconifyIcon Include="simple-icons:teamviewer" Color="#0E8EE9" />
        <IconifyIcon Include="simple-icons:framework" Color="#FFFFFF" />
        <IconifyIcon Include="simple-icons:kingstontechnology" Color="#E4172B" />
        <IconifyIcon Include="logos:microsoft-icon" />
    </ItemGroup>
