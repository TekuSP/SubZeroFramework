<Project Sdk="Uno.Sdk">
    <PropertyGroup>
        <TargetFrameworks>net10.0-desktop;net10.0-windows10.0.26100</TargetFrameworks>
		<ErrorOnDuplicatePublishOutputFiles>false</ErrorOnDuplicatePublishOutputFiles>
        <OutputType>Exe</OutputType>
        <UnoSingleProject>true</UnoSingleProject>

        <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
        <WindowsPackageType>None</WindowsPackageType>

        <!-- Display name -->
        <ApplicationTitle>SubZero Framework</ApplicationTitle>
        <!-- App Identifier -->
        <ApplicationId>tekusp.SubZeroFramework</ApplicationId>
        <!-- Versions: ApplicationDisplayVersion is intentionally NOT set here. Uno.Sdk assigns
             ApplicationDisplayVersion FROM $(Version) (Uno.SingleProject.Desktop.targets), not the other
             way round, so hardcoding a literal here silently wins over the shared <Version> in
             Directory.Build.props — invisible while both read 0.1.0, but every local build would keep
             stamping 0.1.0 after a bump. Let the SDK derive it. -->
        <ApplicationVersion>1</ApplicationVersion>
        <!-- Package Publisher -->
        <ApplicationPublisher>Richard "TekuSP" Torhan</ApplicationPublisher>
        <!-- Package Description -->
        <Description>SubZeroFrame, SubZero version for Framework laptops, powered by Uno Platform.</Description>
        <SupportsFontManifest>true</SupportsFontManifest>
        <!--
      If you encounter this error message:

        error NETSDK1148: A referenced assembly was compiled using a newer version of Microsoft.Windows.SDK.NET.dll.
        Please update to a newer .NET SDK in order to reference this assembly.

      This means that the two packages below must be aligned with the "build" version number of
      the "Microsoft.Windows.SDK.BuildTools" package above, and the "revision" version number
      must be the highest found in https://www.nuget.org/packages/Microsoft.Windows.SDK.NET.Ref.
    -->
        <!-- <WindowsSdkPackageVersion>10.0.22621.28</WindowsSdkPackageVersion> -->

        <!--
      UnoFeatures are used to quickly add and manage features enabled for your app.
      https://aka.platform.uno/singleproject-features
    -->
        <!-- MediaElement deliberately NOT enabled: nothing in the app uses MediaElement/MediaPlayerElement
             (verified by grep across all .xaml/.cs), and it pulled in VideoLAN.LibVLC.Windows — a
             Windows-native package that only ever materialized under net10.0-desktop, which is our
             LINUX-only head. That produced ~279 MB of win-x64/x86/arm64 VLC binaries in the desktop build
             tree that no shipped artifact can use, and put an LGPL-2.1 package in the license closure for
             no benefit. Uno's Skia X11 runtime pack still references LibVLCSharp unconditionally, so
             MediaPlayerElement degrades gracefully on Linux either way ("libvlc.so was not found"). -->
        <UnoFeatures>
            Lottie;
            Hosting;
            Toolkit;
            Logging;
            MVVM;
            Configuration;
            Localization;
            Navigation;
            ThemeService;
            Svg;
        </UnoFeatures>
        <Platforms>x64;ARM64</Platforms>
    </PropertyGroup>
