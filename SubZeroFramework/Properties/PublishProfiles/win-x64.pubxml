<?xml version="1.0" encoding="utf-8"?>
<!--
https://go.microsoft.com/fwlink/?LinkID=208121.
-->
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<PropertyGroup>
		<PublishProtocol>FileSystem</PublishProtocol>
		<Platform>x64</Platform>
		<RuntimeIdentifier>win-x64</RuntimeIdentifier>
		<PublishDir>bin\$(Configuration)\$(TargetFramework)\$(RuntimeIdentifier)\publish\</PublishDir>
		<SelfContained>true</SelfContained>
		<PublishSingleFile>False</PublishSingleFile>
		<PublishReadyToRun Condition="'$(Configuration)' == 'Debug'">False</PublishReadyToRun>
		<PublishReadyToRun Condition="'$(Configuration)' != 'Debug'">True</PublishReadyToRun>
		<!-- Trimming is OFF, and this is measured rather than assumed (2026-07-20). A Release publish of
		     this exact commit with PublishTrimmed=True CRASHES ON STARTUP: 0xc000027b (stowed WinRT
		     exception) inside Microsoft.UI.Xaml.dll, HRESULT 0x802B000A. The untrimmed publish of the same
		     commit launches normally. Rooting the reflection-heavy assemblies (UnitsNet, our own, the
		     navigation resolver, the toast COM activator — see SubZeroFramework.csproj) did NOT fix it:
		     the failure is in WinUI's own CsWinRT marshalling layer (35 IL2081 warnings across
		     ABI.System.Collections.Generic.*), and WindowsAppSDK is not trim-annotated. Trimming saved
		     ~148 MB but produced a binary that does not start.
		     Trim failures are also LAZY — a build can launch and still fail when a particular page or
		     conversion is first touched — so do not re-enable this without exercising every page.
		     Matches the decision in ReleasePlan.md. PublishReadyToRun below is unrelated and stays ON. -->
		<PublishTrimmed>False</PublishTrimmed>
	</PropertyGroup>
</Project>
