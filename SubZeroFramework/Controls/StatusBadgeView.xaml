<UserControl
    x:Class="SubZeroFramework.Controls.StatusBadgeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Filled circular status badge (coloured disc + centred glyph). Reused by the fan rows, the detail
          header status chip, the master footer, and the action bar "clean" state. CornerRadius tracks
          Diameter in code-behind to stay a perfect circle.  -->
    <Border
        x:Name="BadgeBorder"
        Width="{x:Bind Diameter, Mode=OneWay}"
        Height="{x:Bind Diameter, Mode=OneWay}"
        VerticalAlignment="Center"
        Background="{x:Bind Fill, Mode=OneWay}">
        <material:MaterialIcon
            Width="{x:Bind GlyphSize, Mode=OneWay}"
            Height="{x:Bind GlyphSize, Mode=OneWay}"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{x:Bind GlyphForeground, Mode=OneWay}"
            Kind="{x:Bind Glyph, Mode=OneWay}" />
    </Border>
</UserControl>
