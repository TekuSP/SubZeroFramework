<UserControl
    x:Class="SubZeroFramework.Controls.Modules.ModuleHeroView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:branding="using:SubZeroFramework.Controls.Branding"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.Modules.Models"
    mc:Ignorable="d">

    <!--  Shared selected-module hero (mockup): icon/logo + title + confidence chip + flag pills, an optional
          power-delivery pill on the right, and adaptive stat tiles below.  -->
    <Border
        x:Name="RootBorder"
        Padding="16,14"
        Background="{StaticResource CardBackgroundBrush}"
        BorderBrush="{StaticResource SurfaceOutlineBrush}"
        BorderThickness="1"
        CornerRadius="12"
        Visibility="Collapsed">
        <StackPanel Spacing="12">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="44"
                    Height="44"
                    VerticalAlignment="Center"
                    Background="{StaticResource CardMetricBackgroundBrush}"
                    CornerRadius="10">
                    <branding:BrandLogoView
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FallbackGlyph="{x:Bind Source.IconKind, Mode=OneWay}"
                        IconSize="26"
                        Vendor="{x:Bind Source.LogoVendor, Mode=OneWay}" />
                </Border>

                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind Source.Title, Mode=OneWay}" />
                        <Border
                            Height="22"
                            Padding="9,0"
                            VerticalAlignment="Center"
                            Background="#386CCB5F"
                            CornerRadius="11"
                            Visibility="{x:Bind Source.ConfidenceVisibility, Mode=OneWay}">
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource StatusSuccessBrush}"
                                Text="{x:Bind Source.ConfidenceLabel, Mode=OneWay}" />
                        </Border>
                    </StackPanel>

                    <ItemsControl ItemsSource="{x:Bind Source.Chips, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ModuleHeroChipModel">
                                <Border
                                    Height="22"
                                    Padding="8,0"
                                    Background="{StaticResource CardMetricBackgroundBrush}"
                                    CornerRadius="11">
                                    <StackPanel
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="5">
                                        <material:MaterialIcon
                                            Width="12"
                                            Height="12"
                                            VerticalAlignment="Center"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Kind="{x:Bind IconKind}" />
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontSize="11.5"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            Text="{x:Bind Text}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Spacing="4"
                    Visibility="{x:Bind Source.PdPillVisibility, Mode=OneWay}">
                    <TextBlock
                        HorizontalAlignment="Right"
                        FontSize="11"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Power delivery" />
                    <Border
                        Height="24"
                        Padding="10,0"
                        HorizontalAlignment="Right"
                        Background="#380078D7"
                        CornerRadius="12">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12.5"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource StatusInfoBrush}"
                            Text="{x:Bind Source.PdPillText, Mode=OneWay}" />
                    </Border>
                </StackPanel>
            </Grid>

            <ItemsRepeater ItemsSource="{x:Bind Source.Tiles, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        ItemsStretch="Fill"
                        MinColumnSpacing="10"
                        MinItemWidth="170"
                        MinRowSpacing="10" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:ModuleHeroTileModel">
                        <deviceCapabilitiesControls:StatTileView
                            IconKind="{x:Bind IconKind}"
                            Label="{x:Bind Label}"
                            Value="{x:Bind Value}" />
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </Border>
</UserControl>
