<UserControl
    x:Class="SubZeroFramework.Controls.Modules.ModulesFixedChassisView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.Modules.Models"
    xmlns:modules="using:SubZeroFramework.Controls.Modules"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="SlotCardTemplate" x:DataType="models:ModuleSlotCardModel">
            <modules:ModuleSlotCardView Model="{x:Bind}" Tapped="OnSlotCardTapped" />
        </DataTemplate>
    </UserControl.Resources>

    <!--  Shared chassis map for the non-modular laptops (FW12 / FW13 / FW13 Pro): expansion slots flanking the
          top-down chassis art, the selected-expansion hero, internal chips and the fixed input cover. The thin
          per-platform views set the chassis/cover art.  -->
    <StackPanel Spacing="16">
        <Grid ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ItemsControl
                Grid.Column="1"
                VerticalAlignment="Center"
                ItemTemplate="{StaticResource SlotCardTemplate}"
                ItemsSource="{x:Bind Page.LeftSlotCards, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="12" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <Image
                Grid.Column="2"
                Height="300"
                VerticalAlignment="Center"
                Source="{x:Bind ChassisSource, Mode=OneWay}"
                Stretch="Uniform" />

            <ItemsControl
                Grid.Column="3"
                VerticalAlignment="Center"
                ItemTemplate="{StaticResource SlotCardTemplate}"
                ItemsSource="{x:Bind Page.RightSlotCards, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Spacing="12" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Grid>

        <StackPanel Spacing="8" Visibility="{x:Bind Page.DetachedVisibility, Mode=OneWay}">
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="12.5"
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="Detected cards · slot not resolved" />
            <ItemsControl HorizontalAlignment="Center" ItemsSource="{x:Bind Page.DetachedChips, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ModuleInternalChipModel">
                        <Border
                            Height="30"
                            Padding="12,0"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource SurfaceOutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="15">
                            <StackPanel
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="6">
                                <material:MaterialIcon
                                    Width="14"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource StatusInfoBrush}"
                                    Kind="{x:Bind IconKind, Mode=OneWay}" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind Name, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Selected expansion module" />
        <modules:ModuleHeroView Source="{x:Bind Page.SelectedExpansionHero, Mode=OneWay}" />

        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Input cover &amp; internal modules" />

        <StackPanel HorizontalAlignment="Center" Spacing="12">
            <ItemsControl HorizontalAlignment="Center" ItemsSource="{x:Bind Page.InternalChips, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ModuleInternalChipModel">
                        <Border
                            Padding="14,10"
                            Background="{StaticResource CardBackgroundBrush}"
                            BorderBrush="{StaticResource SurfaceOutlineBrush}"
                            BorderThickness="1"
                            CornerRadius="11">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <material:MaterialIcon
                                    Width="16"
                                    Height="16"
                                    HorizontalAlignment="Center"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Kind="{x:Bind IconKind, Mode=OneWay}" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="12.5"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind Name, Mode=OneWay}" />
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="11.5"
                                    Foreground="{x:Bind StateBrush, Mode=OneWay}"
                                    Text="{x:Bind StateDisplay, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!--  The fixed keyboard-and-touchpad input cover, rendered as one unit (no input-deck slots).  -->
            <Border
                Padding="12"
                HorizontalAlignment="Center"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource SurfaceOutlineBrush}"
                BorderThickness="1"
                CornerRadius="11">
                <StackPanel Spacing="8">
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="6">
                        <material:MaterialIcon
                            Width="14"
                            Height="14"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource StatusInfoBrush}"
                            Kind="KeyboardOutline" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12.5"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Input cover" />
                    </StackPanel>
                    <Image
                        Height="180"
                        HorizontalAlignment="Center"
                        Source="{x:Bind CoverSource, Mode=OneWay}"
                        Stretch="Uniform" />
                </StackPanel>
            </Border>
        </StackPanel>

        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Selected input module" />
        <modules:ModuleHeroView Source="{x:Bind Page.InputCoverHero, Mode=OneWay}" />
    </StackPanel>
</UserControl>
