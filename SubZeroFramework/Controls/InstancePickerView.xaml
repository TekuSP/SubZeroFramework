<UserControl
    x:Class="SubZeroFramework.Controls.InstancePickerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Full-height side panel (see the full-height rule): uppercase title + selectable instance list.  -->
    <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12">
        <Grid Padding="10" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
                Margin="6,4,0,0"
                FontSize="12"
                CharacterSpacing="80"
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="{x:Bind Title, Mode=OneWay}" />
            <ListView
                x:Name="List"
                Grid.Row="1"
                ItemTemplate="{x:Bind ItemTemplate, Mode=OneWay}"
                ItemsSource="{x:Bind ItemsSource, Mode=OneWay}"
                SelectionChanged="OnListSelectionChanged"
                SelectionMode="Single" />
            <TextBlock
                x:Name="EmptyTextBlock"
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="12.5"
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="{x:Bind EmptyText, Mode=OneWay}"
                TextAlignment="Center"
                TextWrapping="WrapWholeWords"
                Visibility="Collapsed" />
        </Grid>
    </Border>
</UserControl>
