<UserControl
    x:Class="SubZeroFramework.Controls.Settings.UnitSegmentPickerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.Settings.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <!--  Pill rule: fixed height + CornerRadius = height/2 (never bare 999).  -->
        <DataTemplate x:Key="UnitSegmentTemplate" x:DataType="models:UnitPreferenceSegmentModel">
            <Button
                Height="30"
                MinWidth="52"
                Padding="14,0"
                Background="{x:Bind Background, Mode=OneWay}"
                BorderThickness="0"
                Click="OnSegmentClick"
                CornerRadius="15"
                ToolTipService.ToolTip="{x:Bind Description}">
                <TextBlock
                    FontSize="12.5"
                    FontWeight="SemiBold"
                    Foreground="{x:Bind Foreground, Mode=OneWay}"
                    Text="{x:Bind Label}" />
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <Grid MinHeight="60" ColumnSpacing="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <material:MaterialIcon
            Grid.Column="0"
            Width="18"
            Height="18"
            VerticalAlignment="Center"
            Foreground="{StaticResource StatusInfoBrush}"
            Kind="{x:Bind Item.IconKind, Mode=OneWay}" />

        <StackPanel
            Grid.Column="1"
            VerticalAlignment="Center"
            Spacing="2">
            <TextBlock
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="{x:Bind Item.DisplayName, Mode=OneWay}" />
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock
                    FontSize="12"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{x:Bind Item.SubtitlePrefix, Mode=OneWay}" />
                <TextBlock
                    FontSize="12"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource StatusInfoBrush}"
                    Text="{x:Bind Item.SampleText, Mode=OneWay}" />
            </StackPanel>
        </StackPanel>

        <!--  Segmented picker: pills over a recessed well. ItemsControl (not ItemsRepeater) so each pill's
              DataContext is the segment model — the Click handler depends on it.  -->
        <Border
            Grid.Column="2"
            Height="38"
            Padding="4,0"
            VerticalAlignment="Center"
            Background="{StaticResource SurfaceWellBrush}"
            CornerRadius="19">
            <ItemsControl
                VerticalAlignment="Center"
                ItemTemplate="{StaticResource UnitSegmentTemplate}"
                ItemsSource="{x:Bind Item.Options, Mode=OneWay}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Border>
    </Grid>
</UserControl>
