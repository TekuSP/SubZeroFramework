<UserControl
    x:Class="SubZeroFramework.Controls.Thermal.ThermalSensorTileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="190"
    d:DesignWidth="210"
    mc:Ignorable="d">

    <!--  Thermal sensor tile: a coloured top stripe + plotted checkbox (toggles the chart series), "Sensor N"
          title, platform-role location, a severity-coloured °C value + bar, and an OK/caution status. Unplotted
          tiles dim slightly. The stripe and dot use the sensor's series colour when plotted, muted otherwise.  -->
    <controls:ElevatedCard
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch"
        Background="{StaticResource CardBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="3" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Background="{x:Bind ViewModel.PlottedIndicatorBrush, Mode=OneWay}"
                CornerRadius="10,10,0,0" />

            <StackPanel
                Grid.Row="1"
                Padding="14,12,14,14"
                Opacity="{x:Bind ViewModel.CardOpacity, Mode=OneWay}"
                Spacing="8">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <CheckBox
                        Grid.Column="0"
                        MinWidth="0"
                        VerticalAlignment="Center"
                        IsChecked="{x:Bind ViewModel.IsSelected, Mode=TwoWay}" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="{x:Bind ViewModel.CardTitle, Mode=OneWay}" />
                    <Ellipse
                        Grid.Column="2"
                        Width="8"
                        Height="8"
                        VerticalAlignment="Center"
                        Fill="{x:Bind ViewModel.PlottedIndicatorBrush, Mode=OneWay}" />
                </Grid>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="4"
                    Visibility="{x:Bind ViewModel.LocationVisibility, Mode=OneWay}">
                    <material:MaterialIcon
                        Width="12"
                        Height="12"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Kind="MapMarker" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="{x:Bind ViewModel.LocationDisplay, Mode=OneWay}" />
                </StackPanel>

                <StackPanel
                    Margin="0,2,0,0"
                    Orientation="Horizontal"
                    Spacing="4">
                    <TextBlock
                        FontSize="34"
                        FontWeight="SemiBold"
                        Foreground="{x:Bind ViewModel.TemperatureBrush, Mode=OneWay}"
                        Text="{x:Bind ViewModel.TemperatureValueDisplay, Mode=OneWay}" />
                    <TextBlock
                        Margin="0,0,0,7"
                        VerticalAlignment="Bottom"
                        FontSize="13"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="{x:Bind ViewModel.TemperatureUnitSuffix, Mode=OneWay}" />
                </StackPanel>

                <ProgressBar
                    Height="6"
                    Foreground="{x:Bind ViewModel.TemperatureBrush, Mode=OneWay}"
                    Maximum="100"
                    Value="{x:Bind ViewModel.GaugeValue, Mode=OneWay}" />

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="4">
                    <material:MaterialIcon
                        Width="14"
                        Height="14"
                        VerticalAlignment="Center"
                        Foreground="{x:Bind ViewModel.StatusBrush, Mode=OneWay}"
                        Kind="{x:Bind ViewModel.StatusIconKind, Mode=OneWay}" />
                    <TextBlock
                        FontSize="13"
                        Foreground="{x:Bind ViewModel.StatusBrush, Mode=OneWay}"
                        Text="{x:Bind ViewModel.StatusShortText, Mode=OneWay}" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </controls:ElevatedCard>
</UserControl>
