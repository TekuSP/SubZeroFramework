<UserControl
    x:Class="SubZeroFramework.Controls.Thermal.ThermalStateCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="170"
    d:DesignWidth="280"
    mc:Ignorable="d">

    <controls:ElevatedCard
        Width="280"
        Height="170"
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch"
        Background="{StaticResource CardBackgroundBrush}">
        <StackPanel Padding="14" Spacing="10">
            <TextBlock
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="{x:Bind ViewModel.DisplayName, Mode=OneWay}" />

            <TextBlock
                FontSize="34"
                FontWeight="Bold"
                Foreground="{x:Bind ViewModel.TemperatureBrush, Mode=OneWay}"
                Text="{x:Bind ViewModel.TemperatureValueWithUnit, Mode=OneWay}" />

            <ProgressBar
                Height="10"
                Foreground="{x:Bind ViewModel.TemperatureBrush, Mode=OneWay}"
                Maximum="100"
                Value="{x:Bind ViewModel.GaugeValue, Mode=OneWay}" />

            <TextBlock
                Foreground="{x:Bind ViewModel.StatusBrush, Mode=OneWay}"
                Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
        </StackPanel>
    </controls:ElevatedCard>
</UserControl>
