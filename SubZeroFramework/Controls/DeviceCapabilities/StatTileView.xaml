<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.StatTileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  One stat tile (mockup sz-container spec): accent MDI icon + secondary label on top, value below.  -->
    <Border
        Padding="14,12"
        Background="{StaticResource CardBackgroundBrush}"
        BorderBrush="{StaticResource SurfaceOutlineBrush}"
        BorderThickness="1"
        CornerRadius="11">
        <StackPanel Spacing="5">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <material:MaterialIcon
                    Width="14"
                    Height="14"
                    VerticalAlignment="Center"
                    Foreground="{x:Bind IconBrush, Mode=OneWay}"
                    Kind="{x:Bind IconKind, Mode=OneWay}" />
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="12.5"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{x:Bind Label, Mode=OneWay}" />
            </StackPanel>
            <!--  Grid, not a horizontal StackPanel: the value must get a bounded width so long text wraps instead of clipping.  -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="{x:Bind ValueBrush, Mode=OneWay}"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind Value, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />
                <Border
                    Grid.Column="1"
                    Padding="7,2"
                    VerticalAlignment="Center"
                    Background="#380078D7"
                    CornerRadius="5"
                    Visibility="{x:Bind BadgeVisibility, Mode=OneWay}">
                    <TextBlock
                        FontSize="10"
                        FontWeight="Bold"
                        CharacterSpacing="30"
                        Foreground="{StaticResource StatusInfoBrush}"
                        Text="{x:Bind Badge, Mode=OneWay}" />
                </Border>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
