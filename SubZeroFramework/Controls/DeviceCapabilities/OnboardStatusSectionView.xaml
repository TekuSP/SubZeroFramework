<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.OnboardStatusSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.DeviceCapabilities.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="IsTextSelectionEnabled" Value="True" />
        </Style>

        <!--  One onboard-device tile: icon-led title, big live value, map-marker location, status chip.  -->
        <DataTemplate x:Key="DeviceCapabilitiesRuntimeStatusTileTemplate" x:DataType="models:DeviceCapabilitiesRuntimeStatusItemModel">
            <Border
                Padding="14,12"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource SurfaceOutlineBrush}"
                BorderThickness="1"
                CornerRadius="11">
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <material:MaterialIcon
                            Width="15"
                            Height="15"
                            VerticalAlignment="Center"
                            Foreground="{x:Bind ValueBrush, Mode=OneWay}"
                            Kind="{x:Bind IconKind, Mode=OneWay}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{x:Bind Name, Mode=OneWay}" />
                    </StackPanel>
                    <TextBlock
                        FontSize="24"
                        FontWeight="SemiBold"
                        Foreground="{x:Bind ValueBrush, Mode=OneWay}"
                        Text="{x:Bind ValueDisplay, Mode=OneWay}"
                        Visibility="{x:Bind ValueVisibility, Mode=OneWay}" />
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="5"
                        Visibility="{x:Bind LocationVisibility, Mode=OneWay}">
                        <material:MaterialIcon
                            Width="13"
                            Height="13"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Kind="MapMarkerOutline" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12.5"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{x:Bind Location, Mode=OneWay}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <material:MaterialIcon
                            Width="13"
                            Height="13"
                            VerticalAlignment="Center"
                            Foreground="{x:Bind StatusBrush, Mode=OneWay}"
                            Kind="{x:Bind StatusIconKind, Mode=OneWay}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12.5"
                            FontWeight="SemiBold"
                            Foreground="{x:Bind StatusBrush, Mode=OneWay}"
                            Text="{x:Bind Status, Mode=OneWay}" />
                    </StackPanel>
                    <ItemsControl ItemsSource="{x:Bind DetailLines, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:DeviceCapabilitiesTileLineModel">
                                <StackPanel
                                    Margin="0,3,0,0"
                                    Orientation="Horizontal"
                                    Spacing="5">
                                    <material:MaterialIcon
                                        Width="13"
                                        Height="13"
                                        VerticalAlignment="Center"
                                        Foreground="{x:Bind Brush}"
                                        Kind="{x:Bind IconKind}" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="12.5"
                                        Foreground="{x:Bind Brush}"
                                        Text="{x:Bind Text}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <StackPanel Spacing="16">
        <StackPanel Spacing="10">
            <TextBlock
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="Temperature sensors" />
            <ItemsRepeater ItemTemplate="{StaticResource DeviceCapabilitiesRuntimeStatusTileTemplate}" ItemsSource="{x:Bind ViewModel.TemperatureStatusItems, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        ItemsStretch="Fill"
                        MinColumnSpacing="12"
                        MinItemWidth="175"
                        MinRowSpacing="12" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </StackPanel>

        <StackPanel Spacing="10">
            <TextBlock
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="Fans" />
            <ItemsRepeater ItemTemplate="{StaticResource DeviceCapabilitiesRuntimeStatusTileTemplate}" ItemsSource="{x:Bind ViewModel.FanStatusItems, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        ItemsStretch="Fill"
                        MinColumnSpacing="12"
                        MinItemWidth="175"
                        MinRowSpacing="12" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </StackPanel>

        <StackPanel Spacing="10">
            <TextBlock
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="Batteries" />
            <ItemsRepeater ItemTemplate="{StaticResource DeviceCapabilitiesRuntimeStatusTileTemplate}" ItemsSource="{x:Bind ViewModel.BatteryStatusItems, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        ItemsStretch="Fill"
                        MinColumnSpacing="12"
                        MinItemWidth="175"
                        MinRowSpacing="12" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </StackPanel>
    </StackPanel>
</UserControl>
