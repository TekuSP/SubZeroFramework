<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.GraphicsCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Adapter detail per the mockup: plain heading + six stat tiles (Resolution carries the standard badge).  -->
    <StackPanel Spacing="12">
        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            IsTextSelectionEnabled="True"
            Text="{x:Bind ViewModel.DisplayName, Mode=OneWay}" />

        <deviceCapabilitiesControls:StatTilePanel Visibility="{x:Bind ViewModel.KnownGraphicsCardVisibility, Mode=OneWay}">
            <deviceCapabilitiesControls:StatTileView
                IconKind="Cog"
                Label="Driver version"
                Value="{x:Bind ViewModel.VideoController.DriverVersion, Mode=OneWay, FallbackValue=Unknown, TargetNullValue=Unknown}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="CalendarMonth"
                Label="Driver date"
                Value="{x:Bind ViewModel.VideoController.DisplayDriverDate, Mode=OneWay, FallbackValue=Unknown, TargetNullValue=Unknown}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Memory"
                Label="Adapter RAM"
                Value="{x:Bind ViewModel.VideoController.DisplayAdapterRam, Mode=OneWay, FallbackValue=Unknown, TargetNullValue=Unknown}" />
            <deviceCapabilitiesControls:StatTileView
                Badge="{x:Bind ViewModel.VideoController.ResolutionBadge, Mode=OneWay}"
                IconKind="Monitor"
                Label="Resolution"
                Value="{x:Bind ViewModel.VideoController.DisplayResolution, Mode=OneWay, FallbackValue=Unknown, TargetNullValue=Unknown}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="SineWave"
                Label="Refresh rate"
                Value="{x:Bind ViewModel.VideoController.DisplayRefreshRate, Mode=OneWay, FallbackValue=Unknown, TargetNullValue=Unknown}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="MonitorMultiple"
                Label="Monitors"
                Value="{x:Bind ViewModel.MonitorCountDisplay, Mode=OneWay}" />
        </deviceCapabilitiesControls:StatTilePanel>

        <Border
            Padding="14,12"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource SurfaceOutlineBrush}"
            BorderThickness="1"
            CornerRadius="11"
            Visibility="{x:Bind ViewModel.UnknownGraphicsCardVisibility, Mode=OneWay}">
            <TextBlock
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="Monitors in this group did not report a linked graphics card, so they are shown separately instead of being guessed onto one GPU."
                TextWrapping="WrapWholeWords" />
        </Border>
    </StackPanel>
</UserControl>
