<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.MonitorSummaryCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        Width="360"
        Padding="12"
        Background="{StaticResource CardMetricBackgroundBrush}"
        CornerRadius="12">
        <StackPanel Spacing="10">
            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="{x:Bind ViewModel.MonitorLabel, Mode=OneWay}" />
            <TextBlock
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="{x:Bind ViewModel.DisplayName, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />

            <Grid ColumnSpacing="8" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Padding="10" Background="{StaticResource CardBackgroundBrush}" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Status" />
                        <TextBlock
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{x:Bind ViewModel.DisplayStatus, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Padding="10" Background="{StaticResource CardBackgroundBrush}" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Type" />
                        <TextBlock
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{x:Bind ViewModel.MonitorType, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Padding="10" Background="{StaticResource CardBackgroundBrush}" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Resolution" />
                        <TextBlock
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{x:Bind ViewModel.DisplayCurrentResolution, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Padding="10" Background="{StaticResource CardBackgroundBrush}" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Refresh" />
                        <TextBlock
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{x:Bind ViewModel.DisplayCurrentRefreshRate, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.ColumnSpan="2" Padding="10" Background="{StaticResource CardBackgroundBrush}" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Manufacturer" />
                        <TextBlock
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{x:Bind ViewModel.DisplayManufacturer, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
