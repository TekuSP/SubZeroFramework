<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.CpuSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.DeviceCapabilities.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="IsTextSelectionEnabled" Value="True" />
        </Style>
    </UserControl.Resources>

    <StackPanel Spacing="12">
        <TextBlock
            Margin="15,0"
            FontSize="28"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="CPU" />
        <StackPanel Margin="10,0" Spacing="12">
            <controls:ElevatedCard
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Background="{StaticResource CardBackgroundBrush}">
                <StackPanel Padding="14" Spacing="14">
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Runtime Metrics" />
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Padding="10"
                            Background="#1AFFFFFF"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Package count" />
                                <TextBlock
                                    FontSize="26"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.CpuCount, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Padding="10"
                            Background="#1AFFFFFF"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Average clock" />
                                <TextBlock
                                    FontSize="26"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.AverageClockSpeed, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="2"
                            Padding="10"
                            Background="#1AFFFFFF"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Average max clock" />
                                <TextBlock
                                    FontSize="26"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.AverageMaxClockSpeed, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </controls:ElevatedCard>

            <controls:ElevatedCard
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Background="{StaticResource CardBackgroundBrush}">
                <StackPanel Padding="14" Spacing="10">
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Frequency History" />
                    <lvc:CartesianChart
                        Height="200"
                        AutoUpdateEnabled="True"
                        Background="Transparent"
                        LegendPosition="Hidden"
                        TooltipPosition="Hidden"
                        ZoomMode="None">
                        <lvc:CartesianChart.Series>
                            <lvc:SeriesCollection>
                                <lvc:XamlLineSeries
                                    AnimationsSpeed="0"
                                    Fill="{x:Null}"
                                    GeometryFill="{x:Null}"
                                    GeometryStroke="{x:Null}"
                                    Stroke="{lvc:SolidColorPaint Color='#FFD7D8FF',
                                                                 StrokeWidth='2'}"
                                    Values="{x:Bind ViewModel.CpuClockHistory, Mode=OneWay}" />
                            </lvc:SeriesCollection>
                        </lvc:CartesianChart.Series>
                        <lvc:CartesianChart.XAxes>
                            <lvc:AxesCollection>
                                <lvc:XamlDateTimeAxis
                                    AnimationsSpeed="0"
                                    CustomSeparators="{x:Bind ViewModel.CpuClockHistorySeparators, Mode=OneWay}"
                                    DateFormatter="{x:Bind ViewModel.CpuClockLabelsFormatter, Mode=OneWay}"
                                    Interval="0:10:0"
                                    LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                    MaxLimit="{x:Bind ViewModel.CpuClockHistoryMaxLimit, Mode=OneWay}"
                                    MinLimit="{x:Bind ViewModel.CpuClockHistoryMinLimit, Mode=OneWay}"
                                    SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                    ShowSeparatorLines="True"
                                    TextSize="8" />
                            </lvc:AxesCollection>
                        </lvc:CartesianChart.XAxes>
                        <lvc:CartesianChart.YAxes>
                            <lvc:AxesCollection>
                                <lvc:XamlAxis
                                    Padding="{lvc:Padding Value='0,0'}"
                                    LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                    SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                    ShowSeparatorLines="True"
                                    TextSize="8" />
                            </lvc:AxesCollection>
                        </lvc:CartesianChart.YAxes>
                    </lvc:CartesianChart>
                </StackPanel>
            </controls:ElevatedCard>
        </StackPanel>

        <TextBlock
            Margin="15,0"
            FontSize="22"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="CPU Packages" />
        <GridView
            Margin="10,0"
            IsItemClickEnabled="False"
            ItemsSource="{x:Bind ViewModel.CpuPackageCards, Mode=OneWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.HorizontalScrollMode="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollMode="Disabled"
            SelectionMode="None">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:DeviceCapabilitiesCpuPackageCardModel">
                    <controls:ElevatedCard
                        Width="460"
                        Margin="0,0,12,12"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel Padding="14" Spacing="10">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind Title, Mode=OneWay}"
                                    TextWrapping="WrapWholeWords" />

                                <TextBlock
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="{x:Bind PackageLabel, Mode=OneWay}" />
                            </Grid>

                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Manufacturer" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ManufacturerDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Column="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Current clock" />
                                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind CurrentClockDisplay, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Max clock" />
                                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind MaxClockDisplay, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Socket" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind SocketDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="2"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Physical cores" />
                                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind PhysicalCoreCountDisplay, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Logical processors" />
                                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind LogicalProcessorCountDisplay, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="3"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="L1 cache" />
                                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind L1CacheDisplay, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="L2 cache" />
                                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind L2CacheDisplay, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="4"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="L3 cache" />
                                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind L3CacheDisplay, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="4"
                                    Grid.Column="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Virtualization" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind VirtualizationDisplay, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </controls:ElevatedCard>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </StackPanel>
</UserControl>
