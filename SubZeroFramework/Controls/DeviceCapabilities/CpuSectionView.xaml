<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.CpuSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Mockup "simplicity" layout: plain heading + a row of stat tiles, no card chrome.  -->
    <StackPanel Spacing="10">
        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Runtime metrics" />
        <deviceCapabilitiesControls:StatTilePanel>
            <deviceCapabilitiesControls:StatTileView
                IconKind="Memory"
                Label="Package count"
                Value="{x:Bind ViewModel.CpuCountDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Chip"
                Label="Sockets"
                Value="{x:Bind ViewModel.SocketsDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Speedometer"
                Label="Average clock"
                Value="{x:Bind ViewModel.AverageClockSpeed, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="SpeedometerMedium"
                Label="Average max clock"
                Value="{x:Bind ViewModel.AverageMaxClockSpeed, Mode=OneWay}" />
        </deviceCapabilitiesControls:StatTilePanel>
    </StackPanel>
</UserControl>
