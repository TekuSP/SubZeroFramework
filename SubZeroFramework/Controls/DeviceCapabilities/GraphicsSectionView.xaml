<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.GraphicsSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Mockup "simplicity" layout: plain heading + a row of stat tiles (Primary display carries the tier badge).  -->
    <StackPanel Spacing="10">
        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Adapter summary" />
        <deviceCapabilitiesControls:StatTilePanel>
            <deviceCapabilitiesControls:StatTileView
                IconKind="ExpansionCard"
                Label="Adapters"
                Value="{x:Bind ViewModel.GraphicsAdapterCountDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="MonitorMultiple"
                Label="Monitors"
                Value="{x:Bind ViewModel.MonitorCountDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="MonitorShimmer"
                Label="Active monitors"
                Value="{x:Bind ViewModel.ActiveMonitorCountDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                Badge="{x:Bind ViewModel.PrimaryDisplayBadge, Mode=OneWay}"
                IconKind="Monitor"
                Label="Primary display"
                Value="{x:Bind ViewModel.PrimaryDisplayName, Mode=OneWay}" />
        </deviceCapabilitiesControls:StatTilePanel>
    </StackPanel>
</UserControl>
