<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.GraphicsSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.DeviceCapabilities.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="IsTextSelectionEnabled" Value="True" />
        </Style>
    </UserControl.Resources>

    <StackPanel Spacing="12">
        <TextBlock
            Margin="15,0"
            FontSize="28"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Graphics" />

        <StackPanel Margin="10,0" Spacing="12">
            <controls:ElevatedCard
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Background="{StaticResource CardBackgroundBrush}">
                <StackPanel Padding="14" Spacing="14">
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Adapter Summary" />

                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Padding="10"
                            Background="{StaticResource CardMetricBackgroundBrush}"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Adapters" />
                                <TextBlock
                                    FontSize="26"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.GraphicsAdapterCount, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Padding="10"
                            Background="{StaticResource CardMetricBackgroundBrush}"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Monitors" />
                                <TextBlock
                                    FontSize="26"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.MonitorCount, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="2"
                            Padding="10"
                            Background="{StaticResource CardMetricBackgroundBrush}"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Active monitors" />
                                <TextBlock
                                    FontSize="26"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.ActiveMonitorCount, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <GridView
                        IsItemClickEnabled="False"
                        ItemsSource="{x:Bind ViewModel.MonitorResolutionCards, Mode=OneWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollMode="Disabled"
                        SelectionMode="None">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="models:DeviceCapabilitiesMonitorResolutionCard">
                                <Border
                                    Width="220"
                                    Margin="0,0,12,12"
                                    Padding="12"
                                    Background="{StaticResource CardMetricBackgroundBrush}"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="{x:Bind Title, Mode=OneWay}" />
                                        <TextBlock
                                            FontSize="26"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ResolutionTier, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>
            </controls:ElevatedCard>
        </StackPanel>

        <TextBlock
            Margin="15,0"
            FontSize="22"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Detected Graphics Cards" />

        <GridView
            Margin="10,0"
            IsItemClickEnabled="False"
            ItemsSource="{x:Bind ViewModel.GraphicsCardGroups, Mode=OneWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.HorizontalScrollMode="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollMode="Disabled"
            SelectionMode="None">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:DeviceCapabilitiesGraphicsCardGroupModel">
                    <deviceCapabilitiesControls:GraphicsCardView
                        Margin="0,0,0,12"
                        ViewModel="{x:Bind Mode=OneWay}" />
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </StackPanel>
</UserControl>
