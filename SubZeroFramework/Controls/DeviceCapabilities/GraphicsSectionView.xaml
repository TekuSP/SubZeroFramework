<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.GraphicsSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.DeviceCapabilities.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="IsTextSelectionEnabled" Value="True" />
        </Style>

        <Style x:Key="CopyableValueTextBlockStyle" TargetType="TextBlock">
            <Setter Property="IsTextSelectionEnabled" Value="True" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>
    </UserControl.Resources>

    <StackPanel Spacing="12">
        <TextBlock
            Margin="15,0"
            FontSize="28"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Graphics" />
        <StackPanel Margin="10,0" Spacing="12">
            <controls:ElevatedCard
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                Background="{StaticResource CardBackgroundBrush}">
                <StackPanel Padding="14" Spacing="14">
                    <TextBlock
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Adapter Summary" />
                    <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border
                            Padding="10"
                            Background="#1AFFFFFF"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Adapters" />
                                <TextBlock
                                    FontSize="26"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.GraphicsAdapterCount, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="1"
                            Padding="10"
                            Background="#1AFFFFFF"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Monitors" />
                                <TextBlock
                                    FontSize="26"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.MonitorCount, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <Border
                            Grid.Column="2"
                            Padding="10"
                            Background="#1AFFFFFF"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Active monitors" />
                                <TextBlock
                                    FontSize="26"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    Text="{x:Bind ViewModel.ActiveMonitorCount, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <GridView
                        IsItemClickEnabled="False"
                        ItemsSource="{x:Bind ViewModel.MonitorResolutionCards, Mode=OneWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollMode="Disabled"
                        SelectionMode="None">
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="models:DeviceCapabilitiesMonitorResolutionCard">
                                <Border
                                    Width="220"
                                    Margin="0,0,12,12"
                                    Padding="12"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="{x:Bind Title, Mode=OneWay}" />
                                        <TextBlock
                                            FontSize="26"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ResolutionTier, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>
            </controls:ElevatedCard>
        </StackPanel>

        <TextBlock
            Margin="15,0"
            FontSize="22"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Detected Adapters" />
        <GridView
            Margin="10,0"
            IsItemClickEnabled="False"
            ItemsSource="{x:Bind ViewModel.VideoControllerCards, Mode=OneWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.HorizontalScrollMode="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollMode="Disabled"
            SelectionMode="None">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:DeviceCapabilitiesVideoControllerCardModel">
                    <controls:ElevatedCard
                        Width="420"
                        Margin="0,0,12,12"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel Padding="14" Spacing="10">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Style="{StaticResource CopyableValueTextBlockStyle}"
                                Text="{x:Bind Name, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Manufacturer" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Style="{StaticResource CopyableValueTextBlockStyle}"
                                            Text="{x:Bind Manufacturer, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Column="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Video Processor" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Style="{StaticResource CopyableValueTextBlockStyle}"
                                            Text="{x:Bind VideoProcessor, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Driver Version" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Style="{StaticResource CopyableValueTextBlockStyle}"
                                            Text="{x:Bind DriverVersion, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Driver Date" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Style="{StaticResource CopyableValueTextBlockStyle}"
                                            Text="{x:Bind DisplayDriverDate, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="2"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Video Mode" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Style="{StaticResource CopyableValueTextBlockStyle}"
                                            Text="{x:Bind VideoModeDescription, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Resolution" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Style="{StaticResource CopyableValueTextBlockStyle}"
                                            Text="{x:Bind DisplayResolution, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="3"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Refresh Rate" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Style="{StaticResource CopyableValueTextBlockStyle}"
                                            Text="{x:Bind DisplayRefreshRate, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Adapter RAM" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Style="{StaticResource CopyableValueTextBlockStyle}"
                                            Text="{x:Bind DisplayAdapterRam, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </controls:ElevatedCard>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <TextBlock
            Margin="15,0"
            FontSize="22"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Detected Monitors" />
        <GridView
            Margin="10,0"
            IsItemClickEnabled="False"
            ItemsSource="{x:Bind ViewModel.MonitorCards, Mode=OneWay}"
            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
            ScrollViewer.HorizontalScrollMode="Disabled"
            ScrollViewer.VerticalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollMode="Disabled"
            SelectionMode="None">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:DeviceCapabilitiesMonitorCardModel">
                    <controls:ElevatedCard
                        Width="420"
                        Margin="0,0,12,12"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="{StaticResource CardBackgroundBrush}">
                        <StackPanel Padding="14" Spacing="10">
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{x:Bind DisplayName, FallbackValue=Unknown monitor, TargetNullValue=Unknown monitor}"
                                TextWrapping="WrapWholeWords" />
                            <Grid ColumnSpacing="8" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Status" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind DisplayStatus, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Column="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Monitor Type" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind MonitorType, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Manufacturer" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind DisplayManufacturer, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Logical Density" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind DisplayLogicalDensity, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="2"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Product Code" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ProductCodeId, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Serial ID" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind SerialNumberId, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="3"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Vendor Code" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind MonitorManufacturer, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="3"
                                    Grid.Column="1"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Manufactured" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind DisplayManufactured, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Grid.Row="4"
                                    Grid.ColumnSpan="2"
                                    Padding="10"
                                    Background="#1AFFFFFF"
                                    CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Description" />
                                        <TextBlock
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind Description, FallbackValue=Unknown, TargetNullValue=Unknown}"
                                            TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </controls:ElevatedCard>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </StackPanel>
</UserControl>
