<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.StorageSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Mockup "simplicity" layout: plain headings + stat tiles + the storage usage bar, no card chrome.  -->
    <StackPanel Spacing="10">
        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Drive summary" />
        <deviceCapabilitiesControls:StatTilePanel>
            <deviceCapabilitiesControls:StatTileView
                IconKind="Harddisk"
                Label="Drives"
                Value="{x:Bind ViewModel.StorageDriveCountDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Database"
                Label="Total capacity"
                Value="{x:Bind ViewModel.TotalStorageCapacity, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Database"
                Label="Used"
                Value="{x:Bind ViewModel.TotalStorageUsedSpace, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="DatabaseCheck"
                Label="Free"
                Value="{x:Bind ViewModel.TotalStorageFreeSpace, Mode=OneWay}"
                ValueBrush="{x:Bind ViewModel.TotalStorageFreeBrush, Mode=OneWay}" />
        </deviceCapabilitiesControls:StatTilePanel>

        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Storage usage" />
        <Border
            Padding="14,12"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource SurfaceOutlineBrush}"
            BorderThickness="1"
            CornerRadius="11">
            <StackPanel Spacing="8">
                <ProgressBar
                    MinHeight="6"
                    Foreground="{x:Bind ViewModel.TotalStorageUsageBarBrush, Mode=OneWay}"
                    Maximum="100"
                    Value="{x:Bind ViewModel.TotalStorageUsagePercent, Mode=OneWay}" />
                <TextBlock
                    FontSize="12.5"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind ViewModel.TotalStorageUsageSummary, Mode=OneWay}" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
