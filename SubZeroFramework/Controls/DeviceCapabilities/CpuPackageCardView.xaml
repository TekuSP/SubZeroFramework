<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.CpuPackageCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.DeviceCapabilities.Models"
    mc:Ignorable="d">

    <!--  Mockup "simplicity" layout: Package detail tiles + per-core grid, no card chrome or trend charts.  -->
    <StackPanel Spacing="12">
        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Package detail" />

        <deviceCapabilitiesControls:StatTilePanel>
            <deviceCapabilitiesControls:StatTileView
                IconKind="Speedometer"
                Label="Current clock"
                Value="{x:Bind ViewModel.CurrentClockDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="SpeedometerMedium"
                Label="Max clock"
                Value="{x:Bind ViewModel.MaxClockDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Memory"
                Label="Socket"
                Value="{x:Bind ViewModel.SocketDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Chip"
                Label="Physical cores"
                Value="{x:Bind ViewModel.PhysicalCoreCountDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Sitemap"
                Label="Logical processors"
                Value="{x:Bind ViewModel.LogicalProcessorCountDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Memory"
                Label="L1 cache"
                Value="{x:Bind ViewModel.L1CacheDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Memory"
                Label="L2 cache"
                Value="{x:Bind ViewModel.L2CacheDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Memory"
                Label="L3 cache"
                Value="{x:Bind ViewModel.L3CacheDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="ShieldCheck"
                Label="Virtualization"
                Value="{x:Bind ViewModel.VirtualizationDisplay, Mode=OneWay}"
                ValueBrush="{x:Bind ViewModel.VirtualizationBrush, Mode=OneWay}" />
        </deviceCapabilitiesControls:StatTilePanel>

        <StackPanel
            Spacing="10"
            Visibility="{x:Bind ViewModel.CpuCoreDetailsVisibility, Mode=OneWay}">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock
                    VerticalAlignment="Bottom"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="Per-core detail" />
                <TextBlock
                    VerticalAlignment="Bottom"
                    FontSize="12.5"
                    Foreground="{StaticResource TextSecondaryBrush}">
                    <Run Text="{x:Bind ViewModel.CpuCoreCountDisplay, Mode=OneWay}" />
                    <Run Text="logical" />
                </TextBlock>
            </StackPanel>

            <GridView
                IsItemClickEnabled="False"
                ItemsSource="{x:Bind ViewModel.CpuCoreItems, Mode=OneWay}"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.HorizontalScrollMode="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollMode="Disabled"
                SelectionMode="None">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:DeviceCapabilitiesCpuCoreItemModel">
                        <deviceCapabilitiesControls:CpuCoreUsageCardView ViewModel="{x:Bind Mode=OneWay}" />
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </StackPanel>
    </StackPanel>
</UserControl>
