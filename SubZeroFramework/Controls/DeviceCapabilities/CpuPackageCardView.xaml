<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.CpuPackageCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:SubZeroFramework.Controls.DeviceCapabilities.Models"
    mc:Ignorable="d">

    <Border VerticalAlignment="Stretch">
    <controls:ElevatedCard
        Margin="0,0,0,12"
        HorizontalAlignment="Stretch"
        HorizontalContentAlignment="Stretch"
        VerticalContentAlignment="Stretch"
        Background="{StaticResource CardBackgroundBrush}">
        <StackPanel Padding="14" Spacing="10">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                    TextWrapping="WrapWholeWords" />

                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    Text="{x:Bind ViewModel.PackageLabel, Mode=OneWay}" />
            </Grid>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Padding="12"
                    Background="#1AFFFFFF"
                    CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="CPU Usage avg" />
                        <TextBlock
                            Grid.Row="1"
                            Margin="0,4,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{x:Bind ViewModel.RecentTelemetryHistoryWindowDisplay, Mode=OneWay}" />
                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Margin="0,0,12,0"
                                VerticalAlignment="Top"
                                FontSize="42"
                                FontWeight="Bold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{x:Bind ViewModel.AverageCpuUsageDisplay, Mode=OneWay}" />

                            <lvc:CartesianChart
                                Grid.Column="1"
                                Height="140"
                                AutoUpdateEnabled="True"
                                Background="Transparent"
                                LegendPosition="Hidden"
                                TooltipPosition="Hidden"
                                ZoomMode="None">
                                <lvc:CartesianChart.Series>
                                    <lvc:SeriesCollection>
                                        <lvc:XamlLineSeries
                                            AnimationsSpeed="0"
                                            Fill="{x:Null}"
                                            GeometryFill="{x:Null}"
                                            GeometryStroke="{x:Null}"
                                            Stroke="{lvc:SolidColorPaint Color='#FF8AB7E8', StrokeWidth='2'}"
                                            Values="{x:Bind ViewModel.CpuUsageHistory, Mode=OneWay}" />
                                    </lvc:SeriesCollection>
                                </lvc:CartesianChart.Series>
                                <lvc:CartesianChart.XAxes>
                                    <lvc:AxesCollection>
                                        <lvc:XamlDateTimeAxis
                                            AnimationsSpeed="0"
                                            CustomSeparators="{x:Bind ViewModel.CpuUsageHistorySeparators, Mode=OneWay}"
                                            DateFormatter="{x:Bind ViewModel.LabelsFormatter, Mode=OneWay}"
                                            Interval="0:0:5"
                                            LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                            MaxLimit="{x:Bind ViewModel.CpuUsageHistoryMaxLimit, Mode=OneWay}"
                                            MinLimit="{x:Bind ViewModel.CpuUsageHistoryMinLimit, Mode=OneWay}"
                                            SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                            ShowSeparatorLines="True"
                                            TextSize="8" />
                                    </lvc:AxesCollection>
                                </lvc:CartesianChart.XAxes>
                                <lvc:CartesianChart.YAxes>
                                    <lvc:AxesCollection>
                                        <lvc:XamlAxis
                                            AnimationsSpeed="0"
                                            LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                            MaxLimit="100"
                                            MinLimit="0"
                                            SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                            ShowSeparatorLines="True"
                                            TextSize="8" />
                                    </lvc:AxesCollection>
                                </lvc:CartesianChart.YAxes>
                            </lvc:CartesianChart>
                        </Grid>
                    </Grid>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="12"
                    Background="#1AFFFFFF"
                    CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="Frequency" />

                        <TextBlock
                            Grid.Row="1"
                            Margin="0,4,0,0"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{x:Bind ViewModel.CpuClockHistoryWindowDisplay, Mode=OneWay}" />

                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Margin="0,0,12,0"
                                VerticalAlignment="Top"
                                FontSize="42"
                                FontWeight="Bold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{x:Bind ViewModel.CurrentClockDisplay, Mode=OneWay}" />

                        <lvc:CartesianChart
                            Grid.Column="1"
                            Height="140"
                            AutoUpdateEnabled="True"
                            Background="Transparent"
                            LegendPosition="Hidden"
                            TooltipPosition="Hidden"
                            ZoomMode="None">
                            <lvc:CartesianChart.Series>
                                <lvc:SeriesCollection>
                                    <lvc:XamlLineSeries
                                        AnimationsSpeed="0"
                                        Fill="{x:Null}"
                                        GeometryFill="{x:Null}"
                                        GeometryStroke="{x:Null}"
                                        Stroke="{lvc:SolidColorPaint Color='#FFD7D8FF', StrokeWidth='2'}"
                                        Values="{x:Bind ViewModel.CpuClockHistory, Mode=OneWay}" />
                                </lvc:SeriesCollection>
                            </lvc:CartesianChart.Series>
                            <lvc:CartesianChart.XAxes>
                                <lvc:AxesCollection>
                                    <lvc:XamlDateTimeAxis
                                        AnimationsSpeed="0"
                                        CustomSeparators="{x:Bind ViewModel.CpuClockHistorySeparators, Mode=OneWay}"
                                        DateFormatter="{x:Bind ViewModel.LabelsFormatter, Mode=OneWay}"
                                        Interval="0:10:0"
                                        LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                        MaxLimit="{x:Bind ViewModel.CpuClockHistoryMaxLimit, Mode=OneWay}"
                                        MinLimit="{x:Bind ViewModel.CpuClockHistoryMinLimit, Mode=OneWay}"
                                        SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                        ShowSeparatorLines="True"
                                        TextSize="8" />
                                </lvc:AxesCollection>
                            </lvc:CartesianChart.XAxes>
                            <lvc:CartesianChart.YAxes>
                                <lvc:AxesCollection>
                                    <lvc:XamlAxis
                                        Padding="{lvc:Padding Value='0,0'}"
                                        LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                        SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                        ShowSeparatorLines="True"
                                        TextSize="8" />
                                </lvc:AxesCollection>
                            </lvc:CartesianChart.YAxes>
                        </lvc:CartesianChart>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid ColumnSpacing="8" RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Padding="10"
                    Background="#1AFFFFFF"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Manufacturer" />
                        <TextBlock
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{x:Bind ViewModel.ManufacturerDisplay, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Column="1"
                    Padding="10"
                    Background="#1AFFFFFF"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Current clock" />
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind ViewModel.CurrentClockDisplay, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Padding="10"
                    Background="#1AFFFFFF"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Max clock" />
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind ViewModel.MaxClockDisplay, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Grid.Column="1"
                    Padding="10"
                    Background="#1AFFFFFF"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Socket" />
                        <TextBlock
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{x:Bind ViewModel.SocketDisplay, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="2"
                    Padding="10"
                    Background="#1AFFFFFF"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Physical cores" />
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind ViewModel.PhysicalCoreCountDisplay, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="2"
                    Grid.Column="1"
                    Padding="10"
                    Background="#1AFFFFFF"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Logical processors" />
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind ViewModel.LogicalProcessorCountDisplay, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="3"
                    Padding="10"
                    Background="#1AFFFFFF"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="L1 cache" />
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind ViewModel.L1CacheDisplay, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="3"
                    Grid.Column="1"
                    Padding="10"
                    Background="#1AFFFFFF"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="L2 cache" />
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind ViewModel.L2CacheDisplay, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="4"
                    Padding="10"
                    Background="#1AFFFFFF"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="L3 cache" />
                        <TextBlock Foreground="{StaticResource TextPrimaryBrush}" Text="{x:Bind ViewModel.L3CacheDisplay, Mode=OneWay}" />
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="4"
                    Grid.Column="1"
                    Padding="10"
                    Background="#1AFFFFFF"
                    CornerRadius="10">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Virtualization" />
                        <TextBlock
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{x:Bind ViewModel.VirtualizationDisplay, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>
            </Grid>

            <StackPanel
                Visibility="{x:Bind ViewModel.CpuCoreDetailsVisibility, Mode=OneWay}"
                Spacing="8">
                <TextBlock
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}">
                    <Run Text="Per-core detail (" />
                    <Run Text="{x:Bind ViewModel.CpuCoreCountDisplay, Mode=OneWay}" />
                    <Run Text=")" />
                </TextBlock>

                <GridView
                    IsItemClickEnabled="False"
                    ItemsSource="{x:Bind ViewModel.CpuCoreItems, Mode=OneWay}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.HorizontalScrollMode="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollMode="Disabled"
                    SelectionMode="None">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:DeviceCapabilitiesCpuCoreItemModel">
                            <deviceCapabilitiesControls:CpuCoreUsageCardView ViewModel="{x:Bind Mode=OneWay}" />
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>
        </StackPanel>
    </controls:ElevatedCard>
</Border>
</UserControl>
