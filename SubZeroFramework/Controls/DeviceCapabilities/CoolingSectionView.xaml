<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.CoolingSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:fanControls="using:SubZeroFramework.Controls.Fans"
    xmlns:fanModels="using:SubZeroFramework.Controls.Fans.Models"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="IsTextSelectionEnabled" Value="True" />
        </Style>

        <DataTemplate x:Key="FrameworkLaptop12FanAdvancedInfoTemplate" x:DataType="fanModels:FrameworkLaptop12FanAdvancedInfoCardModel">
            <deviceCapabilitiesControls:StatTilePanel>
                <deviceCapabilitiesControls:StatTileView
                    IconKind="Cpu64Bit"
                    Label="Processor support"
                    Value="{x:Bind ProcessorSupport, Mode=OneWay}" />
                <deviceCapabilitiesControls:StatTileView
                    IconKind="Thermometer"
                    Label="Thermal capacity"
                    Value="{x:Bind ThermalCapacity, Mode=OneWay}" />
                <deviceCapabilitiesControls:StatTileView
                    IconKind="Pipe"
                    Label="Heat pipes"
                    Value="{x:Bind HeatPipeConfiguration, Mode=OneWay}" />
                <deviceCapabilitiesControls:StatTileView
                    IconKind="Ruler"
                    Label="Fan dimensions"
                    Value="{x:Bind FanDimensionsDisplay, Mode=OneWay}" />
                <deviceCapabilitiesControls:StatTileView
                    IconKind="WaterOutline"
                    Label="Thermal interface"
                    Value="{x:Bind ThermalInterfaceMaterial, Mode=OneWay}" />
                <deviceCapabilitiesControls:StatTileView
                    IconKind="TuneVertical"
                    Label="Firmware range"
                    Value="{x:Bind FirmwareRangeDisplay, Mode=OneWay}" />
                <deviceCapabilitiesControls:StatTileView
                    IconKind="Gauge"
                    Label="Physical limit"
                    Value="{x:Bind MaximumPhysicalLimitDisplay, Mode=OneWay}" />
            </deviceCapabilitiesControls:StatTilePanel>
        </DataTemplate>

        <DataTemplate x:Key="FrameworkLaptop13FanAdvancedInfoTemplate" x:DataType="fanModels:FrameworkLaptop13FanAdvancedInfoCardModel">
            <deviceCapabilitiesControls:StatTilePanel MaxColumns="3">
                <deviceCapabilitiesControls:StatTileView
                    IconKind="Cpu64Bit"
                    Label="Processor support"
                    Value="{x:Bind ProcessorSupport, Mode=OneWay}" />
                <deviceCapabilitiesControls:StatTileView
                    IconKind="Cube"
                    Label="Chassis material"
                    Value="{x:Bind ChassisMaterial, Mode=OneWay}" />
                <deviceCapabilitiesControls:StatTileView
                    IconKind="FanSpeed1"
                    Label="Idle speed (firmware)"
                    Value="{x:Bind ApproximateFirmwareIdleSpeedDisplay, Mode=OneWay}" />
                <deviceCapabilitiesControls:StatTileView
                    IconKind="FanSpeed2"
                    Label="Idle speed (tuned)"
                    Value="{x:Bind ApproximateUserTunedIdleSpeedDisplay, Mode=OneWay}" />
                <deviceCapabilitiesControls:StatTileView
                    IconKind="Speedometer"
                    Label="Firmware limit"
                    Value="{x:Bind MaximumFirmwareLimitDisplay, Mode=OneWay}" />
                <deviceCapabilitiesControls:StatTileView
                    IconKind="Gauge"
                    Label="Physical limit"
                    Value="{x:Bind ApproximatePhysicalMaximumDisplay, Mode=OneWay}" />
            </deviceCapabilitiesControls:StatTilePanel>
        </DataTemplate>

        <DataTemplate x:Key="FrameworkLaptop16FanAdvancedInfoTemplate" x:DataType="fanModels:FrameworkLaptop16FanAdvancedInfoCardModel">
            <StackPanel Spacing="10">
                <deviceCapabilitiesControls:StatTilePanel>
                    <deviceCapabilitiesControls:StatTileView
                        IconKind="Cpu64Bit"
                        Label="Processor support"
                        Value="{x:Bind ProcessorSupport, Mode=OneWay}" />
                    <deviceCapabilitiesControls:StatTileView
                        IconKind="WaterOutline"
                        Label="Primary CPU TIM"
                        Value="{x:Bind PrimaryCpuThermalInterfaceMaterial, Mode=OneWay}" />
                    <deviceCapabilitiesControls:StatTileView
                        IconKind="Flash"
                        Label="Expansion bay power"
                        Value="{x:Bind ExpansionBayPowerLimitDisplay, Mode=OneWay}" />
                    <deviceCapabilitiesControls:StatTileView
                        IconKind="Speedometer"
                        Label="Firmware limit"
                        Value="{x:Bind StandardFirmwareMaximumDisplay, Mode=OneWay}" />
                    <deviceCapabilitiesControls:StatTileView
                        IconKind="Thermometer"
                        Label="Thermal stress max"
                        Value="{x:Bind ApproximateThermalStressMaximumDisplay, Mode=OneWay}"
                        ValueBrush="{StaticResource StatusWarningBrush}" />
                </deviceCapabilitiesControls:StatTilePanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="Fan modules" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="same 75 mm footprint, different thickness" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Border
                        Width="215"
                        Padding="14,12"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource SurfaceOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="11">
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Shell fan" />
                            <TextBlock
                                FontSize="12.5"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="{x:Bind ShellFanDimensionsDisplay, Mode=OneWay}" />
                            <material:MaterialIcon
                                Width="42"
                                Height="42"
                                Margin="0,16"
                                HorizontalAlignment="Center"
                                Foreground="{StaticResource StatusInfoBrush}"
                                Kind="Fan" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="12.5"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{x:Bind ShellFanThicknessDisplay, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                    <Border
                        Width="215"
                        Padding="14,12"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource SurfaceOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="11">
                        <StackPanel Spacing="3">
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="Graphics fan" />
                            <TextBlock
                                FontSize="12.5"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="{x:Bind GraphicsFanDimensionsDisplay, Mode=OneWay}" />
                            <material:MaterialIcon
                                Width="42"
                                Height="42"
                                Margin="0,16"
                                HorizontalAlignment="Center"
                                Foreground="{StaticResource StatusInfoBrush}"
                                Kind="Fan" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="12.5"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{x:Bind GraphicsFanThicknessDisplay, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="FrameworkDesktopFanAdvancedInfoTemplate" x:DataType="fanModels:FrameworkDesktopFanAdvancedInfoCardModel">
            <StackPanel Spacing="10">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <deviceCapabilitiesControls:StatTileView
                        IconKind="DesktopTower"
                        Label="Platform"
                        Value="{x:Bind Platform, Mode=OneWay}" />

                    <Border
                        Grid.Column="1"
                        Padding="14,12"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource SurfaceOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="11">
                        <StackPanel Spacing="5">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <material:MaterialIcon
                                    Width="14"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource StatusInfoBrush}"
                                    Kind="Fan" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="Supported fans" />
                            </StackPanel>
                            <ItemsRepeater ItemsSource="{x:Bind SupportedFanOptions, Mode=OneWay}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="fanModels:FrameworkDesktopFanOptionModel">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            Text="{x:Bind ModelName, Mode=OneWay}"
                                            TextWrapping="WrapWholeWords" />
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="14,12"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource SurfaceOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="11">
                        <StackPanel Spacing="5">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <material:MaterialIcon
                                    Width="14"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource StatusInfoBrush}"
                                    Kind="Ruler" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="Fan dimensions" />
                            </StackPanel>
                            <ItemsRepeater ItemsSource="{x:Bind SupportedFanOptions, Mode=OneWay}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="fanModels:FrameworkDesktopFanOptionModel">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontSize="14"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            TextWrapping="WrapWholeWords">
                                            <Run FontWeight="SemiBold" Text="{x:Bind ModelName, Mode=OneWay}" />
                                            <Run Text=": " />
                                            <Run Text="{x:Bind FanDimensionsDisplay, Mode=OneWay}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Padding="14,12"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource SurfaceOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="11">
                        <StackPanel Spacing="5">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <material:MaterialIcon
                                    Width="14"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource StatusInfoBrush}"
                                    Kind="PowerPlug" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="Connectors" />
                            </StackPanel>
                            <ItemsRepeater ItemsSource="{x:Bind SupportedFanOptions, Mode=OneWay}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="fanModels:FrameworkDesktopFanOptionModel">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontSize="14"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            TextWrapping="WrapWholeWords">
                                            <Run FontWeight="SemiBold" Text="{x:Bind ModelName, Mode=OneWay}" />
                                            <Run Text=": " />
                                            <Run Text="{x:Bind ConnectorType, Mode=OneWay}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="14,12"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource SurfaceOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="11">
                        <StackPanel Spacing="5">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <material:MaterialIcon
                                    Width="14"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource StatusInfoBrush}"
                                    Kind="WeatherWindy" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="Max airflow" />
                            </StackPanel>
                            <ItemsRepeater ItemsSource="{x:Bind SupportedFanOptions, Mode=OneWay}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="fanModels:FrameworkDesktopFanOptionModel">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontSize="14"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            TextWrapping="WrapWholeWords">
                                            <Run FontWeight="SemiBold" Text="{x:Bind ModelName, Mode=OneWay}" />
                                            <Run Text=": " />
                                            <Run Text="{x:Bind MaximumAirflowDisplay, Mode=OneWay}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="14,12"
                        Background="{StaticResource CardBackgroundBrush}"
                        BorderBrush="{StaticResource SurfaceOutlineBrush}"
                        BorderThickness="1"
                        CornerRadius="11">
                        <StackPanel Spacing="5">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <material:MaterialIcon
                                    Width="14"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource StatusInfoBrush}"
                                    Kind="VolumeHigh" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="12.5"
                                    Foreground="{StaticResource TextSecondaryBrush}"
                                    Text="Noise" />
                            </StackPanel>
                            <ItemsRepeater ItemsSource="{x:Bind SupportedFanOptions, Mode=OneWay}">
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="fanModels:FrameworkDesktopFanOptionModel">
                                        <TextBlock
                                            Margin="0,0,0,4"
                                            FontSize="14"
                                            Foreground="{StaticResource TextPrimaryBrush}"
                                            TextWrapping="WrapWholeWords">
                                            <Run FontWeight="SemiBold" Text="{x:Bind ModelName, Mode=OneWay}" />
                                            <Run Text=": " />
                                            <Run Text="{x:Bind AcousticNoiseDisplay, Mode=OneWay}" />
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border
                    Padding="14,12"
                    Background="{StaticResource CardBackgroundBrush}"
                    BorderBrush="{StaticResource SurfaceOutlineBrush}"
                    BorderThickness="1"
                    CornerRadius="11">
                    <StackPanel Spacing="5">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <material:MaterialIcon
                                Width="14"
                                Height="14"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource StatusInfoBrush}"
                                Kind="Gauge" />
                            <TextBlock
                                VerticalAlignment="Center"
                                FontSize="12.5"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Maximum fan speed" />
                        </StackPanel>
                        <ItemsRepeater ItemsSource="{x:Bind SupportedFanOptions, Mode=OneWay}">
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="fanModels:FrameworkDesktopFanOptionModel">
                                    <TextBlock
                                        Margin="0,0,0,4"
                                        FontSize="14"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        TextWrapping="WrapWholeWords">
                                        <Run FontWeight="SemiBold" Text="{x:Bind ModelName, Mode=OneWay}" />
                                        <Run Text=": " />
                                        <Run Text="{x:Bind MaximumFanSpeedDisplay, Mode=OneWay}" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>

        <fanControls:FanAdvancedInfoCardTemplateSelector
            x:Key="FanAdvancedInfoCardTemplateSelector"
            FrameworkDesktopTemplate="{StaticResource FrameworkDesktopFanAdvancedInfoTemplate}"
            FrameworkLaptop12Template="{StaticResource FrameworkLaptop12FanAdvancedInfoTemplate}"
            FrameworkLaptop13Template="{StaticResource FrameworkLaptop13FanAdvancedInfoTemplate}"
            FrameworkLaptop16Template="{StaticResource FrameworkLaptop16FanAdvancedInfoTemplate}" />
    </UserControl.Resources>

    <!--  Mockup "simplicity" layout: plain heading + per-platform stat tiles, no card chrome.  -->
    <StackPanel Spacing="10" Visibility="{x:Bind ViewModel.CoolingHardwareVisibility, Mode=OneWay}">
        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Cooling hardware &amp; firmware" />
        <ContentControl
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            Content="{x:Bind ViewModel.FanAdvancedInfo, Mode=OneWay}"
            ContentTemplateSelector="{StaticResource FanAdvancedInfoCardTemplateSelector}"
            IsTabStop="False" />
    </StackPanel>
</UserControl>
