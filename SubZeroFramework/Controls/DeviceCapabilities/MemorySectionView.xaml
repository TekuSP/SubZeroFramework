<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.MemorySectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Mockup "simplicity" layout: plain headings + stat tiles + the RAM usage bar, no card chrome.  -->
    <StackPanel Spacing="10">
        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Capacity &amp; runtime" />
        <deviceCapabilitiesControls:StatTilePanel MaxColumns="6">
            <deviceCapabilitiesControls:StatTileView
                IconKind="Memory"
                Label="Memory modules"
                Value="{x:Bind ViewModel.MemoryModuleCountDisplay, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Database"
                Label="Total capacity"
                Value="{x:Bind ViewModel.MemoryTotalCapacity, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Database"
                Label="Physical total"
                Value="{x:Bind ViewModel.TotalPhysicalMemory, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="DatabaseCheck"
                Label="Physical available"
                Value="{x:Bind ViewModel.AvailablePhysicalMemory, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="SwapHorizontal"
                Label="Swap / page total"
                Value="{x:Bind ViewModel.TotalPageFileMemory, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="SwapHorizontal"
                Label="Swap / page free"
                Value="{x:Bind ViewModel.AvailablePageFileMemory, Mode=OneWay}" />
        </deviceCapabilitiesControls:StatTilePanel>

        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="RAM usage" />
        <Border
            Padding="14,12"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource SurfaceOutlineBrush}"
            BorderThickness="1"
            CornerRadius="11">
            <StackPanel Spacing="8">
                <ProgressBar
                    MinHeight="6"
                    Foreground="{x:Bind ViewModel.PhysicalMemoryUsageBarBrush, Mode=OneWay}"
                    Maximum="100"
                    Value="{x:Bind ViewModel.PhysicalMemoryUsagePercent, Mode=OneWay}" />
                <TextBlock
                    FontSize="12.5"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    IsTextSelectionEnabled="True"
                    Text="{x:Bind ViewModel.PhysicalMemoryUsageDisplay, Mode=OneWay}" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
