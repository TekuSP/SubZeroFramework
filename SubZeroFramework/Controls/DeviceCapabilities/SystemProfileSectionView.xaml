<UserControl
    x:Class="SubZeroFramework.Controls.DeviceCapabilities.SystemProfileSectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:deviceCapabilitiesControls="using:SubZeroFramework.Controls.DeviceCapabilities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--  Mockup "simplicity" layout: plain heading + identity stat tiles, no card chrome.  -->
    <StackPanel Spacing="10">
        <TextBlock
            FontSize="16"
            FontWeight="SemiBold"
            Foreground="{StaticResource TextPrimaryBrush}"
            Text="Device identity" />
        <!--  4 columns max (not the mockup's 6): real values run longer than the mock data, so wider tiles that
              wrap onto extra rows on narrow panes.  -->
        <deviceCapabilitiesControls:StatTilePanel>
            <deviceCapabilitiesControls:StatTileView
                IconKind="MicrosoftWindows"
                Label="Operating system"
                Value="{x:Bind ViewModel.SystemProfileOs, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Factory"
                Label="Vendor"
                Value="{x:Bind ViewModel.SystemProfileVendor, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Laptop"
                Label="Model"
                Value="{x:Bind ViewModel.SystemProfileModel, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Tag"
                Label="OS version"
                Value="{x:Bind ViewModel.SystemProfileOsVersion, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="PackageVariant"
                Label="Product / SKU"
                Value="{x:Bind ViewModel.SystemProfileProductName, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Tag"
                Label="System revision"
                Value="{x:Bind ViewModel.SystemProfileSystemVersion, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Chip"
                Label="EC build"
                Value="{x:Bind ViewModel.SystemProfileEcBuildInfo, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="Chip"
                Label="BIOS version"
                Value="{x:Bind ViewModel.SystemProfileBiosVersion, Mode=OneWay}" />
            <deviceCapabilitiesControls:StatTileView
                IconKind="CalendarMonth"
                Label="BIOS release date"
                Value="{x:Bind ViewModel.SystemProfileBiosReleaseDate, Mode=OneWay}" />
        </deviceCapabilitiesControls:StatTilePanel>
    </StackPanel>
</UserControl>
