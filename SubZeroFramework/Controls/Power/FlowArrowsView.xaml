<UserControl
    x:Class="SubZeroFramework.Controls.Power.FlowArrowsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="OnLoaded"
    Unloaded="OnUnloaded"
    mc:Ignorable="d">

    <!--  Three chevrons with a bright pulse that travels left→right, conveying flow direction (adapter → system
          → battery). The pulse loops while loaded.  -->
    <UserControl.Resources>
        <Storyboard x:Name="FlowStoryboard" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Chevron0" Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.3" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="0.3" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="0.3" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Chevron1" Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.3" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.3" Value="0.3" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.5" Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.8" Value="0.3" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="0.3" />
            </DoubleAnimationUsingKeyFrames>
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Chevron2" Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0.3" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.6" Value="0.3" />
                <LinearDoubleKeyFrame KeyTime="0:0:0.8" Value="1" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.1" Value="0.3" />
                <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="0.3" />
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal" Spacing="-3">
        <material:MaterialIcon
            x:Name="Chevron0"
            Width="18"
            Height="18"
            VerticalAlignment="Center"
            Foreground="{x:Bind Accent, Mode=OneWay}"
            Kind="ChevronRight"
            Opacity="0.3" />
        <material:MaterialIcon
            x:Name="Chevron1"
            Width="18"
            Height="18"
            VerticalAlignment="Center"
            Foreground="{x:Bind Accent, Mode=OneWay}"
            Kind="ChevronRight"
            Opacity="0.3" />
        <material:MaterialIcon
            x:Name="Chevron2"
            Width="18"
            Height="18"
            VerticalAlignment="Center"
            Foreground="{x:Bind Accent, Mode=OneWay}"
            Kind="ChevronRight"
            Opacity="0.3" />
    </StackPanel>
</UserControl>
