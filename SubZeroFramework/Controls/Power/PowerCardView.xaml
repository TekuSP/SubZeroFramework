<UserControl
    x:Class="SubZeroFramework.Controls.Power.PowerCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="360"
    d:DesignWidth="1200"
    mc:Ignorable="d">

    <Border VerticalAlignment="Stretch">
        <controls:ElevatedCard
            MinHeight="360"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            Background="{StaticResource CardBackgroundBrush}">
            <Grid
                Margin="14"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    FontSize="30"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextPrimaryBrush}"
                    Text="{x:Bind ViewModel.BatteryTitle, Mode=OneWay}" />

                <StackPanel
                    Grid.Row="1"
                    Margin="0,12,0,0"
                    Spacing="8">
                    <ProgressBar
                        Height="10"
                        Foreground="{x:Bind ViewModel.StateBrush, Mode=OneWay}"
                        Maximum="100"
                        Value="{x:Bind ViewModel.ChargePercentValue, Mode=OneWay}" />
                    <TextBlock Foreground="{x:Bind ViewModel.StateBrush, Mode=OneWay}" Text="{x:Bind ViewModel.ChargeAndStateDisplay, Mode=OneWay}" />
                </StackPanel>

                <Grid
                    Grid.Row="2"
                    Margin="0,12,0,0"
                    ColumnSpacing="8"
                    RowSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="10"
                        Background="#1AFFFFFF"
                        CornerRadius="10">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Battery State" />
                            <TextBlock
                                FontSize="26"
                                Foreground="{x:Bind ViewModel.StateBrush, Mode=OneWay}"
                                Text="{x:Bind ViewModel.StateDisplay, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="10"
                        Background="#1AFFFFFF"
                        CornerRadius="10">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Power State" />
                            <TextBlock
                                FontSize="26"
                                Foreground="{x:Bind ViewModel.PowerBrush, Mode=OneWay}"
                                Text="{x:Bind ViewModel.PowerDisplay, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="10"
                        Background="#1AFFFFFF"
                        CornerRadius="10">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="{x:Bind ViewModel.RateKind, Mode=OneWay}" />
                            <TextBlock
                                FontSize="26"
                                Foreground="{StaticResource StatusWarningBrush}"
                                Text="{x:Bind ViewModel.RateDisplay, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="3"
                        Padding="10"
                        Background="#1AFFFFFF"
                        CornerRadius="10">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Battery Voltage (V)" />
                            <TextBlock
                                FontSize="26"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{x:Bind ViewModel.VoltageDisplay, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Column="4"
                        Padding="10"
                        Background="#1AFFFFFF"
                        CornerRadius="10">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Battery Cycles" />
                            <TextBlock
                                FontSize="26"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{x:Bind ViewModel.CyclesDisplay, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Grid.Column="0"
                        Padding="10"
                        Background="#1AFFFFFF"
                        CornerRadius="10">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Nominal Voltage (V)" />
                            <TextBlock
                                FontSize="26"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{x:Bind ViewModel.DesignVoltage, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Grid.Column="1"
                        Padding="10"
                        Background="#1AFFFFFF"
                        CornerRadius="10">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Battery Design Capacity (Ah)" />
                            <TextBlock
                                FontSize="26"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{x:Bind ViewModel.DesignCapacityAmpereHours, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Grid.Column="2"
                        Padding="10"
                        Background="#1AFFFFFF"
                        CornerRadius="10">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Battery Remaining Capacity (Ah)" />
                            <TextBlock
                                FontSize="26"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{x:Bind ViewModel.RemainingCapacityAmpereHours, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Grid.Column="3"
                        Padding="10"
                        Background="#1AFFFFFF"
                        CornerRadius="10">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Battery Last Full Charge (Ah)" />
                            <TextBlock
                                FontSize="26"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{x:Bind ViewModel.LastFullChargeCapacityAmpereHours, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border
                        Grid.Row="1"
                        Grid.Column="4"
                        Padding="10"
                        Background="#1AFFFFFF"
                        CornerRadius="10">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource TextSecondaryBrush}" Text="Battery Health" />
                            <TextBlock
                                FontSize="26"
                                Foreground="{StaticResource TextPrimaryBrush}"
                                Text="{x:Bind ViewModel.BatteryLife, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid
                    Grid.Row="3"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border
                        Grid.Column="0"
                        Padding="8"
                        Background="#1AFFFFFF"
                        CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Margin="0,0,0,4"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Charge (%)" />
                            <lvc:CartesianChart
                                Grid.Row="1"
                                Height="160"
                                AutoUpdateEnabled="True"
                                Background="Transparent"
                                LegendPosition="Hidden"
                                TooltipPosition="Top">
                                <lvc:CartesianChart.Series>
                                    <lvc:SeriesCollection>
                                        <lvc:XamlLineSeries
                                            AnimationsSpeed="0"
                                            Fill="{x:Null}"
                                            GeometryFill="{x:Null}"
                                            GeometryStroke="{x:Null}"
                                            Stroke="{lvc:SolidColorPaint Color='#FF8AB7E8', StrokeWidth='2'}"
                                            Values="{x:Bind ViewModel.ChargeHistory, Mode=OneWay}" />
                                    </lvc:SeriesCollection>
                                </lvc:CartesianChart.Series>
                                <lvc:CartesianChart.XAxes>
                                    <lvc:AxesCollection>
                                        <lvc:XamlDateTimeAxis
                                            AnimationsSpeed="0"
                                            CustomSeparators="{x:Bind ViewModel.ChargeSeparators, Mode=OneWay}"
                                            DateFormatter="{x:Bind ViewModel.LabelsFormatter, Mode=OneWay}"
                                            Interval="0:10:0"
                                            LabelsPaint="{lvc:SolidColorPaint Color='#FFD7D8FF'}"
                                            MaxLimit="{x:Bind ViewModel.ChargeMax, Mode=OneWay}"
                                            MinLimit="{x:Bind ViewModel.ChargeMin, Mode=OneWay}"
                                            SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                            ShowSeparatorLines="True"
                                            TextSize="12" />
                                    </lvc:AxesCollection>
                                </lvc:CartesianChart.XAxes>
                                <lvc:CartesianChart.YAxes>
                                    <lvc:AxesCollection>
                                        <lvc:XamlAxis
                                            AnimationsSpeed="0"
                                            LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                            MaxLimit="100"
                                            MinLimit="0"
                                            SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                            ShowSeparatorLines="True"
                                            TextSize="9" />
                                    </lvc:AxesCollection>
                                </lvc:CartesianChart.YAxes>
                            </lvc:CartesianChart>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Column="1"
                        Padding="8"
                        Background="#1AFFFFFF"
                        CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Margin="0,0,0,4"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="{x:Bind ViewModel.RateKind, Mode=OneWay}" />
                            <lvc:CartesianChart
                                Grid.Row="1"
                                Height="160"
                                AutoUpdateEnabled="True"
                                Background="Transparent"
                                LegendPosition="Hidden"
                                TooltipPosition="Top">
                                <lvc:CartesianChart.Series>
                                    <lvc:SeriesCollection>
                                        <lvc:XamlLineSeries
                                            AnimationsSpeed="0"
                                            Fill="{x:Null}"
                                            GeometryFill="{x:Null}"
                                            GeometryStroke="{x:Null}"
                                            Stroke="{lvc:SolidColorPaint Color='#FFC5994E', StrokeWidth='2'}"
                                            Values="{x:Bind ViewModel.CurrentHistory, Mode=OneWay}" />
                                    </lvc:SeriesCollection>
                                </lvc:CartesianChart.Series>
                                <lvc:CartesianChart.XAxes>
                                    <lvc:AxesCollection>
                                        <lvc:XamlDateTimeAxis
                                            AnimationsSpeed="0"
                                            CustomSeparators="{x:Bind ViewModel.CurrentSeparators, Mode=OneWay}"
                                            DateFormatter="{x:Bind ViewModel.LabelsFormatter, Mode=OneWay}"
                                            Interval="0:10:0"
                                            LabelsPaint="{lvc:SolidColorPaint Color='#FFD7D8FF'}"
                                            MaxLimit="{x:Bind ViewModel.CurrentMax, Mode=OneWay}"
                                            MinLimit="{x:Bind ViewModel.CurrentMin, Mode=OneWay}"
                                            SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                            ShowSeparatorLines="True"
                                            TextSize="12" />
                                    </lvc:AxesCollection>
                                </lvc:CartesianChart.XAxes>
                                <lvc:CartesianChart.YAxes>
                                    <lvc:AxesCollection>
                                        <lvc:XamlAxis
                                            AnimationsSpeed="0"
                                            LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                            SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                            ShowSeparatorLines="True"
                                            TextSize="9" />
                                    </lvc:AxesCollection>
                                </lvc:CartesianChart.YAxes>
                            </lvc:CartesianChart>
                        </Grid>
                    </Border>

                    <Border
                        Grid.Column="2"
                        Padding="8"
                        Background="#1AFFFFFF"
                        CornerRadius="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock
                                Margin="0,0,0,4"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                Text="Battery Voltage (V)" />
                            <lvc:CartesianChart
                                Grid.Row="1"
                                Height="160"
                                AutoUpdateEnabled="True"
                                Background="Transparent"
                                LegendPosition="Hidden"
                                TooltipPosition="Top">
                                <lvc:CartesianChart.Series>
                                    <lvc:SeriesCollection>
                                        <lvc:XamlLineSeries
                                            AnimationsSpeed="0"
                                            Fill="{x:Null}"
                                            GeometryFill="{x:Null}"
                                            GeometryStroke="{x:Null}"
                                            Stroke="{lvc:SolidColorPaint Color='#FFD7D8FF', StrokeWidth='2'}"
                                            Values="{x:Bind ViewModel.VoltageHistory, Mode=OneWay}" />
                                    </lvc:SeriesCollection>
                                </lvc:CartesianChart.Series>
                                <lvc:CartesianChart.XAxes>
                                    <lvc:AxesCollection>
                                        <lvc:XamlDateTimeAxis
                                            AnimationsSpeed="0"
                                            CustomSeparators="{x:Bind ViewModel.VoltageSeparators, Mode=OneWay}"
                                            DateFormatter="{x:Bind ViewModel.LabelsFormatter, Mode=OneWay}"
                                            Interval="0:10:0"
                                            LabelsPaint="{lvc:SolidColorPaint Color='#FFD7D8FF'}"
                                            MaxLimit="{x:Bind ViewModel.VoltageMax, Mode=OneWay}"
                                            MinLimit="{x:Bind ViewModel.VoltageMin, Mode=OneWay}"
                                            SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                            ShowSeparatorLines="True"
                                            TextSize="12" />
                                    </lvc:AxesCollection>
                                </lvc:CartesianChart.XAxes>
                                <lvc:CartesianChart.YAxes>
                                    <lvc:AxesCollection>
                                        <lvc:XamlAxis
                                            AnimationsSpeed="0"
                                            LabelsPaint="{lvc:SolidColorPaint Color='FFD7D8FF'}"
                                            MaxLimit="18"
                                            MinLimit="10"
                                            SeparatorsPaint="{lvc:SolidColorPaint Color='485D5E73'}"
                                            ShowSeparatorLines="True"
                                            TextSize="9" />
                                    </lvc:AxesCollection>
                                </lvc:CartesianChart.YAxes>
                            </lvc:CartesianChart>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </controls:ElevatedCard>
    </Border>
</UserControl>
