<UserControl
    x:Class="SubZeroFramework.Controls.Dashboard.FanQuickControlCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:SubZeroFramework.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        Padding="16,14"
        Background="{StaticResource SurfaceCardBrush}"
        BorderBrush="{StaticResource SurfaceOutlineBrush}"
        BorderThickness="1"
        CornerRadius="12">
        <Grid RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  Header: name + slot | function chip  -->
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="1">
                    <TextBlock
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource TextPrimaryBrush}"
                        Text="{x:Bind Model.Fan.Snapshot.DisplayName, Mode=OneWay}" />
                    <TextBlock
                        FontSize="11.5"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="{x:Bind Model.Fan.SlotLabel, Mode=OneWay}" />
                </StackPanel>
                <Border
                    Grid.Column="1"
                    Height="26"
                    Padding="10,0"
                    VerticalAlignment="Top"
                    Background="{StaticResource CardBackgroundBrush}"
                    CornerRadius="13">
                    <StackPanel
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="5">
                        <material:MaterialIcon
                            Width="12"
                            Height="12"
                            VerticalAlignment="Center"
                            Foreground="{StaticResource StatusInfoBrush}"
                            Kind="{x:Bind Model.FunctionChipIcon, Mode=OneWay}" />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="11.5"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{x:Bind Model.FunctionChipLabel, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Body: ring gauge | now driving + duty bar  -->
            <Grid Grid.Row="1" ColumnSpacing="14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Width="76" Height="76">
                    <controls:BandRingGaugeView Fan="{x:Bind Model.Fan, Mode=OneWay}" RingThickness="6" />
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="17"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TextPrimaryBrush}"
                            Text="{x:Bind Model.Fan.FanSpeedValueDisplay, Mode=OneWay}" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="10"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            Text="{x:Bind Model.Fan.FanSpeedUnitSuffix, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Spacing="4">
                    <TextBlock
                        FontSize="11.5"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        Text="Now driving" />
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource StatusInfoBrush}"
                        Text="{x:Bind Model.NowDrivingText, Mode=OneWay}" />
                    <ProgressBar
                        Margin="0,4,0,0"
                        Background="{StaticResource SurfaceWellBrush}"
                        Foreground="{StaticResource BrandPrimaryBrush}"
                        Maximum="100"
                        Value="{x:Bind Model.DutyBarValue, Mode=OneWay}" />
                </StackPanel>
            </Grid>

            <!--  Read-only mode indicator: the fan is controlled from Fan Curve Profiles, so these segments
                  only REFLECT the active mode (including Curve, which the old buttons could clobber).  -->
            <Border
                Grid.Row="2"
                Height="38"
                Padding="4"
                Background="{StaticResource SurfaceWellBrush}"
                CornerRadius="8">
                <Grid ColumnSpacing="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{x:Bind Model.AutoSegmentBackground, Mode=OneWay}" CornerRadius="6">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="12.5"
                            Foreground="{x:Bind Model.AutoSegmentForeground, Mode=OneWay}"
                            Text="Auto" />
                    </Border>
                    <Border
                        Grid.Column="1"
                        Background="{x:Bind Model.ManualSegmentBackground, Mode=OneWay}"
                        CornerRadius="6">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="12.5"
                            Foreground="{x:Bind Model.ManualSegmentForeground, Mode=OneWay}"
                            Text="Manual" />
                    </Border>
                    <Border
                        Grid.Column="2"
                        Background="{x:Bind Model.MaxSegmentBackground, Mode=OneWay}"
                        CornerRadius="6">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="12.5"
                            Foreground="{x:Bind Model.MaxSegmentForeground, Mode=OneWay}"
                            Text="Max" />
                    </Border>
                    <Border
                        Grid.Column="3"
                        Background="{x:Bind Model.CurveSegmentBackground, Mode=OneWay}"
                        CornerRadius="6">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="12.5"
                            Foreground="{x:Bind Model.CurveSegmentForeground, Mode=OneWay}"
                            Text="Curve" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
