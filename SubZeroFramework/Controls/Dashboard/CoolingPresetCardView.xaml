<UserControl
    x:Class="SubZeroFramework.Controls.Dashboard.CoolingPresetCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:material="using:Material.Icons.UNO"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border
        MinHeight="96"
        Padding="16,12"
        Background="{StaticResource CardBackgroundBrush}"
        BorderBrush="{x:Bind Model.CardBorderBrush, Mode=OneWay}"
        BorderThickness="1.5"
        CornerRadius="12">
        <Grid RowSpacing="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <material:MaterialIcon
                    Width="20"
                    Height="20"
                    HorizontalAlignment="Left"
                    Foreground="{StaticResource StatusInfoBrush}"
                    Kind="{x:Bind Model.IconKind, Mode=OneWay}" />
                <material:MaterialIcon
                    Width="16"
                    Height="16"
                    HorizontalAlignment="Right"
                    Foreground="{StaticResource BrandPrimaryBrush}"
                    Kind="CheckCircle"
                    Visibility="{x:Bind Model.CheckVisibility, Mode=OneWay}" />
            </Grid>

            <TextBlock
                Grid.Row="1"
                FontSize="14.5"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                Text="{x:Bind Model.Name, Mode=OneWay}" />

            <TextBlock
                Grid.Row="2"
                FontSize="12"
                Foreground="{StaticResource TextSecondaryBrush}"
                Text="{x:Bind Model.Description, Mode=OneWay}"
                TextWrapping="WrapWholeWords" />
        </Grid>
    </Border>
</UserControl>
