      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-service",
      // If you have changed target frameworks, make sure to update the program path.
      "program": "${workspaceFolder}/SubZeroFramework.Service/bin/Debug/net10.0/SubZeroFramework.Service.dll",
      "args": [],
