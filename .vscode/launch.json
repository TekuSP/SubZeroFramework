      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-windows",
      // If you have changed target frameworks, make sure to update the program path.
      "program": "${workspaceFolder}/SubZeroFramework/bin/Debug/net10.0-windows10.0.26100/SubZeroFramework.exe",
      "args": [],
