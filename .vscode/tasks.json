{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-linux",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/SubZeroFramework/SubZeroFramework.csproj",
        "/property:GenerateFullPaths=true",
        "/property:TargetFramework=net10.0-desktop",
        "/v:minimal",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": false
      },
    },
    {
      "label": "publish-linux",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/SubZeroFramework/SubZeroFramework.csproj",
        "/property:GenerateFullPaths=true",
        "/property:TargetFramework=net10.0-desktop",
        "/v:minimal",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": {
        "kind": "none",
        "isDefault": false
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-windows",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/SubZeroFramework/SubZeroFramework.csproj",
        "/property:GenerateFullPaths=true",
        "/property:TargetFramework=net10.0-windows10.0.26100",
        "/v:minimal",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "publish-windows",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/SubZeroFramework/SubZeroFramework.csproj",
        "/property:GenerateFullPaths=true",
        "/property:TargetFramework=net10.0-windows10.0.26100",
        "/v:minimal",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": {
        "kind": "none",
        "isDefault": false
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-service",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/SubZeroFramework.Service/SubZeroFramework.Service.csproj",
        "/property:GenerateFullPaths=true",
        "/v:minimal",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "test-service",
      "command": "dotnet",
      "type": "process",
      "args": [
        "test",
        "${workspaceFolder}/SubZeroFramework.Tests/SubZeroFramework.Tests.csproj",
        "/property:GenerateFullPaths=true",
        "/v:minimal",
        "/consoleloggerparameters:NoSummary"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "test",
        "isDefault": true
      },
    },
    {
      "label": "build-all",
      "dependsOn": [
        "build-service",
        "build-linux",
        "build-windows"
      ],
      "dependsOrder": "sequence",
      "group": {
        "kind": "build",
        "isDefault": true
      },
    },
    {
      "label": "build-all-windows",
      "dependsOn": [
        "build-service",
        "build-windows"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [
        "$msCompile"
      ],
      "group": {
        "kind": "build",
        "isDefault": false
      },
    },
    // ── Local release builds (no GitHub Actions) ──────────────────────────────────────────────────
    // Produces the same artifact layout as CI: the app at the payload root, the service under
    // service-package\windows\ (where the app's helper discovery looks), and the Inno Setup installer.
    // Output lands in artifacts\windows\. Requires Inno Setup for the installer step
    // (winget install JRSoftware.InnoSetup); without it the payload is still produced.
    {
      "label": "release: windows x64 (local)",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/packaging/windows/build-release-windows.ps1",
        "-Arch", "x64"
      ],
      "problemMatcher": "$msCompile",
      "group": { "kind": "none", "isDefault": false },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "release: windows arm64 (local)",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/packaging/windows/build-release-windows.ps1",
        "-Arch", "arm64"
      ],
      "problemMatcher": "$msCompile",
      "group": { "kind": "none", "isDefault": false },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      // Payload only — skips Inno Setup. Handy for checking the layout without installing ISCC.
      "label": "release: windows payload only (no installer)",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/packaging/windows/build-release-windows.ps1",
        "-SkipInstaller"
      ],
      "problemMatcher": "$msCompile",
      "group": { "kind": "none", "isDefault": false },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    // ── Linux release via WSL2 ────────────────────────────────────────────────────────────────────
    // Builds the real .deb/.rpm/tarball/AUR artifacts inside a WSL distro, against this same working
    // tree — no copying, no second checkout. `type: process` (not `shell`) so the argument containing
    // $(wslpath ...) reaches bash verbatim instead of being mangled by PowerShell quoting first.
    // wslpath translates ${workspaceFolder} (a Windows path) to its /mnt/... form inside the distro.
    {
      "label": "release: linux (WSL) — install prerequisites",
      "detail": "One-time per distro: dpkg-deb, rpmbuild, makepkg. Prompts for your sudo password.",
      "type": "process",
      "command": "wsl.exe",
      "args": [
        "-d", "${input:wslDistro}",
        "--",
        "bash", "-lc",
        "sudo pacman -S --needed --noconfirm dpkg rpm-tools base-devel git && echo && echo 'Prerequisites installed.' && for c in dotnet dpkg-deb rpmbuild makepkg; do printf '  %-10s %s\\n' \"$c\" \"$(command -v $c || echo MISSING)\"; done"
      ],
      "problemMatcher": [],
      "group": { "kind": "none", "isDefault": false },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "release: linux (WSL)",
      "detail": "Publishes the UI + service and builds .deb/.rpm/tarball/AUR into artifacts/linux/.",
      "type": "process",
      "command": "wsl.exe",
      "args": [
        "-d", "${input:wslDistro}",
        "--",
        "bash", "-lc",
        "cd \"$(wslpath '${workspaceFolder}')\" && ./packaging/linux/build-release-linux.sh"
      ],
      "problemMatcher": [],
      "group": { "kind": "none", "isDefault": false },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "release: linux (WSL) — shell at repo",
      "detail": "Opens an interactive shell in the distro, already cd'd into this working tree.",
      "type": "process",
      "command": "wsl.exe",
      "args": [
        "-d", "${input:wslDistro}",
        "--",
        "bash", "-lc",
        "cd \"$(wslpath '${workspaceFolder}')\" && exec bash -l"
      ],
      "problemMatcher": [],
      "group": { "kind": "none", "isDefault": false },
      "presentation": { "reveal": "always", "panel": "dedicated" }
    }
  ],
  "inputs": [
    {
      // Both are Arch. `archlinux` is the WSL default and starts cleanly; `Arch` has a newer SDK but
      // reported a systemd user-session error, so it is not the default choice here.
      "id": "wslDistro",
      "type": "pickString",
      "description": "Which WSL distro should build the Linux release?",
      "options": ["archlinux", "Arch", "Debian"],
      "default": "archlinux"
    }
  ]
}
